  (window as any).toggleCampusStrategy = (item: HTMLElement) => {
    const tactics = item.querySelector('.campus-strategy-tactics') as HTMLElement;
    const chevron = item.querySelector('.campus-strategy-chevron') as HTMLElement;
    const isHidden = tactics.classList.contains('hidden');
    tactics.classList.toggle('hidden', !isHidden);
    chevron.style.transform = isHidden ? 'rotate(180deg)' : '';
  };

  // ═══════════════════════════════════════════════
  //  UNIVERSITY EDIT MODAL
  // ═══════════════════════════════════════════════
  let deletedTacticIds: number[] = [];
  let editModalReload: () => void = loadUniversityStrategies;

  function openUnivEditModal() {
    const el = document.getElementById('univEditModal')!;
    el.classList.remove('hidden');
    el.classList.add('flex');
  }
  function closeUnivEditModal() {
    const el = document.getElementById('univEditModal')!;
    el.classList.add('hidden');
    el.classList.remove('flex');
    deletedTacticIds = [];
    (document.getElementById('univEditForm') as HTMLFormElement).reset();
    (document.getElementById('univEditTacticsList') as HTMLElement).innerHTML = '';
    (document.getElementById('univEditError') as HTMLElement).classList.add('hidden');
  }

  function renderTacticRows(tactics: Tactic[], strategyNo: number) {
    const list = document.getElementById('univEditTacticsList')!;
    list.innerHTML = '';
    tactics.forEach((t, ti) => {
      const seq = t.orderSequence ?? (ti + 1);
      const code = `SO${strategyNo}.${seq}`;
      list.appendChild(makeTacticRow(t.id, seq, code, t.name));
    });
  }

  function makeTacticRow(id: number | null, seq: number, code: string, name: string): HTMLElement {
    const row = document.createElement('div');
    row.className = 'flex items-center gap-2 group';
    row.dataset.tacticId = id !== null ? String(id) : 'new';
    row.innerHTML = `
      <span class="font-mono text-xs font-semibold text-[#0c2957] shrink-0 w-14 text-right">${code}</span>
      <span class="text-xs text-gray-400 shrink-0">:</span>
      <input type="text" value="${name.replace(/"/g, '&quot;')}"
        data-tactic-seq="${seq}"
        class="tactic-name-input flex-1 border border-gray-200 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#0c2957]/20 focus:border-[#0c2957]"
        placeholder="ชื่อกลยุทธ์" />
      <button type="button" title="ลบ"
        class="tactic-delete-btn shrink-0 p-1.5 text-gray-300 hover:text-red-500 hover:bg-red-50 rounded-lg transition-colors opacity-0 group-hover:opacity-100">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
        </svg>
      </button>`;

    row.querySelector('.tactic-delete-btn')!.addEventListener('click', () => {
      if (id !== null) deletedTacticIds.push(id);
      row.remove();
      renumberTacticRows();
    });
    return row;
  }

  function renumberTacticRows() {
    const strategyNo = Number((document.getElementById('univEditOrder') as HTMLInputElement).value) || 1;
    document.querySelectorAll('#univEditTacticsList [data-tactic-id]').forEach((row, i) => {
      const seq = i + 1;
      const code = `SO${strategyNo}.${seq}`;
      (row as HTMLElement).querySelector('span.font-mono')!.textContent = code;
      const input = (row as HTMLElement).querySelector('input') as HTMLInputElement;
      input.dataset.tacticSeq = String(seq);
    });
  }

  // ใช้ event delegation บน univAccordion
  document.getElementById('univAccordion')?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.univ-edit-btn') as HTMLElement | null;
    if (!btn) return;
    e.stopPropagation();
    const id = Number(btn.dataset.univEditId);
    const order = btn.dataset.univEditOrder!;
    const name = btn.dataset.univEditName!;
    const strategy = univStrategyStore.get(id);

    editModalReload = loadUniversityStrategies;
    deletedTacticIds = [];
    (document.getElementById('univEditId') as HTMLInputElement).value = String(id);
    (document.getElementById('univEditOrder') as HTMLInputElement).value = order;
    (document.getElementById('univEditName') as HTMLTextAreaElement).value = name;
    (document.getElementById('univEditFiscalPlan') as HTMLInputElement).value = strategy?.fiscalPlan ?? '';

    if (strategy) {
      renderTacticRows(strategy.tactics, Number(order));
    }
    openUnivEditModal();
  });

  // event delegation บน campusAccordion (แก้ไข)
  document.getElementById('campusAccordion')?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.campus-edit-btn') as HTMLElement | null;
    if (!btn) return;
    e.stopPropagation();
    const id = Number(btn.dataset.campusEditId);
    const order = btn.dataset.campusEditOrder!;
    const name = btn.dataset.campusEditName!;
    const strategy = campusStrategyStore.get(id);

    editModalReload = loadCampusStrategies;
    deletedTacticIds = [];
    (document.getElementById('univEditId') as HTMLInputElement).value = String(id);
    (document.getElementById('univEditOrder') as HTMLInputElement).value = order;
    (document.getElementById('univEditName') as HTMLTextAreaElement).value = name;
    (document.getElementById('univEditFiscalPlan') as HTMLInputElement).value = strategy?.fiscalPlan ?? '';

    if (strategy) {
      renderTacticRows(strategy.tactics, Number(order));
    }
    openUnivEditModal();
  });

  // ปุ่มเพิ่มกลยุทธ์
  document.getElementById('btnAddTactic')?.addEventListener('click', () => {
    const strategyNo = Number((document.getElementById('univEditOrder') as HTMLInputElement).value) || 1;
    const list = document.getElementById('univEditTacticsList')!;
    const seq = list.children.length + 1;
    const code = `SO${strategyNo}.${seq}`;
    const row = makeTacticRow(null, seq, code, '');
    list.appendChild(row);
    (row.querySelector('.tactic-name-input') as HTMLInputElement)?.focus();
  });

  document.getElementById('univEditClose')?.addEventListener('click', closeUnivEditModal);
  document.getElementById('univEditCancel')?.addEventListener('click', closeUnivEditModal);
  document.getElementById('univEditBackdrop')?.addEventListener('click', closeUnivEditModal);

  document.getElementById('univEditForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const strategyId = (document.getElementById('univEditId') as HTMLInputElement).value;
    const name = (document.getElementById('univEditName') as HTMLTextAreaElement).value.trim();
    const orderList = (document.getElementById('univEditOrder') as HTMLInputElement).value;
    const fiscalPlan = (document.getElementById('univEditFiscalPlan') as HTMLInputElement).value || null;
    const errEl = document.getElementById('univEditError')!;
    const submitBtn = document.getElementById('univEditSubmit')!;

    if (!name) {
      errEl.textContent = 'กรุณาระบุชื่อยุทธศาสตร์';
      errEl.classList.remove('hidden');
      return;
    }

    submitBtn.textContent = 'กำลังบันทึก...';
    submitBtn.setAttribute('disabled', 'true');
    errEl.classList.add('hidden');

    const token = localStorage.getItem('ku_access_token');
    const headers = { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` };

    try {
      // 1. อัปเดตยุทธศาสตร์
      const r1 = await fetch(`http://localhost:3000/api/strategies/${strategyId}`, {
        method: 'PUT', headers,
        body: JSON.stringify({ name, orderList: orderList ? Number(orderList) : null, fiscalPlan }),
      });
      const d1 = await r1.json();
      if (!r1.ok || !d1.success) throw new Error(d1.message ?? 'บันทึกยุทธศาสตร์ไม่สำเร็จ');

      // 2. ลบกลยุทธ์ที่ถูก mark ลบ
      for (const tid of deletedTacticIds) {
        await fetch(`http://localhost:3000/api/strategies/tactics/${tid}`, { method: 'DELETE', headers });
      }

      // 3. บันทึกกลยุทธ์ในรายการ (แก้ไข / เพิ่มใหม่)
      const tacticRows = document.querySelectorAll('#univEditTacticsList [data-tactic-id]');
      for (let i = 0; i < tacticRows.length; i++) {
        const row = tacticRows[i] as HTMLElement;
        const tid = row.dataset.tacticId!;
        const input = row.querySelector('.tactic-name-input') as HTMLInputElement;
        const tacticName = input.value.trim();
        const seq = i + 1;
        if (!tacticName) continue;

        if (tid === 'new') {
          await fetch(`http://localhost:3000/api/strategies/${strategyId}/tactics`, {
            method: 'POST', headers,
            body: JSON.stringify({ name: tacticName, orderSequence: seq }),
          });
        } else {
          await fetch(`http://localhost:3000/api/strategies/tactics/${tid}`, {
            method: 'PUT', headers,
            body: JSON.stringify({ name: tacticName, orderSequence: seq }),
          });
        }
      }

      closeUnivEditModal();
      editModalReload();
      (window as any).showToast('บันทึกการแก้ไขยุทธศาสตร์สำเร็จ');
    } catch (err: any) {
      errEl.textContent = err.message ?? 'เกิดข้อผิดพลาด ไม่สามารถเชื่อมต่อเซิร์ฟเวอร์ได้';
      errEl.classList.remove('hidden');
    } finally {
      submitBtn.textContent = 'บันทึก';
      submitBtn.removeAttribute('disabled');
    }
  });

  async function loadUniversityStrategies() {
    try {
      const res = await apiFetch('http://localhost:3000/api/strategies/university');
      if (!res || !res.ok) return;
      const json = await res.json();
      if (!json.success) return;

      univRawData = json.data as UnivStrategy[];
      // ลบ loading indicator
      document.getElementById('univLoading')?.remove();
      if (activeTab === 'university') {
        populateYearFilter(univRawData.map(s => s.fiscalPlan));
        filterAndRenderAccordion();
      } else {
        renderUnivAccordion(univRawData);
      }
    } catch {
      document.getElementById('univLoading')!.innerHTML =
        '<p class="text-sm text-red-400 py-4 text-center">โหลดข้อมูลไม่สำเร็จ</p>';
    }
  }

  async function loadCampusStrategies() {
    try {
      const res = await apiFetch('http://localhost:3000/api/strategies/campus');
      if (!res || !res.ok) return;
      const json = await res.json();
      if (!json.success) return;

      campusRawData = json.data as UnivStrategy[];
      document.getElementById('campusLoading')?.remove();
      if (activeTab === 'campus') {
        populateYearFilter(campusRawData.map(s => s.fiscalPlan));
        filterAndRenderAccordion();
      } else {
        renderCampusAccordion(campusRawData);
      }
    } catch {
      const el = document.getElementById('campusLoading');
      if (el) el.innerHTML = '<p class="text-sm text-red-400 py-4 text-center">โหลดข้อมูลไม่สำเร็จ</p>';
    }
  }

  // ═══════════════════════════════════════════════
  //  DEPARTMENT STRATEGIES — ดึงจาก API + Accordion
  // ═══════════════════════════════════════════════
  interface DeptTactic {
    id: number;
    name: string;
    order: number | null;
  }
  interface DeptStrategy {
    id: number;
    name: string;
    year: number | null;
    fiscalPlan?: string | null;
    tactics: DeptTactic[];
  }

  const deptStrategyStore = new Map<number, DeptStrategy>();

  function renderDeptAccordion(data: DeptStrategy[]) {
    deptStrategyStore.clear();
    data.forEach(s => deptStrategyStore.set(s.id, s));

    const container = document.getElementById('deptAccordion')!;

    if (data.length === 0) {
      container.innerHTML = `
        <div class="px-5 py-12 text-center text-sm text-gray-400">ไม่พบข้อมูลยุทธศาสตร์ระดับส่วนงาน</div>`;
      return;
    }

    container.innerHTML = data.map((s, si) => {
      const strategyNo = si + 1;
      const tacticCount = s.tactics.length;

      const tacticRows = s.tactics.map((t, ti) => {
        const tacticCode = `SD${strategyNo}.${t.order ?? (ti + 1)}`;
        return `
          <div class="flex items-start gap-3 py-2">
            <span class="font-mono text-sm font-semibold text-[#7d8416] shrink-0 mt-0.5 min-w-[2.5rem]">${tacticCode}</span>
            <span class="text-sm text-gray-400 shrink-0 mt-0.5">:</span>
            <span class="text-sm text-gray-700 leading-relaxed">${t.name}</span>
          </div>`;
      }).join('');

      const yearLabel = s.year ? `ปีงบ ${s.year}` : '';
      const fiscalLabel = s.fiscalPlan ? `แผน ${s.fiscalPlan}` : '';
      const metaLabel = [yearLabel, fiscalLabel].filter(Boolean).join(' · ');

      return `
        <div class="dept-strategy-item">
          <!-- Strategy header row -->
          <div class="flex items-start gap-3 px-5 py-4 hover:bg-yellow-50/40 transition-colors">
            <!-- Toggle area -->
            <button type="button" class="flex items-start gap-3 flex-1 min-w-0 text-left"
              onclick="toggleDeptStrategy(this.closest('.dept-strategy-item'))">
              <div class="w-7 h-7 rounded-lg bg-[#b2bb1e] text-white text-xs font-bold flex items-center justify-center shrink-0 mt-0.5">
                ${strategyNo}
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-semibold text-[#7d8416] leading-snug">
                  ยุทธศาสตร์ที่ ${strategyNo} : <span class="font-normal text-gray-800">${s.name}</span>
                </p>
                <p class="text-xs text-gray-500 mt-1">
                  ประกอบด้วย <span class="font-semibold text-[#b2bb1e]">${tacticCount}</span> กลยุทธ์${metaLabel ? ` · ${metaLabel}` : ''}
                </p>
              </div>
            </button>
            <!-- Actions -->
            <div class="flex items-center gap-2 shrink-0 mt-0.5">
              <button type="button"
                data-dept-edit-id="${s.id}"
                data-dept-edit-order="${strategyNo}"
                class="dept-edit-btn flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-[#7d8416] border border-[#7d8416]/30 rounded-lg hover:bg-[#b2bb1e] hover:text-white hover:border-[#b2bb1e] transition-colors">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                </svg>
                แก้ไข
              </button>
              <button type="button"
                data-dept-delete-id="${s.id}"
                data-dept-delete-name="${s.name.replace(/"/g, '&quot;')}"
                class="dept-delete-btn flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-red-500 border border-red-200 rounded-lg hover:bg-red-600 hover:text-white hover:border-red-600 transition-colors">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                </svg>
                ลบ
              </button>
              <svg class="w-4 h-4 text-gray-400 shrink-0 transition-transform duration-200 dept-strategy-chevron cursor-pointer"
                fill="none" stroke="currentColor" viewBox="0 0 24 24"
