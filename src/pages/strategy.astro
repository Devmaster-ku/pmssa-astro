  document.getElementById('strategyAddForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const level = (document.getElementById('addLevel') as HTMLSelectElement).value as StrategyLevel;
    const name = (document.getElementById('addName') as HTMLTextAreaElement).value.trim();
    const fiscalPlan = (document.getElementById('addFiscalPlan') as HTMLInputElement).value.trim() || null;
    const orderVal = (document.getElementById('addOrder') as HTMLInputElement).value;
    const orderList = orderVal ? Number(orderVal) : null;
    const errEl = document.getElementById('strategyAddError')!;
    const submitBtn = document.getElementById('strategyAddSubmit')!;

    if (!name) {
      errEl.textContent = 'กรุณาระบุชื่อยุทธศาสตร์';
      errEl.classList.remove('hidden');
      return;
    }
    errEl.classList.add('hidden');
    submitBtn.textContent = 'กำลังบันทึก...';
    submitBtn.setAttribute('disabled', 'true');

    const token = localStorage.getItem('ku_access_token');
    const headers = { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` };

    try {
      let endpoint = '';
      let bodyData: Record<string, unknown> = { name, fiscalPlan };

      if (level === 'university') {
        endpoint = 'http://localhost:3000/api/strategies';
        bodyData = { ...bodyData, orderList, campus: 'บางเขน' };
      } else if (level === 'campus') {
        endpoint = 'http://localhost:3000/api/strategies';
        bodyData = { ...bodyData, orderList, campus: currentCampusName ?? 'บางเขน' };
      } else if (level === 'division') {
        endpoint = 'http://localhost:3000/api/strategies/departments';
        bodyData = { ...bodyData };
      } else if (level === 'dean') {
        endpoint = 'http://localhost:3000/api/strategies/dean';
        bodyData = { ...bodyData };
      }

      const res = await fetch(endpoint, {
        method: 'POST', headers,
        body: JSON.stringify(bodyData),
      });
      const json = await res.json();

      if (!res.ok || !json.success) {
        errEl.textContent = json.message ?? 'เกิดข้อผิดพลาด ไม่สามารถบันทึกได้';
        errEl.classList.remove('hidden');
        return;
      }

      // เพิ่มกลยุทธ์ย่อย (ถ้ามี)
      const newStrategyId = json.id;
      const tacticInputs = document.querySelectorAll('#addTacticsList .add-tactic-input') as NodeListOf<HTMLInputElement>;
      let tacticEndpoint = '';
      if (level === 'university' || level === 'campus') {
        tacticEndpoint = `http://localhost:3000/api/strategies/${newStrategyId}/tactics`;
      } else if (level === 'division') {
        tacticEndpoint = `http://localhost:3000/api/strategies/departments/${newStrategyId}/tactics`;
      } else if (level === 'dean') {
        tacticEndpoint = `http://localhost:3000/api/strategies/dean/${newStrategyId}/tactics`;
      }

      for (let i = 0; i < tacticInputs.length; i++) {
        const tacticName = tacticInputs[i].value.trim();
        if (!tacticName) continue;
        await fetch(tacticEndpoint, {
          method: 'POST', headers,
          body: JSON.stringify(
            (level === 'university' || level === 'campus')
              ? { name: tacticName, orderSequence: i + 1 }
              : { name: tacticName, order: i + 1 }
          ),
        });
      }

      closeStrategyAddModal();
      (window as any).showToast(`เพิ่ม${ADD_LEVEL_CONFIG[level]?.label ?? 'ยุทธศาสตร์'}สำเร็จ`);

      // โหลดข้อมูลใหม่ตามระดับ
      if (level === 'university') loadUniversityStrategies();
      else if (level === 'campus') loadCampusStrategies();
      else if (level === 'division') loadDepartmentStrategies();
      else if (level === 'dean') loadDeanStrategies();
      loadSummary();

    } catch {
      errEl.textContent = 'เกิดข้อผิดพลาด ไม่สามารถเชื่อมต่อเซิร์ฟเวอร์ได้';
      errEl.classList.remove('hidden');
    } finally {
      submitBtn.textContent = 'บันทึก';
      submitBtn.removeAttribute('disabled');
    }
  });

