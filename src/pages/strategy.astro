                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </div>
          </div>
          <!-- Tactics list (collapsible) -->
          <div class="dept-strategy-tactics hidden px-5 pb-4 pl-16 space-y-0.5 border-t border-yellow-50 bg-yellow-50/20">
