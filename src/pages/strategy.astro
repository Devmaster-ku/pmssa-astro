---
import AuthLayout from '../layouts/AuthenticatedLayout.astro';
---

<AuthLayout title="ยุทธศาสตร์ของมหาวิทยาลัยและส่วนงาน">

  <!-- ══════════════════════════════════════════════
       PAGE HEADER
  ═══════════════════════════════════════════════ -->
  <div class="relative rounded-sm overflow-hidden mb-6 shadow-lg"
       style="background: linear-gradient(135deg, #0c2957 0%, #0a4068 45%, #006664 100%);">
    <!-- KU lime top accent bar -->
    <div class="absolute top-0 left-0 right-0 h-1.5"
         style="background: linear-gradient(90deg, #006664, #d4de3a, #b2bb1e);"></div>
    <!-- Decorative glows -->
    <div class="absolute -right-20 -top-20 w-80 h-80 rounded-full pointer-events-none"
         style="background: radial-gradient(circle, rgba(178,187,30,0.12) 0%, transparent 65%);"></div>
    <div class="absolute inset-0 pointer-events-none opacity-[0.03]"
         style="background-image: repeating-linear-gradient(45deg, #ffffff 0, #ffffff 1px, transparent 0, transparent 12px);"></div>

    <div class="relative z-10 p-5 sm:p-6">
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <!-- Breadcrumb + Title -->
        <div class="flex items-start gap-4">
          <div class="mt-2 w-14 h-14 bg-white/10 rounded-xl flex items-center justify-center border border-white/20 shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-[#b2bb1e]" viewBox="0 0 26 26">
              <g fill="currentColor" fill-rule="evenodd" clip-rule="evenodd">
                <path d="M7.5 7v6h10.159l-1.197-1.71a2.25 2.25 0 0 1 0-2.58L17.659 7zm-1-2a1 1 0 0 0-1 1v8a1 1 0 0 0 1 1h13.08a1 1 0 0 0 .819-1.573L18.1 10.143a.25.25 0 0 1 0-.286l2.3-3.284A1 1 0 0 0 19.579 5z"/>
                <path d="M6.5 6a1 1 0 0 1 1 1v13a1 1 0 1 1-2 0V7a1 1 0 0 1 1-1"/>
                <path d="M13 24c6.075 0 11-4.925 11-11S19.075 2 13 2S2 6.925 2 13s4.925 11 11 11m0 2c7.18 0 13-5.82 13-13S20.18 0 13 0S0 5.82 0 13s5.82 13 13 13"/>
              </g>
            </svg>
          </div>
          <div>
            <nav class="flex items-center gap-1.5 text-white/90 text-xs mb-1">
              <a href="/dashboard" class="hover:text-white transition-colors">แผงควบคุม</a>
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
              <span class="text-white/80">ยุทธศาสตร์</span>
            </nav>
            <h1 class="text-white text-lg font-bold leading-tight">
              ยุทธศาสตร์ของมหาวิทยาลัยและส่วนงาน
            </h1>
            <p class="text-white/80 text-sm mt-1">กำหนดและจัดการยุทธศาสตร์ มหาวิทยาลัยเกษตรศาสตร์ ในทุกระดับ</p>
          </div>
        </div>

        <!-- Action button -->
        <button id="btnAddStrategy"
          class="shrink-0 flex items-center gap-2 px-4 py-2.5 bg-[#b2bb1e] hover:bg-[#9da61b] text-white text-sm font-semibold rounded-lg transition-colors shadow-md">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
          </svg>
          เพิ่มยุทธศาสตร์
        </button>
      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════════════
       SUMMARY STATS
  ═══════════════════════════════════════════════ -->
  <div class="grid grid-cols-2 sm:grid-cols-5 gap-3 mb-6">
    <!-- University -->
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4 flex items-center gap-3">
      <div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0"
           style="background-color: #eef2ff;">
        <svg class="w-5 h-5 text-[#0c2957]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z"/>
        </svg>
      </div>
      <div class="min-w-0">
        <p class="text-xs text-gray-500">ระดับมหาวิทยาลัย</p>
        <p class="text-lg font-bold text-[#0c2957] leading-tight" id="statUnivStrategy">—</p>
        <p class="text-xs text-gray-400" id="statUnivTactic">— กลยุทธ์</p>
      </div>
    </div>
    <!-- Campus -->
    <div id="cardCampus" class="hidden bg-white rounded-xl border border-gray-200 shadow-sm p-4 items-center gap-3">
      <div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0"
           style="background-color: #f0fdf4;">
        <svg class="w-5 h-5 text-[#006664]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
      </div>
      <div class="min-w-0">
        <p class="text-xs text-gray-500 truncate" id="labelCampus">ระดับวิทยาเขต</p>
        <p class="text-lg font-bold text-[#006664] leading-tight" id="statCampusStrategy">—</p>
        <p class="text-xs text-gray-400" id="statCampusTactic">— กลยุทธ์</p>
      </div>
    </div>
    <!-- Division -->
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4 flex items-center gap-3">
      <div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0"
           style="background-color: #fefce8;">
        <svg class="w-5 h-5 text-[#b2bb1e]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
        </svg>
      </div>
      <div class="min-w-0">
        <p class="text-xs text-gray-500">ระดับส่วนงาน/คณะ/สำนัก</p>
        <p class="text-lg font-bold text-[#b2bb1e] leading-tight" id="statDivStrategy">—</p>
        <p class="text-xs text-gray-400" id="statDivTactic">— กลยุทธ์</p>
      </div>
    </div>
    <!-- Dean -->
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4 flex items-center gap-3">
      <div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0"
           style="background-color: #fdf2f8;">
        <svg class="w-5 h-5 text-[#9d174d]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
        </svg>
      </div>
      <div class="min-w-0">
        <p class="text-xs text-gray-500">ระดับคณบดีส่วนงาน</p>
        <p class="text-lg font-bold text-[#9d174d] leading-tight" id="statDeanStrategy">—</p>
        <p class="text-xs text-gray-400" id="statDeanTactic">— กลยุทธ์</p>
      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════════════
       LEVEL TABS
  ═══════════════════════════════════════════════ -->
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">

    <!-- Tab Bar -->
    <div class="border-b border-gray-200 overflow-x-auto">
      <div class="flex min-w-max">
        <!-- Tab 1 -->
        <button data-tab="university"
          class="tab-btn active-tab flex items-center gap-2 px-5 py-3.5 text-sm font-semibold border-b-2 border-[#0c2957] text-[#0c2957] whitespace-nowrap transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z"/>
          </svg>
          ระดับมหาวิทยาลัย
        </button>
        <!-- Tab 2 -->
        <button data-tab="campus"
          class="tab-btn hidden items-center gap-2 px-5 py-3.5 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-[#006664] hover:border-[#006664] whitespace-nowrap transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          ระดับวิทยาเขต
        </button>
        <!-- Tab 3 -->
        <button data-tab="division"
          class="tab-btn flex items-center gap-2 px-5 py-3.5 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-[#b2bb1e] hover:border-[#b2bb1e] whitespace-nowrap transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
          </svg>
          ระดับส่วนงาน/คณะ/สำนัก
        </button>
        <!-- Tab 4 -->
        <button data-tab="dean"
          class="tab-btn flex items-center gap-2 px-5 py-3.5 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-[#9d174d] hover:border-[#9d174d] whitespace-nowrap transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
          ระดับคณบดีส่วนงาน
        </button>
      </div>
    </div>

    <!-- ── Toolbar (Search + Filter) ── -->
    <div class="px-4 sm:px-5 py-3 border-b border-gray-100 flex flex-col sm:flex-row sm:items-center gap-3">
      <!-- Search -->
      <div class="relative flex-1">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
        <input id="searchInput" type="text" placeholder="ค้นหายุทธศาสตร์..."
          class="w-full pl-9 pr-4 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#0c2957]/30 focus:border-[#0c2957]" />
      </div>
      <!-- Filter by year -->
      <div class="flex items-center gap-2">
        <label class="text-xs text-gray-500 whitespace-nowrap">แผนปีงบประมาณ</label>
        <select id="yearFilter"
          class="border border-gray-200 rounded-lg text-sm px-3 py-2 focus:outline-none focus:ring-2 focus:ring-[#0c2957]/30 focus:border-[#0c2957]">
          <option value="">ทั้งหมด</option>
        </select>
        <!-- Status filter -->
        <select id="statusFilter"
          class="border border-gray-200 rounded-lg text-sm px-3 py-2 focus:outline-none focus:ring-2 focus:ring-[#0c2957]/30 focus:border-[#0c2957]">
          <option value="">ทุกสถานะ</option>
          <option value="active">ใช้งาน</option>
          <option value="draft">ร่าง</option>
        </select>
      </div>
    </div>

    <!-- ── Tab Panels ── -->

    <!-- UNIVERSITY PANEL -->
    <div id="panel-university" class="tab-panel">
      <!-- Section description -->
      <div class="px-5 pt-4 pb-3 flex items-start gap-3 bg-blue-50/50 border-b border-blue-100">
        <div class="w-8 h-8 rounded-lg bg-[#0c2957] flex items-center justify-center shrink-0 mt-0.5">
          <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-semibold text-[#0c2957]">ยุทธศาสตร์ระดับมหาวิทยาลัย</p>
          <p class="text-xs text-gray-500 mt-0.5">ยุทธศาสตร์หลักของมหาวิทยาลัยเกษตรศาสตร์ กำหนดทิศทางและเป้าหมายในภาพรวมของมหาวิทยาลัย</p>
        </div>
      </div>

      <!-- Accordion list -->
      <div id="univAccordion" class="divide-y divide-gray-100">
        <!-- Loading state -->
        <div id="univLoading" class="px-5 py-12 text-center">
          <div class="flex flex-col items-center gap-2 text-gray-400">
            <svg class="w-10 h-10 opacity-30 animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
            </svg>
            <p class="text-sm">กำลังโหลดข้อมูล...</p>
          </div>
        </div>
      </div>
    </div>

    <!-- CAMPUS PANEL -->
    <div id="panel-campus" class="tab-panel hidden">
      <div class="px-5 pt-4 pb-3 flex items-start gap-3 bg-emerald-50/50 border-b border-emerald-100">
        <div class="w-8 h-8 rounded-lg bg-[#006664] flex items-center justify-center shrink-0 mt-0.5">
          <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-semibold text-[#006664]">ยุทธศาสตร์ระดับวิทยาเขต</p>
          <p class="text-xs text-gray-500 mt-0.5">ยุทธศาสตร์เฉพาะของแต่ละวิทยาเขต สอดคล้องกับยุทธศาสตร์มหาวิทยาลัยและบริบทพื้นที่</p>
        </div>
      </div>
      <!-- Accordion list -->
      <div id="campusAccordion" class="divide-y divide-gray-100">
        <!-- Loading state -->
        <div id="campusLoading" class="px-5 py-12 text-center">
          <div class="flex flex-col items-center gap-2 text-gray-400">
            <svg class="w-10 h-10 opacity-30 animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
            </svg>
            <p class="text-sm">กำลังโหลดข้อมูล...</p>
          </div>
        </div>
      </div>
    </div>

    <!-- DIVISION PANEL -->
    <div id="panel-division" class="tab-panel hidden">
      <div class="px-5 pt-4 pb-3 flex items-start gap-3 bg-yellow-50/50 border-b border-yellow-100">
        <div class="w-8 h-8 rounded-lg bg-[#b2bb1e] flex items-center justify-center shrink-0 mt-0.5">
          <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-semibold text-[#7d8416]">ยุทธศาสตร์ระดับส่วนงาน</p>
          <p class="text-xs text-gray-500 mt-0.5">ยุทธศาสตร์ของหน่วยงานที่ผู้ใช้สังกัด สอดคล้องกับยุทธศาสตร์มหาวิทยาลัย</p>
        </div>
      </div>

      <!-- Accordion list -->
      <div id="deptAccordion" class="divide-y divide-gray-100">
        <!-- Loading state -->
        <div id="deptLoading" class="px-5 py-12 text-center">
          <div class="flex flex-col items-center gap-2 text-gray-400">
            <svg class="w-10 h-10 opacity-30 animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
            </svg>
            <p class="text-sm">กำลังโหลดข้อมูล...</p>
          </div>
        </div>
      </div>
    </div>

    <!-- DEAN PANEL -->
    <div id="panel-dean" class="tab-panel hidden">
      <div class="px-5 pt-4 pb-3 flex items-start gap-3 bg-pink-50/50 border-b border-pink-100">
        <div class="w-8 h-8 rounded-lg bg-[#9d174d] flex items-center justify-center shrink-0 mt-0.5">
          <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-semibold text-[#9d174d]">ยุทธศาสตร์ระดับคณบดีส่วนงาน</p>
          <p class="text-xs text-gray-500 mt-0.5">ยุทธศาสตร์ที่กำหนดโดยคณบดีของแต่ละส่วนงาน เพื่อขับเคลื่อนพันธกิจเฉพาะ</p>
        </div>
      </div>

      <!-- Accordion list -->
      <div id="deanAccordion" class="divide-y divide-gray-100">
        <!-- Loading state -->
        <div id="deanLoading" class="px-5 py-12 text-center">
          <div class="flex flex-col items-center gap-2 text-gray-400">
            <svg class="w-10 h-10 opacity-30 animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
            </svg>
            <p class="text-sm">กำลังโหลดข้อมูล...</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Pagination Footer -->
    <div class="px-5 py-3 border-t border-gray-100 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
      <p class="text-xs text-gray-400" id="paginationInfo">— รายการ</p>
      <div class="flex items-center gap-1">
        <button class="px-3 py-1.5 text-xs border border-gray-200 rounded-lg text-gray-500 hover:bg-gray-50 disabled:opacity-40" disabled>ก่อนหน้า</button>
        <button class="px-3 py-1.5 text-xs border border-[#0c2957] rounded-lg bg-[#0c2957] text-white font-medium">1</button>
        <button class="px-3 py-1.5 text-xs border border-gray-200 rounded-lg text-gray-500 hover:bg-gray-50 disabled:opacity-40" disabled>ถัดไป</button>
      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════════════
       ADD STRATEGY MODAL (NEW DESIGN)
  ═══════════════════════════════════════════════ -->
  <div id="strategyAddModal" class="fixed inset-0 z-50 hidden items-center justify-center p-4">
    <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" id="strategyAddBackdrop"></div>
    <div class="relative bg-white rounded-2xl shadow-2xl w-full max-w-4xl flex flex-col max-h-[90vh]">
      <!-- Modal header -->
      <div class="flex items-center justify-between px-6 py-4 border-b border-gray-200 shrink-0"
           style="background: linear-gradient(135deg, #0c2957, #006664);">
        <div class="flex items-center gap-2">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
          </svg>
          <h2 class="text-white font-bold text-base">เพิ่มยุทธศาสตร์ใหม่</h2>
        </div>
        <button id="strategyAddClose" class="text-white/70 hover:text-white transition-colors">
