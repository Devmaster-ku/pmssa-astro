      renumberDeptTacticRows();
    });
    return row;
  }

  function renumberDeptTacticRows() {
    const strategyNo = Number((document.getElementById('deptEditOrder') as HTMLInputElement).value) || 1;
    document.querySelectorAll('#deptEditTacticsList [data-dept-tactic-id]').forEach((row, i) => {
      const seq = i + 1;
      const code = `SD${strategyNo}.${seq}`;
      (row as HTMLElement).querySelector('span.font-mono')!.textContent = code;
      const input = (row as HTMLElement).querySelector('input') as HTMLInputElement;
      input.dataset.tacticSeq = String(seq);
    });
  }

  // event delegation บน deptAccordion
  document.getElementById('deptAccordion')?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.dept-edit-btn') as HTMLElement | null;
    if (!btn) return;
    e.stopPropagation();
    const id = Number(btn.dataset.deptEditId);
    const order = btn.dataset.deptEditOrder!;
    const strategy = deptStrategyStore.get(id);
    if (!strategy) return;

    deletedDeptTacticIds = [];
    (document.getElementById('deptEditId') as HTMLInputElement).value = String(id);
    (document.getElementById('deptEditOrder') as HTMLInputElement).value = order;
    (document.getElementById('deptEditName') as HTMLTextAreaElement).value = strategy.name;
    (document.getElementById('deptEditYear') as HTMLInputElement).value = strategy.year ? String(strategy.year) : '';
    (document.getElementById('deptEditFiscalPlan') as HTMLInputElement).value = strategy.fiscalPlan ?? '';

    renderDeptTacticRows(strategy.tactics, Number(order));
    openDeptEditModal();
  });

  // ปุ่มเพิ่มกลยุทธ์
  document.getElementById('btnAddDeptTactic')?.addEventListener('click', () => {
    const strategyNo = Number((document.getElementById('deptEditOrder') as HTMLInputElement).value) || 1;
    const list = document.getElementById('deptEditTacticsList')!;
    const seq = list.children.length + 1;
    const code = `SD${strategyNo}.${seq}`;
    const row = makeDeptTacticRow(null, seq, code, '');
    list.appendChild(row);
    (row.querySelector('.dept-tactic-name-input') as HTMLInputElement)?.focus();
  });

  document.getElementById('deptEditClose')?.addEventListener('click', closeDeptEditModal);
  document.getElementById('deptEditCancel')?.addEventListener('click', closeDeptEditModal);
  document.getElementById('deptEditBackdrop')?.addEventListener('click', closeDeptEditModal);

  document.getElementById('deptEditForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const strategyId = (document.getElementById('deptEditId') as HTMLInputElement).value;
    const name = (document.getElementById('deptEditName') as HTMLTextAreaElement).value.trim();
    const yearVal = (document.getElementById('deptEditYear') as HTMLInputElement).value;
    const fiscalPlan = (document.getElementById('deptEditFiscalPlan') as HTMLInputElement).value || null;
    const errEl = document.getElementById('deptEditError')!;
    const submitBtn = document.getElementById('deptEditSubmit')!;

    if (!name) {
      errEl.textContent = 'กรุณาระบุชื่อยุทธศาสตร์';
      errEl.classList.remove('hidden');
      return;
    }

    submitBtn.textContent = 'กำลังบันทึก...';
    submitBtn.setAttribute('disabled', 'true');
    errEl.classList.add('hidden');

    const token = localStorage.getItem('ku_access_token');
    const headers = { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` };

    try {
      // 1. อัปเดตยุทธศาสตร์ส่วนงาน
      const r1 = await fetch(`http://localhost:3000/api/strategies/departments/${strategyId}`, {
        method: 'PUT', headers,
        body: JSON.stringify({
          name,
          fiscalPlan,
          year: yearVal ? Number(yearVal) : null,
        }),
      });
      const d1 = await r1.json();
      if (!r1.ok || !d1.success) throw new Error(d1.message ?? 'บันทึกยุทธศาสตร์ไม่สำเร็จ');

      // 2. ลบกลยุทธ์ที่ถูก mark ลบ
      for (const tid of deletedDeptTacticIds) {
        await fetch(`http://localhost:3000/api/strategies/department-tactics/${tid}`, { method: 'DELETE', headers });
      }

      // 3. บันทึกกลยุทธ์ในรายการ (แก้ไข / เพิ่มใหม่)
      const tacticRows = document.querySelectorAll('#deptEditTacticsList [data-dept-tactic-id]');
      for (let i = 0; i < tacticRows.length; i++) {
        const row = tacticRows[i] as HTMLElement;
        const tid = row.dataset.deptTacticId!;
        const input = row.querySelector('.dept-tactic-name-input') as HTMLInputElement;
        const tacticName = input.value.trim();
        const seq = i + 1;
        if (!tacticName) continue;

        if (tid === 'new') {
          await fetch(`http://localhost:3000/api/strategies/departments/${strategyId}/tactics`, {
            method: 'POST', headers,
            body: JSON.stringify({ name: tacticName, order: seq }),
          });
        } else {
          await fetch(`http://localhost:3000/api/strategies/department-tactics/${tid}`, {
            method: 'PUT', headers,
            body: JSON.stringify({ name: tacticName, order: seq }),
          });
        }
      }

      closeDeptEditModal();
      loadDepartmentStrategies();
      (window as any).showToast('บันทึกการแก้ไขยุทธศาสตร์ระดับส่วนงานสำเร็จ');
    } catch (err: any) {
      errEl.textContent = err.message ?? 'เกิดข้อผิดพลาด ไม่สามารถเชื่อมต่อเซิร์ฟเวอร์ได้';
      errEl.classList.remove('hidden');
    } finally {
      submitBtn.textContent = 'บันทึกการแก้ไข';
      submitBtn.removeAttribute('disabled');
    }
  });

  async function loadDepartmentStrategies() {
    try {
      const res = await apiFetch('http://localhost:3000/api/strategies/departments');
      if (!res || !res.ok) return;
      const json = await res.json();
      if (!json.success) return;

      deptRawData = json.data as DeptStrategy[];
      document.getElementById('deptLoading')?.remove();
      if (activeTab === 'division') {
        populateYearFilter(deptRawData.map(s => s.fiscalPlan));
        filterAndRenderAccordion();
      } else {
        renderDeptAccordion(deptRawData);
      }
    } catch {
      const loadingEl = document.getElementById('deptLoading');
      if (loadingEl) loadingEl.innerHTML =
        '<p class="text-sm text-red-400 py-4 text-center">โหลดข้อมูลไม่สำเร็จ</p>';
    }
  }

  // ═══════════════════════════════════════════════
  //  DEAN STRATEGIES — ดึงจาก API + Accordion
  // ═══════════════════════════════════════════════
  interface DeanTactic {
    id: number;
    name: string;
    order: number | null;
  }
  interface DeanStrategy {
    id: number;
    name: string;
    year: number | null;
    fiscalPlan?: string | null;
    tactics: DeanTactic[];
  }

  const deanStrategyStore = new Map<number, DeanStrategy>();

  function renderDeanAccordion(data: DeanStrategy[]) {
    deanStrategyStore.clear();
    data.forEach(s => deanStrategyStore.set(s.id, s));

    const container = document.getElementById('deanAccordion')!;

    if (data.length === 0) {
      container.innerHTML = `
        <div class="px-5 py-12 text-center text-sm text-gray-400">ไม่พบข้อมูลยุทธศาสตร์ระดับคณบดีส่วนงาน</div>`;
      return;
    }

    container.innerHTML = data.map((s, si) => {
      const strategyNo = si + 1;
      const tacticCount = s.tactics.length;

      const tacticRows = s.tactics.map((t, ti) => {
        const tacticCode = `CD${strategyNo}.${t.order ?? (ti + 1)}`;
        return `
          <div class="flex items-start gap-3 py-2">
            <span class="font-mono text-sm font-semibold text-[#9d174d] shrink-0 mt-0.5 min-w-[2.5rem]">${tacticCode}</span>
            <span class="text-sm text-gray-400 shrink-0 mt-0.5">:</span>
            <span class="text-sm text-gray-700 leading-relaxed">${t.name}</span>
          </div>`;
      }).join('');

      const yearLabel = s.year ? `ปีงบ ${s.year}` : '';
      const fiscalLabel = s.fiscalPlan ? `แผน ${s.fiscalPlan}` : '';
      const metaLabel = [yearLabel, fiscalLabel].filter(Boolean).join(' · ');

      return `
        <div class="dean-strategy-item">
          <!-- Strategy header row -->
          <div class="flex items-start gap-3 px-5 py-4 hover:bg-pink-50/40 transition-colors">
            <!-- Toggle area -->
            <button type="button" class="flex items-start gap-3 flex-1 min-w-0 text-left"
              onclick="toggleDeanStrategy(this.closest('.dean-strategy-item'))">
              <div class="w-7 h-7 rounded-lg bg-[#9d174d] text-white text-xs font-bold flex items-center justify-center shrink-0 mt-0.5">
                ${strategyNo}
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-semibold text-[#9d174d] leading-snug">
                  ยุทธศาสตร์ที่ ${strategyNo} : <span class="font-normal text-gray-800">${s.name}</span>
                </p>
                <p class="text-xs text-gray-500 mt-1">
                  ประกอบด้วย <span class="font-semibold text-[#9d174d]">${tacticCount}</span> กลยุทธ์${metaLabel ? ` · ${metaLabel}` : ''}
                </p>
              </div>
            </button>
            <!-- Actions -->
            <div class="flex items-center gap-2 shrink-0 mt-0.5">
              <button type="button"
                data-dean-edit-id="${s.id}"
                data-dean-edit-order="${strategyNo}"
                class="dean-edit-btn flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-[#9d174d] border border-[#9d174d]/30 rounded-lg hover:bg-[#9d174d] hover:text-white hover:border-[#9d174d] transition-colors">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                </svg>
                แก้ไข
              </button>
              <button type="button"
                data-dean-delete-id="${s.id}"
                data-dean-delete-name="${s.name.replace(/"/g, '&quot;')}"
                class="dean-delete-btn flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium text-red-500 border border-red-200 rounded-lg hover:bg-red-600 hover:text-white hover:border-red-600 transition-colors">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                </svg>
                ลบ
              </button>
              <svg class="w-4 h-4 text-gray-400 shrink-0 transition-transform duration-200 dean-strategy-chevron cursor-pointer"
                fill="none" stroke="currentColor" viewBox="0 0 24 24"
                onclick="toggleDeanStrategy(this.closest('.dean-strategy-item'))">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </div>
          </div>
          <!-- Tactics list (collapsible) -->
          <div class="dean-strategy-tactics hidden px-5 pb-4 pl-16 space-y-0.5 border-t border-pink-50 bg-pink-50/20">
            ${tacticCount > 0 ? tacticRows : '<p class="text-xs text-gray-400 py-2">ไม่มีกลยุทธ์ย่อย</p>'}
          </div>
        </div>`;
    }).join('');
  }

  (window as any).toggleDeanStrategy = (item: HTMLElement) => {
    const tactics = item.querySelector('.dean-strategy-tactics') as HTMLElement;
    const chevron = item.querySelector('.dean-strategy-chevron') as HTMLElement;
    const isHidden = tactics.classList.contains('hidden');
    tactics.classList.toggle('hidden', !isHidden);
    chevron.style.transform = isHidden ? 'rotate(180deg)' : '';
  };

  // ═══════════════════════════════════════════════
  //  DEAN EDIT MODAL
  // ═══════════════════════════════════════════════
  let deletedDeanTacticIds: number[] = [];

  function openDeanEditModal() {
    const el = document.getElementById('deanEditModal')!;
    el.classList.remove('hidden');
    el.classList.add('flex');
  }
  function closeDeanEditModal() {
    const el = document.getElementById('deanEditModal')!;
    el.classList.add('hidden');
    el.classList.remove('flex');
    deletedDeanTacticIds = [];
    (document.getElementById('deanEditForm') as HTMLFormElement).reset();
    (document.getElementById('deanEditTacticsList') as HTMLElement).innerHTML = '';
    (document.getElementById('deanEditError') as HTMLElement).classList.add('hidden');
  }

  function renderDeanTacticRows(tactics: DeanTactic[], strategyNo: number) {
    const list = document.getElementById('deanEditTacticsList')!;
    list.innerHTML = '';
    tactics.forEach((t, ti) => {
      const seq = t.order ?? (ti + 1);
      const code = `CD${strategyNo}.${seq}`;
      list.appendChild(makeDeanTacticRow(t.id, seq, code, t.name));
    });
  }

  function makeDeanTacticRow(id: number | null, seq: number, code: string, name: string): HTMLElement {
    const row = document.createElement('div');
    row.className = 'flex items-center gap-2 group';
    row.dataset.deanTacticId = id !== null ? String(id) : 'new';
    row.innerHTML = `
      <span class="font-mono text-xs font-semibold text-[#9d174d] shrink-0 w-14 text-right">${code}</span>
      <span class="text-xs text-gray-400 shrink-0">:</span>
      <input type="text" value="${name.replace(/"/g, '&quot;')}"
        data-tactic-seq="${seq}"
        class="dean-tactic-name-input flex-1 border border-gray-200 rounded-lg px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#9d174d]/30 focus:border-[#9d174d]"
        placeholder="ชื่อกลยุทธ์" />
      <button type="button" title="ลบ"
        class="dean-tactic-delete-btn shrink-0 p-1.5 text-gray-300 hover:text-red-500 hover:bg-red-50 rounded-lg transition-colors opacity-0 group-hover:opacity-100">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
        </svg>
      </button>`;

    row.querySelector('.dean-tactic-delete-btn')!.addEventListener('click', () => {
      if (id !== null) deletedDeanTacticIds.push(id);
      row.remove();
      renumberDeanTacticRows();
    });
    return row;
  }

  function renumberDeanTacticRows() {
    const strategyNo = Number((document.getElementById('deanEditOrder') as HTMLInputElement).value) || 1;
    document.querySelectorAll('#deanEditTacticsList [data-dean-tactic-id]').forEach((row, i) => {
      const seq = i + 1;
      const code = `CD${strategyNo}.${seq}`;
      (row as HTMLElement).querySelector('span.font-mono')!.textContent = code;
      const input = (row as HTMLElement).querySelector('input') as HTMLInputElement;
      input.dataset.tacticSeq = String(seq);
    });
  }

  // event delegation บน deanAccordion
  document.getElementById('deanAccordion')?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.dean-edit-btn') as HTMLElement | null;
    if (!btn) return;
    e.stopPropagation();
    const id = Number(btn.dataset.deanEditId);
    const order = btn.dataset.deanEditOrder!;
    const strategy = deanStrategyStore.get(id);
    if (!strategy) return;

    deletedDeanTacticIds = [];
    (document.getElementById('deanEditId') as HTMLInputElement).value = String(id);
    (document.getElementById('deanEditOrder') as HTMLInputElement).value = order;
    (document.getElementById('deanEditName') as HTMLTextAreaElement).value = strategy.name;
    (document.getElementById('deanEditYear') as HTMLInputElement).value = strategy.year ? String(strategy.year) : '';
    (document.getElementById('deanEditFiscalPlan') as HTMLInputElement).value = strategy.fiscalPlan ?? '';

    renderDeanTacticRows(strategy.tactics, Number(order));
    openDeanEditModal();
  });

  // ปุ่มเพิ่มกลยุทธ์
  document.getElementById('btnAddDeanTactic')?.addEventListener('click', () => {
    const strategyNo = Number((document.getElementById('deanEditOrder') as HTMLInputElement).value) || 1;
    const list = document.getElementById('deanEditTacticsList')!;
    const seq = list.children.length + 1;
    const code = `CD${strategyNo}.${seq}`;
    const row = makeDeanTacticRow(null, seq, code, '');
    list.appendChild(row);
    (row.querySelector('.dean-tactic-name-input') as HTMLInputElement)?.focus();
  });

  document.getElementById('deanEditClose')?.addEventListener('click', closeDeanEditModal);
  document.getElementById('deanEditCancel')?.addEventListener('click', closeDeanEditModal);
  document.getElementById('deanEditBackdrop')?.addEventListener('click', closeDeanEditModal);

  document.getElementById('deanEditForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const strategyId = (document.getElementById('deanEditId') as HTMLInputElement).value;
    const name = (document.getElementById('deanEditName') as HTMLTextAreaElement).value.trim();
    const yearVal = (document.getElementById('deanEditYear') as HTMLInputElement).value;
    const fiscalPlan = (document.getElementById('deanEditFiscalPlan') as HTMLInputElement).value || null;
    const errEl = document.getElementById('deanEditError')!;
    const submitBtn = document.getElementById('deanEditSubmit')!;

    if (!name) {
      errEl.textContent = 'กรุณาระบุชื่อยุทธศาสตร์';
      errEl.classList.remove('hidden');
      return;
    }

    submitBtn.textContent = 'กำลังบันทึก...';
    submitBtn.setAttribute('disabled', 'true');
    errEl.classList.add('hidden');

    const token = localStorage.getItem('ku_access_token');
    const headers = { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` };

    try {
      // 1. อัปเดตยุทธศาสตร์คณบดี
      const r1 = await fetch(`http://localhost:3000/api/strategies/dean/${strategyId}`, {
        method: 'PUT', headers,
        body: JSON.stringify({
          name,
          fiscalPlan,
          year: yearVal ? Number(yearVal) : null,
        }),
      });
      const d1 = await r1.json();
      if (!r1.ok || !d1.success) throw new Error(d1.message ?? 'บันทึกยุทธศาสตร์ไม่สำเร็จ');

      // 2. ลบกลยุทธ์ที่ถูก mark ลบ
      for (const tid of deletedDeanTacticIds) {
        await fetch(`http://localhost:3000/api/strategies/dean-tactics/${tid}`, { method: 'DELETE', headers });
      }

      // 3. บันทึกกลยุทธ์ในรายการ (แก้ไข / เพิ่มใหม่)
      const tacticRows = document.querySelectorAll('#deanEditTacticsList [data-dean-tactic-id]');
      for (let i = 0; i < tacticRows.length; i++) {
        const row = tacticRows[i] as HTMLElement;
        const tid = row.dataset.deanTacticId!;
        const input = row.querySelector('.dean-tactic-name-input') as HTMLInputElement;
        const tacticName = input.value.trim();
        const seq = i + 1;
        if (!tacticName) continue;

        if (tid === 'new') {
          await fetch(`http://localhost:3000/api/strategies/dean/${strategyId}/tactics`, {
            method: 'POST', headers,
            body: JSON.stringify({ name: tacticName, order: seq }),
          });
        } else {
          await fetch(`http://localhost:3000/api/strategies/dean-tactics/${tid}`, {
            method: 'PUT', headers,
            body: JSON.stringify({ name: tacticName, order: seq }),
          });
        }
      }

      closeDeanEditModal();
      loadDeanStrategies();
      (window as any).showToast('บันทึกการแก้ไขยุทธศาสตร์ระดับคณบดีสำเร็จ');
    } catch (err: any) {
      errEl.textContent = err.message ?? 'เกิดข้อผิดพลาด ไม่สามารถเชื่อมต่อเซิร์ฟเวอร์ได้';
      errEl.classList.remove('hidden');
    } finally {
      submitBtn.textContent = 'บันทึกการแก้ไข';
      submitBtn.removeAttribute('disabled');
    }
  });

  async function loadDeanStrategies() {
    try {
      const res = await apiFetch('http://localhost:3000/api/strategies/dean');
      if (!res || !res.ok) return;
      const json = await res.json();
      if (!json.success) return;

      deanRawData = json.data as DeanStrategy[];
      document.getElementById('deanLoading')?.remove();
      if (activeTab === 'dean') {
        populateYearFilter(deanRawData.map(s => s.fiscalPlan));
        filterAndRenderAccordion();
      } else {
        renderDeanAccordion(deanRawData);
      }
    } catch {
      const loadingEl = document.getElementById('deanLoading');
      if (loadingEl) loadingEl.innerHTML =
        '<p class="text-sm text-red-400 py-4 text-center">โหลดข้อมูลไม่สำเร็จ</p>';
    }
  }

  // Initial render
  renderAll();
  loadSummary();
  loadUniversityStrategies();
  loadCampusStrategies();
  loadDepartmentStrategies();
  loadDeanStrategies();
</script>
