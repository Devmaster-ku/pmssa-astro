  document.getElementById('deleteConfirmBackdrop')?.addEventListener('click', closeDeleteConfirm);

  document.getElementById('deleteConfirmOk')?.addEventListener('click', async () => {
    if (!pendingDeleteId || !pendingDeleteLevel) return;

    const btn = document.getElementById('deleteConfirmOk')!;
    btn.textContent = 'กำลังลบ...';
    btn.setAttribute('disabled', 'true');

    const token = localStorage.getItem('ku_access_token');
    const headers = { Authorization: `Bearer ${token}` };

    const endpointMap = {
      university: `http://localhost:3000/api/strategies/${pendingDeleteId}`,
      campus:     `http://localhost:3000/api/strategies/${pendingDeleteId}`,
      division:   `http://localhost:3000/api/strategies/departments/${pendingDeleteId}`,
      dean:       `http://localhost:3000/api/strategies/dean/${pendingDeleteId}`,
    };

    const reloadMap = {
      university: loadUniversityStrategies,
      campus:     loadCampusStrategies,
      division:   loadDepartmentStrategies,
      dean:       loadDeanStrategies,
    };

    try {
      const res = await fetch(endpointMap[pendingDeleteLevel], { method: 'DELETE', headers });
      const json = await res.json();

      if (!res.ok || !json.success) {
        (window as any).showToast(json.message ?? 'เกิดข้อผิดพลาด', 'error');
        return;
      }

      const levelToReload = pendingDeleteLevel;
      closeDeleteConfirm();
      (window as any).showToast('ลบยุทธศาสตร์เรียบร้อย');
      reloadMap[levelToReload]();
      loadSummary();
    } catch {
      (window as any).showToast('ไม่สามารถเชื่อมต่อเซิร์ฟเวอร์ได้', 'error');
