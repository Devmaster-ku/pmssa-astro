  // ═══════════════════════════════════════════════
  //  TOKEN REFRESH HELPER
  // ═══════════════════════════════════════════════
  async function refreshAccessToken(): Promise<string | null> {
    const refreshToken = localStorage.getItem('ku_refresh_token');
    if (!refreshToken) return null;
    try {
      const res = await fetch('http://localhost:3000/api/auth/refresh', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ refreshToken }),
      });
      if (!res.ok) return null;
      const data = await res.json();
      if (!data.success || !data.accessToken) return null;
      localStorage.setItem('ku_access_token', data.accessToken);
      if (data.refreshToken) localStorage.setItem('ku_refresh_token', data.refreshToken);
      return data.accessToken;
    } catch {
      return null;
    }
  }

  // fetch wrapper: retry once with refreshed token on 401
  async function apiFetch(url: string): Promise<Response | null> {
    let token = localStorage.getItem('ku_access_token');
    if (!token) return null;

    let res = await fetch(url, { headers: { Authorization: `Bearer ${token}` } });

    if (res.status === 401) {
      token = await refreshAccessToken();
      if (!token) {
        window.location.replace('/login');
        return null;
      }
      res = await fetch(url, { headers: { Authorization: `Bearer ${token}` } });
    }
    return res;
  }

  // ═══════════════════════════════════════════════
  //  SUMMARY STATS — ดึงข้อมูลจาก API
  // ═══════════════════════════════════════════════
  async function loadSummary() {
    try {
      const res = await apiFetch('http://localhost:3000/api/strategies/summary');
      if (!res || !res.ok) return;

      const data = await res.json();
      if (!data.success) return;

      // ระดับมหาวิทยาลัย
      document.getElementById('statUnivStrategy')!.textContent =
        `${data.university.strategyCount} ยุทธศาสตร์`;
      document.getElementById('statUnivTactic')!.textContent =
        `${data.university.tacticCount} กลยุทธ์`;

      // ระดับวิทยาเขต
      currentCampusName = data.campus.campusName ?? null;
      const isBangkhen = !data.campus.campusName || data.campus.campusName === 'บางเขน';
      const cardCampus = document.getElementById('cardCampus');
      const tabCampus = document.querySelector('[data-tab="campus"]') as HTMLElement | null;

      if (isBangkhen) {
        // ผู้ใช้สังกัดบางเขน — ซ่อน card, tab และตัวเลือกใน add/edit modal
        cardCampus?.classList.remove('flex');
        cardCampus?.classList.add('hidden');
        tabCampus?.classList.remove('flex');
        tabCampus?.classList.add('hidden');
        const campusOption = document.querySelector('#addLevel option[value="campus"]') as HTMLOptionElement | null;
        if (campusOption) campusOption.hidden = true;
        const campusOptionForm = document.querySelector('#formLevel option[value="campus"]') as HTMLOptionElement | null;
        if (campusOptionForm) campusOptionForm.hidden = true;
        // ถ้า active tab คือ campus ให้เปลี่ยนไป university
        if (activeTab === 'campus') {
          (document.querySelector('[data-tab="university"]') as HTMLElement)?.click();
        }
      } else {
        cardCampus?.classList.remove('hidden');
        cardCampus?.classList.add('flex');
        tabCampus?.classList.remove('hidden');
        tabCampus?.classList.add('flex');
        document.getElementById('labelCampus')!.textContent =
          `วิทยาเขต${data.campus.campusName}`;
        document.getElementById('statCampusStrategy')!.textContent =
          `${data.campus.strategyCount} ยุทธศาสตร์`;
        document.getElementById('statCampusTactic')!.textContent =
          `${data.campus.tacticCount} กลยุทธ์`;
      }

      // ระดับส่วนงาน
      document.getElementById('statDivStrategy')!.textContent =
        `${data.division.strategyCount} ยุทธศาสตร์`;
      document.getElementById('statDivTactic')!.textContent =
        `${data.division.tacticCount} กลยุทธ์`;

      // ระดับคณบดีส่วนงาน
      document.getElementById('statDeanStrategy')!.textContent =
        `${data.dean.strategyCount} ยุทธศาสตร์`;
      document.getElementById('statDeanTactic')!.textContent =
        `${data.dean.tacticCount} กลยุทธ์`;

    } catch {
      // API ไม่ตอบสนอง — คงค่า — ไว้
    }
  }

