      while (editSubOrgIdSel.options.length > 0) editSubOrgIdSel.remove(0);

      const optNone = document.createElement('option');
      optNone.value = ''; optNone.textContent = '-- ไม่ระบุ --';
      editSubOrgIdSel.appendChild(optNone);

      for (const o of childOrgs) {
        const opt = document.createElement('option');
        opt.value = String(o.id); opt.textContent = o.nameTh;
        editSubOrgIdSel.appendChild(opt);
      }
