    // ──────────── Add User ────────────
    function openAddUserModal() {
      (document.getElementById('addUserForm') as HTMLFormElement).reset();
      // คืนค่า addOrgId ให้เป็น main org แล้ว update sub-org
      if (myOrgId) (document.getElementById('addOrgId') as HTMLSelectElement).value = String(myOrgId);
      updateAddSubOrgDropdown();
      document.getElementById('addUserError')!.classList.add('hidden');
      showModal('addUserModal');
    }

    document.getElementById('addUserForm')!.addEventListener('submit', async (e) => {
      e.preventDefault();
      const errEl = document.getElementById('addUserError')!;
      errEl.classList.add('hidden');
      const btn = document.getElementById('addUserSubmit') as HTMLButtonElement;
      btn.disabled = true; btn.textContent = 'กำลังบันทึก...';
      try {
        const mainOrgId = (document.getElementById('addOrgId') as HTMLSelectElement).value;
        const subOrgId = (document.getElementById('addSubOrgId') as HTMLSelectElement).value;
        const body: any = {
          username: (document.getElementById('addUsername') as HTMLInputElement).value.trim(),
          email: (document.getElementById('addEmail') as HTMLInputElement).value.trim(),
          nameTh: (document.getElementById('addNameTh') as HTMLInputElement).value.trim(),
          nameEn: (document.getElementById('addNameEn') as HTMLInputElement).value.trim() || undefined,
          phone: (document.getElementById('addPhone') as HTMLInputElement).value.trim() || undefined,
          password: (document.getElementById('addPassword') as HTMLInputElement).value || undefined,
          role: (document.getElementById('addRole') as HTMLSelectElement).value,
          positionTitle: (document.getElementById('addPositionTitle') as HTMLInputElement).value.trim() || undefined,
        };
        if (mainOrgId) body.orgId = Number(mainOrgId);
        if (subOrgId) body.subDepId = Number(subOrgId);
        const res = await apiFetch(`${API}/api/users`, {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
        const data = await res.json();
        if (!data.success) throw new Error(data.message);
        hideModal('addUserModal');
        showToast('สร้างผู้ใช้สำเร็จ');
        await loadUsers();
      } catch (ex: any) {
        errEl.textContent = ex.message; errEl.classList.remove('hidden');
      } finally {
        btn.disabled = false; btn.textContent = 'บันทึก';
      }
    });

    // ──────────── Edit User ────────────
    function openEditUser(id: number) {
      const u = allUsers.find(x => x.id === id);
      if (!u) return;
      const primaryAff = u.affiliations?.find((a: any) => a.isPrimary) || u.affiliations?.[0] || null;
      (document.getElementById('editUserId') as HTMLInputElement).value = String(id);
      (document.getElementById('editNameTh') as HTMLInputElement).value = u.nameTh || '';
      (document.getElementById('editNameEn') as HTMLInputElement).value = u.nameEn || '';
      (document.getElementById('editUsername') as HTMLInputElement).value = u.username || '';
      (document.getElementById('editEmail') as HTMLInputElement).value = u.email || '';
      (document.getElementById('editPhone') as HTMLInputElement).value = u.phone || '';
      (document.getElementById('editPassword') as HTMLInputElement).value = '';
      // organization = หน่วยงานหลัก (orgId), subDep = หน่วยงานย่อย (subDepId)
      (document.getElementById('editOrgId') as HTMLSelectElement).value = primaryAff?.organization?.id ? String(primaryAff.organization.id) : '';
      updateEditSubOrgDropdown();
      (document.getElementById('editSubOrgId') as HTMLSelectElement).value = primaryAff?.subDep?.id ? String(primaryAff.subDep.id) : '';
      (document.getElementById('editRole') as HTMLSelectElement).value = primaryAff?.role || 'staff';
      (document.getElementById('editPositionTitle') as HTMLInputElement).value = primaryAff?.positionTitle || '';
      document.getElementById('editUserError')!.classList.add('hidden');
      // store primary affiliation id for role/position update
      (document.getElementById('editUserId') as HTMLInputElement).dataset.affId = primaryAff?.id ? String(primaryAff.id) : '';
      showModal('editUserModal');
    }

    document.getElementById('editUserForm')!.addEventListener('submit', async (e) => {
      e.preventDefault();
      const idEl = document.getElementById('editUserId') as HTMLInputElement;
      const id = idEl.value;
      const affId = idEl.dataset.affId;
      const errEl = document.getElementById('editUserError')!;
      errEl.classList.add('hidden');
      const btn = document.getElementById('editUserSubmit') as HTMLButtonElement;
      btn.disabled = true; btn.textContent = 'กำลังบันทึก...';
      try {
        const password = (document.getElementById('editPassword') as HTMLInputElement).value;
        const userBody: any = {
          nameTh: (document.getElementById('editNameTh') as HTMLInputElement).value.trim(),
          nameEn: (document.getElementById('editNameEn') as HTMLInputElement).value.trim() || undefined,
          email: (document.getElementById('editEmail') as HTMLInputElement).value.trim(),
          phone: (document.getElementById('editPhone') as HTMLInputElement).value.trim() || undefined,
        };
        if (password) userBody.password = password;

        const res = await apiFetch(`${API}/api/users/${id}`, {
          method: 'PATCH', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(userBody),
        });
        const data = await res.json();
        if (!data.success) throw new Error(data.message);

        // update role/position/org on primary affiliation if we have one
        if (affId) {
          const role = (document.getElementById('editRole') as HTMLSelectElement).value;
          const positionTitle = (document.getElementById('editPositionTitle') as HTMLInputElement).value.trim();
          const editMainOrgId = (document.getElementById('editOrgId') as HTMLSelectElement).value;
          const editSubOrgId = (document.getElementById('editSubOrgId') as HTMLSelectElement).value;
          const affBody: any = { role, positionTitle: positionTitle || undefined };
          if (editMainOrgId) affBody.orgId = Number(editMainOrgId);
          affBody.subDepId = editSubOrgId ? Number(editSubOrgId) : null;
          await apiFetch(`${API}/api/admin/affiliations/${affId}`, {
            method: 'PATCH', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(affBody),
          });
        }

        hideModal('editUserModal');
        showToast('แก้ไขข้อมูลสำเร็จ');
        await loadUsers();
      } catch (ex: any) {
        errEl.textContent = ex.message; errEl.classList.remove('hidden');
      } finally {
        btn.disabled = false; btn.textContent = 'บันทึก';
      }
    });

    // ──────────── Confirm Modal ────────────
    function showConfirm(opts: {
      title: string;
      body: string;
      okLabel: string;
      okClass: string;
      iconPath: string;
      iconClass: string;
      headerClass: string;
      onConfirm: () => void;
    }) {
      document.getElementById('confirmTitle')!.textContent = opts.title;
      document.getElementById('confirmBody')!.textContent = opts.body;
      const okBtn = document.getElementById('confirmOkBtn')!;
      okBtn.textContent = opts.okLabel;
      okBtn.className = `px-4 py-2 text-sm font-semibold rounded-lg transition-all ${opts.okClass}`;
      (document.getElementById('confirmIcon') as SVGElement).innerHTML = opts.iconPath;
      document.getElementById('confirmIconWrap')!.className = `w-9 h-9 rounded-full flex items-center justify-center shrink-0 ${opts.iconClass}`;
      document.getElementById('confirmHeader')!.className = `flex items-center gap-3 px-5 py-4 border-b border-gray-100 rounded-t-2xl ${opts.headerClass}`;

      const cleanup = () => hideModal('confirmModal');
      const newOk = okBtn.cloneNode(true) as HTMLElement;
      okBtn.replaceWith(newOk);
      newOk.addEventListener('click', () => { cleanup(); opts.onConfirm(); });
      document.getElementById('confirmCancelBtn')!.onclick = cleanup;
      showModal('confirmModal');
    }

    // ──────────── Toggle Active ────────────
    function toggleActive(id: number, currentStatus: boolean) {
      if (currentStatus) {
        showConfirm({
          title: 'ระงับบัญชีผู้ใช้งาน',
          body: 'บัญชีนี้จะถูกระงับการใช้งาน ผู้ใช้จะไม่สามารถเข้าสู่ระบบได้จนกว่าจะเปิดใช้งานอีกครั้ง',
          okLabel: 'ระงับบัญชี',
          okClass: 'text-white bg-red-500 hover:bg-red-600',
          iconPath: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/>',
          iconClass: 'bg-red-100 text-red-500',
          headerClass: '',
          onConfirm: () => doToggleActive(id),
        });
      } else {
        showConfirm({
          title: 'เปิดใช้งานบัญชีผู้ใช้งาน',
          body: 'บัญชีนี้จะถูกเปิดใช้งาน ผู้ใช้จะสามารถเข้าสู่ระบบได้ตามปกติ',
          okLabel: 'เปิดใช้งาน',
          okClass: 'text-white bg-emerald-500 hover:bg-emerald-600',
          iconPath: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>',
          iconClass: 'bg-emerald-100 text-emerald-600',
          headerClass: '',
          onConfirm: () => doToggleActive(id),
        });
      }
    }

    async function doToggleActive(id: number) {
      try {
        const res = await apiFetch(`${API}/api/users/${id}/toggle-active`, {
          method: 'PATCH',
        });
        const data = await res.json();
        if (!data.success) throw new Error(data.message);
        showToast(data.message);
        await loadUsers();
      } catch (ex: any) {
        showToast(ex.message, false);
      }
    }

    // ──────────── Affiliations Modal ────────────
    async function openAffModal(userId: number, userName: string) {
      (document.getElementById('affUserId') as HTMLInputElement).value = String(userId);
      document.getElementById('affUserName')!.textContent = userName;
      document.getElementById('affError')!.classList.add('hidden');
      // reset form
      (document.getElementById('affNewPosition') as HTMLInputElement).value = '';
      (document.getElementById('affNewRole') as HTMLSelectElement).value = 'staff';
      updateAffSubOrgDropdown();
      showModal('affModal');
      await loadAffiliations(userId);
    }

    async function loadAffiliations(userId: number) {
      const list = document.getElementById('affList')!;
      list.innerHTML = '<p class="text-xs text-gray-400 animate-pulse">กำลังโหลด...</p>';
      try {
        const res = await apiFetch(`${API}/api/users/${userId}`);
        const data = await res.json();
        if (!data.success) throw new Error(data.message);
        const affs = data.affiliations || [];
        if (!affs.length) {
          list.innerHTML = '<p class="text-xs text-gray-400 italic">ยังไม่มีสังกัด</p>';
          return;
        }
        list.innerHTML = affs.map((a: any) => {
          const primaryBadge = a.isPrimary
            ? `<span style="display:inline-flex;align-items:center;padding:1px 6px;border-radius:4px;font-size:10px;font-weight:700;background:#d1fae5;color:#065f46;margin-right:4px;">หลัก</span>`
            : '';
          const subDepRow = a.subDep?.nameTh
            ? `<p style="font-size:11px;color:#6b7280;margin:2px 0 0;display:flex;align-items:center;gap:3px;">
                <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="flex-shrink:0;opacity:.6"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                ${a.subDep.nameTh}
               </p>`
            : '';
          const posRow = a.positionTitle
            ? `<p style="font-size:11px;color:#9ca3af;margin:1px 0 0;">ตำแหน่ง: ${a.positionTitle}</p>`
            : '';
          return `
          <div style="display:flex;align-items:flex-start;justify-content:space-between;padding:10px 12px;background:#f9fafb;border-radius:10px;border:1px solid #e5e7eb;gap:8px;">
            <div style="flex:1;min-width:0;">
              <div style="display:flex;align-items:center;flex-wrap:wrap;gap:2px;margin-bottom:3px;">
                ${primaryBadge}
                <span style="font-size:12px;font-weight:600;color:#1f2937;">${a.organization?.nameTh || '—'}</span>
              </div>
              ${subDepRow}
              <div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap;margin-top:5px;">
                ${roleBadge(a.role)}
              </div>
              ${posRow}
            </div>
            <button onclick="removeAffiliation(${a.id}, ${userId})"
              class="p-1.5 rounded-lg text-red-400 hover:text-red-600 hover:bg-red-50 transition-colors shrink-0 mt-0.5" title="ลบสังกัด">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
            </button>
          </div>`;
        }).join('');
      } catch (ex: any) {
        list.innerHTML = `<p class="text-xs text-red-500">${ex.message}</p>`;
      }
    }

    function removeAffiliation(affId: number, userId: number) {
      showConfirm({
        title: 'ลบสังกัดนี้',
        body: 'สังกัดนี้จะถูกลบออกจากบัญชีผู้ใช้ ไม่สามารถย้อนกลับได้',
        okLabel: 'ลบสังกัด',
        okClass: 'text-white bg-red-500 hover:bg-red-600',
        iconPath: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>',
        iconClass: 'bg-red-100 text-red-500',
        headerClass: '',
        onConfirm: async () => {
          try {
            const res = await apiFetch(`${API}/api/admin/affiliations/${affId}`, { method: 'DELETE' });
            const data = await res.json();
            if (!data.success) throw new Error(data.message);
            showToast('ลบสังกัดสำเร็จ');
            loadAffiliations(userId);
            loadUsers();
          } catch (ex: any) {
            showToast(ex.message, false);
          }
        },
      });
    }

    document.getElementById('affClearBtn')!.addEventListener('click', () => {
      (document.getElementById('affNewPosition') as HTMLInputElement).value = '';
      (document.getElementById('affNewRole') as HTMLSelectElement).value = 'staff';
      updateAffSubOrgDropdown();
      document.getElementById('affError')!.classList.add('hidden');
    });

    document.getElementById('btnAddAff')!.addEventListener('click', async () => {
      const btn = document.getElementById('btnAddAff') as HTMLButtonElement;
      const userId = Number((document.getElementById('affUserId') as HTMLInputElement).value);
      const orgId = Number((document.getElementById('affNewOrgId') as HTMLSelectElement).value);
      const subDepIdRaw = (document.getElementById('affNewSubDepId') as HTMLSelectElement).value;
      const subDepId = subDepIdRaw ? Number(subDepIdRaw) : null;
      const role = (document.getElementById('affNewRole') as HTMLSelectElement).value;
      const positionTitle = (document.getElementById('affNewPosition') as HTMLInputElement).value.trim();
      const errEl = document.getElementById('affError')!;
      errEl.classList.add('hidden');
      if (!orgId) { errEl.textContent = 'กรุณาเลือกหน่วยงานหลัก'; errEl.classList.remove('hidden'); return; }

      // lock ปุ่มระหว่างบันทึก
      btn.disabled = true;
      btn.textContent = 'กำลังบันทึก...';

      try {
        const res = await apiFetch(`${API}/api/admin/affiliations`, {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ userId, orgId, subDepId, role, positionTitle: positionTitle || undefined, isPrimary: false }),
        });
        const data = await res.json();
        if (!data.success) throw new Error(data.message);

        // reset form ทันที — ให้ผู้ใช้เพิ่มสังกัดถัดไปได้เลย
        (document.getElementById('affNewPosition') as HTMLInputElement).value = '';
        (document.getElementById('affNewRole') as HTMLSelectElement).value = 'staff';
        updateAffSubOrgDropdown();
        showToast('เพิ่มสังกัดสำเร็จ');

        // refresh รายการและตารางหลักใน background (ไม่บล็อกฟอร์ม)
        loadAffiliations(userId);
        loadUsers();

        // focus ช่องตำแหน่งเพื่อพร้อมกรอกครั้งถัดไป
        (document.getElementById('affNewPosition') as HTMLInputElement).focus();
      } catch (ex: any) {
        errEl.textContent = ex.message; errEl.classList.remove('hidden');
      } finally {
        btn.disabled = false;
        btn.textContent = 'บันทึกข้อมูล';
      }
    });

    // ──────────── modal helpers ────────────
    function showModal(id: string) {
      const m = document.getElementById(id)!;
      m.classList.remove('hidden');
      m.classList.add('flex');
    }
    function hideModal(id: string) {
      const m = document.getElementById(id)!;
      m.classList.add('hidden');
      m.classList.remove('flex');
    }

    // wire up close buttons
    ['addUser', 'editUser', 'aff'].forEach(prefix => {
      document.getElementById(`${prefix}Close`)?.addEventListener('click', () => hideModal(`${prefix}Modal`));
      document.getElementById(`${prefix}Cancel`)?.addEventListener('click', () => hideModal(`${prefix}Modal`));
      document.getElementById(`${prefix}Backdrop`)?.addEventListener('click', () => hideModal(`${prefix}Modal`));
    });
    document.getElementById('affDone')?.addEventListener('click', () => hideModal('affModal'));

    // ──────────── init ────────────
    document.getElementById('btnAddUser')!.addEventListener('click', openAddUserModal);
    document.getElementById('searchInput')!.addEventListener('input', () => { currentPage = 1; renderTable(); });
    document.getElementById('filterStatus')!.addEventListener('change', () => { currentPage = 1; renderTable(); });
    document.getElementById('filterRole')!.addEventListener('change', () => { currentPage = 1; renderTable(); });
    document.getElementById('filterOrg')!.addEventListener('change', () => { updateSubOrgFilter(); currentPage = 1; renderTable(); });
    document.getElementById('filterSubOrg')!.addEventListener('change', () => { currentPage = 1; renderTable(); });
    document.getElementById('addOrgId')!.addEventListener('change', () => { updateAddSubOrgDropdown(); });
    document.getElementById('editOrgId')!.addEventListener('change', () => { updateEditSubOrgDropdown(); });
    document.getElementById('affNewOrgId')!.addEventListener('change', () => { updateAffSubOrgDropdown(); });

    // expose to inline onclick handlers
    (window as any).openEditUser = openEditUser;
    (window as any).openAffModal = openAffModal;
    (window as any).toggleActive = toggleActive;
    (window as any).removeAffiliation = removeAffiliation;
    (window as any).goPage = (p: number) => {
      const search = (document.getElementById('searchInput') as HTMLInputElement).value.toLowerCase();
      const status = (document.getElementById('filterStatus') as HTMLSelectElement).value;
      const role = (document.getElementById('filterRole') as HTMLSelectElement).value;
      const orgId = (document.getElementById('filterOrg') as HTMLSelectElement).value;
      const subOrgId = (document.getElementById('filterSubOrg') as HTMLSelectElement).value;
      const filtered = allUsers.filter(u => {
        const matchSearch = !search || u.nameTh?.toLowerCase().includes(search) || u.username?.toLowerCase().includes(search) || u.email?.toLowerCase().includes(search);
        const matchStatus = !status || (status === 'active' && u.isActive) || (status === 'inactive' && !u.isActive);
        const matchRole = !role || u.affiliations?.some((a: any) => a.role === role);
        return matchSearch && matchStatus && matchRole && matchOrgFilter(u, orgId, subOrgId);
      });
      const totalPages = Math.max(1, Math.ceil(filtered.length / PAGE_SIZE));
      currentPage = Math.max(1, Math.min(p, totalPages));
      renderTable();
      document.getElementById('userTableBody')?.closest('.overflow-x-auto')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    };

    document.addEventListener('DOMContentLoaded', async () => {
      // อ่าน orgId ของผู้ใช้ที่ login ก่อนเสมอ
      try {
        const activeAff = JSON.parse(localStorage.getItem('ku_active_affiliation') || 'null');
        // ku_active_affiliation มี organization.id หรือ orgId (ขึ้นกับ version ที่บันทึก)
        myOrgId = activeAff?.organization?.id
          ? Number(activeAff.organization.id)
          : (activeAff?.orgId ? Number(activeAff.orgId) : null);
        // อ่าน subDep ของ user ที่ login (subDep.id หรือ subDepId)
        mySubDepId = activeAff?.subDep?.id
          ? Number(activeAff.subDep.id)
          : (activeAff?.subDepId ? Number(activeAff.subDepId) : null);
      } catch {}
      await loadOrgs();   // โหลด org dropdown (ใช้ myOrgId สร้าง grouped dropdown)
      await loadUsers();  // โหลด users (ใช้ myOrgId + child orgs กรองข้อมูล)
    });
  </script>

  <style>
    .dropdown-arrow {
      position: relative;
      appearance: none;
    }
    
    .dropdown-arrow::-webkit-calendar-picker-indicator,
    .dropdown-arrow::-ms-expand,
    .dropdown-arrow::-moz-focus-inner {
      display: none;
    }
    
    .dropdown-arrow::after {
      content: '';
      position: absolute;
      top: 50%;
      right: 6px;
      transform: translateY(-50%);
      width: 0;
      height: 0;
      border-left: 4px solid transparent;
      border-right: 4px solid transparent;
      border-top: 4px solid #6b7280;
      pointer-events: none;
    }

    #userTableBody tr,
    #userTableBody td {
      vertical-align: top !important;
    }
  </style>

</AuthLayout>
