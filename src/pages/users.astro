    function renderPagination(totalPages: number, total: number) {
      const ctrl = document.getElementById('paginationControls')!;
      if (totalPages <= 1) { ctrl.innerHTML = ''; return; }

      const pageBtn = (p: number, isActive: boolean) => {
        const activeStyle = 'border:2px solid #B2BB1E; color:#006664; font-weight:600; background:#fff;';
        const normalStyle = 'border:1px solid #e5e7eb; color:#4b5563; background:#fff;';
        return `<button onclick="goPage(${p})"
          style="padding:4px 10px; font-size:12px; border-radius:8px; cursor:pointer; transition:all .15s; ${isActive ? activeStyle : normalStyle}"
          onmouseover="if(!${isActive})this.style.borderColor='#B2BB1E'"
          onmouseout="if(!${isActive})this.style.borderColor='#e5e7eb'"
        >${p}</button>`;
      };

      const arrowBtn = (icon: string, page: number, disabled: boolean) => {
        const disStyle = 'border:1px solid #f3f4f6; color:#d1d5db; background:#f9fafb; cursor:not-allowed;';
        const enStyle  = 'border:1px solid #e5e7eb; color:#4b5563; background:#fff; cursor:pointer;';
        return `<button ${disabled ? 'disabled' : `onclick="goPage(${page})"`}
          style="padding:4px 8px; font-size:12px; border-radius:8px; transition:all .15s; ${disabled ? disStyle : enStyle}"
        >${icon}</button>`;
      };

      // Build page number list with ellipsis
      const pages: (number|'...')[] = [];
      for (let p = 1; p <= totalPages; p++) {
        if (p === 1 || p === totalPages || (p >= currentPage - 2 && p <= currentPage + 2)) {
          pages.push(p);
        } else if (pages[pages.length - 1] !== '...') {
          pages.push('...');
        }
      }

      ctrl.innerHTML = [
        arrowBtn(`<svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>`,
          currentPage - 1, currentPage === 1),
        ...pages.map(p =>
          p === '...'
            ? `<span style="font-size:12px;color:#9ca3af;padding:0 4px">…</span>`
            : pageBtn(p as number, p === currentPage)
        ),
        arrowBtn(`<svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>`,
          currentPage + 1, currentPage === totalPages),
      ].join('');
    }

    // ──────────── fetch orgs ────────────
    function populateSelect(sel: HTMLSelectElement, defaultLabel: string, items: any[]) {
      // ล้าง options เดิมทั้งหมด
      while (sel.options.length > 0) sel.remove(0);
      // เพิ่ม default option
      const def = document.createElement('option');
      def.value = '';
      def.textContent = defaultLabel;
      sel.appendChild(def);
      // เพิ่ม options จากข้อมูล (ใช้ DOM API เพื่อป้องกัน HTML injection)
      for (const o of items) {
        const opt = document.createElement('option');
        opt.value = String(o.id);
        opt.textContent = o.nameTh;
        sel.appendChild(opt);
      }
    }

    async function loadOrgs() {
      try {
        const res = await apiFetch(`${API}/api/organizations`);
        const data = await res.json();
        orgList = data.data || data.organizations || [];

        // affNewOrgId → แสดงเฉพาะหน่วยงานหลัก (top-level) เหมือน addOrgId/editOrgId
        const affNewOrgIdSel = document.getElementById('affNewOrgId') as HTMLSelectElement;
        if (affNewOrgIdSel) {
          while (affNewOrgIdSel.options.length > 0) affNewOrgIdSel.remove(0);
          const mainOrg = myOrgId ? orgList.find((o: any) => Number(o.id) === myOrgId) : null;
          if (mainOrg) {
            const opt = document.createElement('option');
            opt.value = String(mainOrg.id); opt.textContent = mainOrg.nameTh;
            affNewOrgIdSel.appendChild(opt);
            affNewOrgIdSel.value = String(mainOrg.id);
          } else {
            const topLevelOrgs = orgList.filter((o: any) => !o.parentId || o.parentId === null);
            const optNone = document.createElement('option');
            optNone.value = ''; optNone.textContent = '-- ไม่ระบุ --';
            affNewOrgIdSel.appendChild(optNone);
            for (const o of topLevelOrgs) {
              const opt = document.createElement('option');
              opt.value = String(o.id); opt.textContent = o.nameTh;
              affNewOrgIdSel.appendChild(opt);
            }
          }
          updateAffSubOrgDropdown();
        }

        // addOrgId และ editOrgId → แสดงเฉพาะหน่วยงานหลัก (top-level) เหมือน filterOrg
        for (const selId of ['addOrgId', 'editOrgId']) {
          const sel = document.getElementById(selId) as HTMLSelectElement;
          if (!sel) continue;
          while (sel.options.length > 0) sel.remove(0);
          const mainOrg = myOrgId ? orgList.find((o: any) => Number(o.id) === myOrgId) : null;
          if (mainOrg) {
            const opt = document.createElement('option');
            opt.value = String(mainOrg.id); opt.textContent = mainOrg.nameTh;
            sel.appendChild(opt);
            sel.value = String(mainOrg.id);
          } else {
            const topLevelOrgs = orgList.filter((o: any) => !o.parentId || o.parentId === null);
            const optNone = document.createElement('option');
            optNone.value = ''; optNone.textContent = '-- ไม่ระบุ --';
            sel.appendChild(optNone);
            for (const o of topLevelOrgs) {
              const opt = document.createElement('option');
              opt.value = String(o.id); opt.textContent = o.nameTh;
              sel.appendChild(opt);
            }
          }
        }
        updateAddSubOrgDropdown();

        // addOrgId → แสดงเฉพาะหน่วยงานหลัก (เหมือน filterOrg)
        const addOrgIdSel = document.getElementById('addOrgId') as HTMLSelectElement;
        if (addOrgIdSel) {
          while (addOrgIdSel.options.length > 0) addOrgIdSel.remove(0);
          const mainOrg = myOrgId ? orgList.find((o: any) => Number(o.id) === myOrgId) : null;
          if (mainOrg) {
            const opt = document.createElement('option');
            opt.value = String(mainOrg.id);
            opt.textContent = mainOrg.nameTh;
            addOrgIdSel.appendChild(opt);
            addOrgIdSel.value = String(mainOrg.id);
          } else {
            const topLevelOrgs = orgList.filter((o: any) => !o.parentId || o.parentId === null);
            const optNone = document.createElement('option');
            optNone.value = ''; optNone.textContent = '-- ไม่ระบุ --';
            addOrgIdSel.appendChild(optNone);
            for (const o of topLevelOrgs) {
              const opt = document.createElement('option');
              opt.value = String(o.id); opt.textContent = o.nameTh;
              addOrgIdSel.appendChild(opt);
            }
          }
          updateAddSubOrgDropdown();
        }

        // สร้าง filterOrg: แสดงเฉพาะหน่วยงานหลักของผู้ใช้ (top-level เท่านั้น ไม่รวมหน่วยงานย่อย)
        const filterOrgSel = document.getElementById('filterOrg') as HTMLSelectElement;
        if (filterOrgSel) {
          while (filterOrgSel.options.length > 0) filterOrgSel.remove(0);

          // หน่วยงานหลัก = org ที่ผู้ใช้ login สังกัดอยู่ (myOrgId)
          const mainOrg = myOrgId ? orgList.find((o: any) => Number(o.id) === myOrgId) : null;

          if (mainOrg) {
            // มี myOrgId → แสดงเฉพาะหน่วยงานหลักเดียว (ไม่ปน child)
            const optAll = document.createElement('option');
            optAll.value = '';
            optAll.textContent = 'ทุกหน่วยงานหลัก';
            filterOrgSel.appendChild(optAll);

            const optMain = document.createElement('option');
            optMain.value = String(mainOrg.id);
            optMain.textContent = mainOrg.nameTh;
            filterOrgSel.appendChild(optMain);

            filterOrgSel.value = String(mainOrg.id); // default = หน่วยงานหลัก
          } else {
            // fallback: ไม่รู้ myOrgId → แสดงเฉพาะ top-level orgs (parentId = null/undefined)
            const topLevelOrgs = orgList.filter((o: any) => !o.parentId || o.parentId === null);
            const optAll = document.createElement('option');
            optAll.value = '';
            optAll.textContent = 'ทุกหน่วยงานหลัก';
            filterOrgSel.appendChild(optAll);
            for (const o of topLevelOrgs) {
              const opt = document.createElement('option');
              opt.value = String(o.id);
              opt.textContent = o.nameTh;
              filterOrgSel.appendChild(opt);
            }
          }
        }

        // สร้าง filterSubOrg: แสดงหน่วยงานย่อยภายใต้หน่วยงานหลัก และ default ตาม subDep ของ user
        updateSubOrgFilter(mySubDepId);
      } catch {}
    }

    function updateSubOrgFilter(defaultSubDepId: number | null = null) {
      const filterOrgSel = document.getElementById('filterOrg') as HTMLSelectElement;
      const filterSubOrgSel = document.getElementById('filterSubOrg') as HTMLSelectElement;
      if (!filterSubOrgSel) return;

      const selectedOrgId = filterOrgSel?.value ? Number(filterOrgSel.value) : (myOrgId ?? null);
      const childOrgs = selectedOrgId
        ? orgList.filter((o: any) => Number(o.parentId) === selectedOrgId)
        : [];

      while (filterSubOrgSel.options.length > 0) filterSubOrgSel.remove(0);

      const optAll = document.createElement('option');
      optAll.value = '';
      optAll.textContent = 'ทุกหน่วยงานย่อย';
      filterSubOrgSel.appendChild(optAll);

      for (const o of childOrgs) {
        const opt = document.createElement('option');
        opt.value = String(o.id);
        opt.textContent = o.nameTh;
        filterSubOrgSel.appendChild(opt);
      }

      // ตั้งค่า default: ใช้ defaultSubDepId ถ้าส่งมา (init เท่านั้น) ไม่งั้น reset เป็นทุกหน่วยงาน
      filterSubOrgSel.value = defaultSubDepId ? String(defaultSubDepId) : '';
    }

    function updateAddSubOrgDropdown() {
      const addOrgIdSel = document.getElementById('addOrgId') as HTMLSelectElement;
      const addSubOrgIdSel = document.getElementById('addSubOrgId') as HTMLSelectElement;
      if (!addSubOrgIdSel) return;

      const selectedOrgId = addOrgIdSel?.value ? Number(addOrgIdSel.value) : null;
      const childOrgs = selectedOrgId
        ? orgList.filter((o: any) => Number(o.parentId) === selectedOrgId)
        : [];

      while (addSubOrgIdSel.options.length > 0) addSubOrgIdSel.remove(0);

      const optNone = document.createElement('option');
      optNone.value = ''; optNone.textContent = '-- ไม่ระบุ --';
      addSubOrgIdSel.appendChild(optNone);

      for (const o of childOrgs) {
        const opt = document.createElement('option');
        opt.value = String(o.id); opt.textContent = o.nameTh;
        addSubOrgIdSel.appendChild(opt);
      }
      addSubOrgIdSel.value = '';
    }

