    function updateAffSubOrgDropdown() {
      const orgSel = document.getElementById('affNewOrgId') as HTMLSelectElement;
      const subSel = document.getElementById('affNewSubDepId') as HTMLSelectElement;
      if (!subSel) return;
      const selectedOrgId = orgSel?.value ? Number(orgSel.value) : null;
