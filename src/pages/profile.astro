            <div class="relative">
              <input type="password" id="confirmPassword" placeholder="ยืนยันรหัสผ่านใหม่" class="w-full px-4 py-2.5 text-sm border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#0f2d4e] focus:border-transparent pr-10" oninput="this.value = this.value.replace(/[\u0E00-\u0E7F]/g, '')">
