            ยกเลิก
          </button>
          <button id="confirmPasswordChange" class="px-6 py-2.5 text-sm bg-[#0f2d4e] hover:bg-[#0a2038] text-white rounded-lg transition-colors font-semibold flex items-center gap-2 disabled:opacity-40 disabled:cursor-not-allowed border border-[#0a2038]" disabled>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
            ยืนยันการเปลี่ยนรหัสผ่าน
          </button>
