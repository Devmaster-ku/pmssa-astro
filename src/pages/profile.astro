  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // ===== Toast Notification System =====
      function showToast(message, type = 'success', duration = 5000) {
        const toastContainer = document.getElementById('toastContainer');
        if (!toastContainer) return;

        const toast = document.createElement('div');
        toast.className = `pointer-events-auto transform transition-all duration-300 translate-x-full mb-4`;

        const icons = {
          success: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>',
          error: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>',
          warning: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z"></path></svg>',
          info: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>'
        };

        const colors = {
          success: 'bg-green-500 border-green-600',
          error: 'bg-red-500 border-red-600',
          warning: 'bg-orange-500 border-orange-600',
          info: 'bg-blue-500 border-blue-600'
        };

        toast.innerHTML = `
          <div class="${colors[type]} border-l-4 rounded-lg shadow-lg p-4 flex items-start gap-3 min-w-[320px] max-w-md">
            <div class="text-white flex-shrink-0">
              ${icons[type]}
            </div>
            <div class="flex-1">
              <p class="text-white font-medium">${message}</p>
              <div class="mt-2">
                <div class="w-full bg-white/20 rounded-full h-1.5">
                  <div class="bg-white h-1.5 rounded-full transition-all duration-1000 linear" style="width: 100%"></div>
                </div>
              </div>
            </div>
            <button onclick="this.parentElement.parentElement.remove()" class="text-white/80 hover:text-white transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
            </button>
          </div>
        `;

        toastContainer.appendChild(toast);

        // Animate in
        setTimeout(() => {
          toast.classList.remove('translate-x-full');
          toast.classList.add('translate-x-0');
        }, 10);

        // Animate progress bar
        const progressBar = toast.querySelector('[style*="width"]');
        if (progressBar) {
          progressBar.style.transition = `width ${duration}ms linear`;
          setTimeout(() => {
            progressBar.style.width = '0%';
          }, 100);
        }

        // Auto remove
        setTimeout(() => {
          toast.classList.remove('translate-x-0');
          toast.classList.add('translate-x-full');
          setTimeout(() => {
            toast.remove();
          }, 300);
        }, duration);
      }

      function showSuccessToastWithCountdown(message, countdownSeconds = 5) {
        const toastContainer = document.getElementById('toastContainer');
        if (!toastContainer) return;

        const toast = document.createElement('div');
        toast.className = `pointer-events-auto transform transition-all duration-300 translate-x-full mb-4`;

        let remainingTime = countdownSeconds;

        toast.innerHTML = `
          <div class="bg-green-500 border-l-4 border-green-600 rounded-lg shadow-lg p-4 flex items-start gap-3 min-w-[380px] max-w-md">
            <div class="text-white flex-shrink-0">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <div class="flex-1">
              <p class="text-white font-medium mb-2">${message}</p>
              <p class="text-white/90 text-sm">ระบบจะทำการออกจากระบบใน <span id="countdown">${remainingTime}</span> วินาที</p>
              <div class="mt-2">
                <div class="w-full bg-white/20 rounded-full h-1.5">
                  <div class="bg-white h-1.5 rounded-full transition-all duration-1000 linear" style="width: 100%"></div>
                </div>
              </div>
            </div>
            <button onclick="this.parentElement.parentElement.remove()" class="text-white/80 hover:text-white transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
            </button>
          </div>
        `;

        toastContainer.appendChild(toast);

        // Animate in
        setTimeout(() => {
          toast.classList.remove('translate-x-full');
          toast.classList.add('translate-x-0');
        }, 10);

        // Countdown timer
        const countdownEl = toast.querySelector('#countdown');
        const interval = setInterval(() => {
          remainingTime--;
          if (countdownEl) {
            countdownEl.textContent = remainingTime;
          }
          if (remainingTime <= 0) {
            clearInterval(interval);
          }
        }, 1000);

        // Animate progress bar
        const progressBar = toast.querySelector('[style*="width"]');
        if (progressBar) {
          progressBar.style.transition = `width ${countdownSeconds * 1000}ms linear`;
          setTimeout(() => {
            progressBar.style.width = '0%';
          }, 100);
        }

        // Auto remove
        setTimeout(() => {
          clearInterval(interval);
          toast.classList.remove('translate-x-0');
          toast.classList.add('translate-x-full');
          setTimeout(() => {
            toast.remove();
          }, 300);
        }, countdownSeconds * 1000);
      }

      // ===== Token Refresh Helper =====
      async function refreshAccessToken() {
        const refreshToken = localStorage.getItem('ku_refresh_token');
        if (!refreshToken) return null;
        try {
          const res = await fetch('http://localhost:3000/api/auth/refresh', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ refreshToken }),
          });
          if (!res.ok) return null;
          const data = await res.json();
          if (!data.success || !data.accessToken) return null;
          localStorage.setItem('ku_access_token', data.accessToken);
          if (data.refreshToken) localStorage.setItem('ku_refresh_token', data.refreshToken);
          return data.accessToken;
        } catch {
          return null;
        }
      }

      // ===== Load User Data =====
      async function loadUserProfile() {
        try {
          let token = localStorage.getItem('ku_access_token');
          if (!token) {
            console.error('No access token found');
            return;
          }

          let res = await fetch('http://localhost:3000/api/auth/me', {
            headers: {
              'Authorization': `Bearer ${token}`
            }
          });

          // Token expired — try refresh once
          if (res.status === 401) {
            token = await refreshAccessToken();
            if (!token) {
              console.error('Session expired. Please log in again.');
              window.location.href = '/login';
              return;
            }
            res = await fetch('http://localhost:3000/api/auth/me', {
              headers: { 'Authorization': `Bearer ${token}` }
            });
          }

          if (!res.ok) {
            throw new Error('Failed to fetch user profile');
          }

          const data = await res.json();
          if (!data.success) {
            throw new Error(data.message || 'Failed to load profile');
          }

          const user = data.user;
          const affiliations = data.affiliations || [];

          // Helper function
          const setText = (id, val) => {
            const el = document.getElementById(id);
            if (el && val) el.textContent = val;
          };

          // Header
          setText('profileName', user.nameTh || user.nameEn || user.username || '-');
          setText('profileEmail', user.email || '-');
          setText('profileRoleBadge', data.activeAffiliation?.role || 'staff');

          // Personal info - Using correct database fields
          setText('infoName', user.nameTh || user.nameEn || user.username || '-'); // 1. ชื่อ-นามสกุล from users.name_th
          setText('infoPosition', data.activeAffiliation?.positionTitle || '-'); // 2. ตำแหน่งงาน from user_affiliations.position_title
          setText('infoEmail', user.email || '-');

          // 3. หน่วยงานหลัก from user_affiliations.org_id -> organizations.name_th
          const primaryOrg = affiliations.find(a => a.isPrimary) || affiliations[0];
          setText('infoDepartment', primaryOrg?.organization?.nameTh || '-');

          // 3b. ส่วนงาน (campus) — NULL campusId = บางเขน (ส่วนกลาง)
          const campusName = primaryOrg?.organization?.campus?.nameTh
            || (primaryOrg?.organization?.campusId == null ? 'บางเขน' : '-');
          setText('infoCampus', campusName);

          setText('infoPhone', user.phone || '-'); // 4. เบอร์โทรศัพท์ from users.phone
          setText('infoKuUid', user.kuUid || '-');
          setText('infoKuFacultyId', user.kuFacultyId || '-');

          if (user.createdAt) {
            const d = new Date(user.createdAt);
            const now = new Date();
            const diff = Math.floor((now.getTime() - d.getTime()) / (1000 * 60 * 60 * 24 * 30));
            setText('infoCreatedAt', diff > 0 ? `${diff} เดือนที่แล้ว` : 'ไม่นานมานี้');
          }

          // Department list
          const deptList = document.getElementById('departmentList');
          const deptEmpty = document.getElementById('departmentEmpty');

          if (affiliations.length > 0 && deptList && deptEmpty) {
            deptEmpty.classList.add('hidden');
            deptList.innerHTML = affiliations.map(aff => `
              <div class="border border-gray-200 rounded-lg p-4 bg-gray-50/30">

                <!-- ต้นสังกัด (org_id) + role badge -->
                <div class="flex items-start justify-between gap-2 mb-0.5">
                  <p class="text-[12px] font-semibold text-sky-600 uppercase tracking-wider">ต้นสังกัด</p>
                  <div class="flex items-center gap-1.5 flex-shrink-0">
                    ${aff.isPrimary ? `<span class="px-2 py-0.5 bg-[#0f2d4e]/10 border border-[#0f2d4e] text-[#0f2d4e] text-[10px] font-bold rounded uppercase tracking-wide">หลัก</span>` : ''}
                    ${aff.role ? `<span class="px-2 py-0.5 bg-white border border-[#1a5c2a] text-[#1a5c2a] text-[10px] font-bold rounded uppercase tracking-wide">${aff.role.replace('_', ' ')}</span>` : ''}
                  </div>
                </div>
                <h4 class="text-sm font-semibold text-gray-800 mb-0.5">${aff.organization?.nameTh || '-'}
                  <span class="ml-6 text-[15px] text-gray-400 font-mono mb-0">${aff.organization?.code || ''}</span>
                </h4>

                <!-- หน่วยงานย่อย (sub_dep_id) -->
                ${aff.subDep ? `
                <div class="mt-2.5 pl-3 border-l-2 border-gray-200">
                  <p class="text-[12px] font-semibold text-teal-600 uppercase tracking-wider mb-0.5">หน่วยงานย่อย</p>
                  <p class="text-xs text-gray-700 font-medium leading-snug">${aff.subDep.nameTh}</p>
                  ${aff.positionTitle ? `<p class="text-[11px] text-gray-500 mt-1">ตำแหน่ง: ${aff.positionTitle}</p>` : ''}
                </div>` : `${aff.positionTitle ? `<p class="text-[11px] text-gray-500 mt-2">ตำแหน่ง: ${aff.positionTitle}</p>` : ''}`}

              </div>
            `).join('');
          } else if (deptEmpty) {
            deptEmpty.classList.remove('hidden');
          }

          // Last login
          if (user.lastLoginAt) {
            const lastLogin = new Date(user.lastLoginAt);
            const loginStr = lastLogin.toLocaleDateString('th-TH', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' });
            setText('profileLastLogin', loginStr);
          } else {
            setText('profileLastLogin', '-');
          }

        } catch (e) {
          console.error('Error loading user data:', e);
          // Fallback to localStorage if API fails
          const userStr = localStorage.getItem('ku_user');
          if (userStr) {
            try {
              const user = JSON.parse(userStr);
              const setText = (id, val) => {
                const el = document.getElementById(id);
                if (el && val) el.textContent = val;
              };

              setText('profileName', user.name || user.username || '-');
              setText('profileEmail', user.email || '-');
              setText('profileRoleBadge', user.role || user.roleName || 'ผู้ใช้งาน');
              setText('infoName', user.name || user.username || '-');
              setText('infoPosition', user.position || user.roleName || '-');
              setText('infoEmail', user.email || '-');
              setText('infoDepartment', user.faculty || user.department || '-');
              setText('infoPhone', user.phone || '-');
              setText('infoKuUid', user.kuUid || '-');
              setText('infoKuFacultyId', user.kuFacultyId || '-');
            } catch (fallbackError) {
              console.error('Error in fallback:', fallbackError);
            }
          }
        }
      }

      // Load user profile on page load
      loadUserProfile();

      // ===== Signature Drawing =====
      const signatureModal = document.getElementById('signatureModal');
      const signaturePreview = document.getElementById('signaturePreview');
      const signaturePlaceholder = document.getElementById('signaturePlaceholder');
      const drawCanvas = document.getElementById('drawCanvas');

      let isDrawing = false;
      let ctx = null;

      function initCanvas() {
        if (!drawCanvas) return;
        const container = drawCanvas.parentElement;
        drawCanvas.width = container.offsetWidth;
        drawCanvas.height = container.offsetHeight;
        ctx = drawCanvas.getContext('2d');
        ctx.strokeStyle = '#000';
        ctx.lineWidth = 2;
        ctx.lineCap = 'round';
        ctx.lineJoin = 'round';
      }

      function showSignatureModal() {
        signatureModal?.classList.remove('hidden');
        signatureModal?.classList.add('flex');
        setTimeout(initCanvas, 100);
      }

      function hideSignatureModal() {
        signatureModal?.classList.add('hidden');
        signatureModal?.classList.remove('flex');
      }

      document.getElementById('changeSignatureBtn')?.addEventListener('click', showSignatureModal);
      document.getElementById('closeSignatureModal')?.addEventListener('click', hideSignatureModal);
      document.getElementById('cancelSignature')?.addEventListener('click', hideSignatureModal);

      // Drawing events
      if (drawCanvas) {
        const getPos = (e) => {
          const rect = drawCanvas.getBoundingClientRect();
          const clientX = e.touches ? e.touches[0].clientX : e.clientX;
          const clientY = e.touches ? e.touches[0].clientY : e.clientY;
          return {
            x: (clientX - rect.left) * (drawCanvas.width / rect.width),
            y: (clientY - rect.top) * (drawCanvas.height / rect.height)
          };
        };

        const startDraw = (e) => {
          e.preventDefault();
          isDrawing = true;
          const pos = getPos(e);
          ctx?.beginPath();
          ctx?.moveTo(pos.x, pos.y);
        };
        const draw = (e) => {
          if (!isDrawing || !ctx) return;
          e.preventDefault();
          const pos = getPos(e);
          ctx.lineTo(pos.x, pos.y);
          ctx.stroke();
        };
        const stopDraw = () => { isDrawing = false; };

        drawCanvas.addEventListener('mousedown', startDraw);
        drawCanvas.addEventListener('mousemove', draw);
        drawCanvas.addEventListener('mouseup', stopDraw);
        drawCanvas.addEventListener('mouseleave', stopDraw);
        drawCanvas.addEventListener('touchstart', startDraw, { passive: false });
        drawCanvas.addEventListener('touchmove', draw, { passive: false });
        drawCanvas.addEventListener('touchend', stopDraw);
      }

      document.getElementById('clearSignature')?.addEventListener('click', () => {
        if (ctx && drawCanvas) {
          ctx.clearRect(0, 0, drawCanvas.width, drawCanvas.height);
        }
      });

      document.getElementById('saveSignature')?.addEventListener('click', () => {
        if (!drawCanvas) return;
        const dataUrl = drawCanvas.toDataURL('image/png');
        localStorage.setItem('ku_signature', dataUrl);

        // Update preview
        if (signaturePreview) {
          signaturePreview.innerHTML = `<img src="${dataUrl}" alt="ลายเซ็น" class="w-full h-full object-contain p-1">`;
        }

        const now = new Date();
        const dateStr = now.toLocaleDateString('th-TH', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' });
        const createdEl = document.getElementById('signatureCreatedAt');
        if (createdEl) createdEl.textContent = `สร้างเมื่อ: ${dateStr}`;

        hideSignatureModal();
      });

      document.getElementById('deleteSignatureBtn')?.addEventListener('click', () => {
        if (confirm('คุณต้องการลบลายเซ็นหรือไม่?')) {
          localStorage.removeItem('ku_signature');
          if (signaturePreview) {
            signaturePreview.innerHTML = `<p class="text-xs text-gray-400">ยังไม่มีลายเซ็น</p>`;
          }
          const createdEl = document.getElementById('signatureCreatedAt');
          if (createdEl) createdEl.textContent = 'สร้างเมื่อ: -';
        }
      });

      // Load existing signature
      const savedSig = localStorage.getItem('ku_signature');
      if (savedSig && signaturePreview) {
        signaturePreview.innerHTML = `<img src="${savedSig}" alt="ลายเซ็น" class="w-full h-full object-contain p-1">`;
      }

      // ===== Change Password Modal =====
      const passwordModal = document.getElementById('passwordModal');
      const currentPasswordInput = document.getElementById('currentPassword');
      const newPasswordInput = document.getElementById('newPassword');
      const confirmPasswordInput = document.getElementById('confirmPassword');
      const confirmBtn = document.getElementById('confirmPasswordChange');

      function showPasswordModal() {
        passwordModal?.classList.remove('hidden');
        passwordModal?.classList.add('flex');
        // Reset fields
        if (currentPasswordInput) currentPasswordInput.value = '';
        if (newPasswordInput) newPasswordInput.value = '';
        if (confirmPasswordInput) confirmPasswordInput.value = '';
        validatePassword();
      }

      function hidePasswordModal() {
        passwordModal?.classList.add('hidden');
        passwordModal?.classList.remove('flex');
      }

      document.getElementById('changePasswordBtnHeader')?.addEventListener('click', showPasswordModal);
      document.getElementById('changePasswordBtnSecurity')?.addEventListener('click', showPasswordModal);
      document.getElementById('closePasswordModal')?.addEventListener('click', hidePasswordModal);
      document.getElementById('cancelPasswordChange')?.addEventListener('click', hidePasswordModal);

      // Close modals on backdrop click
      [passwordModal, signatureModal].forEach(modal => {
        modal?.addEventListener('click', (e) => {
          if (e.target === modal) {
            modal.classList.add('hidden');
            modal.classList.remove('flex');
          }
        });
      });

      // Toggle password visibility
      document.querySelectorAll('.toggle-password').forEach(btn => {
        btn.addEventListener('click', () => {
          const targetId = btn.getAttribute('data-target');
          const input = document.getElementById(targetId);
          if (!input) return;
          const isPassword = input.type === 'password';
          input.type = isPassword ? 'text' : 'password';
          btn.querySelector('.eye-open')?.classList.toggle('hidden', !isPassword);
          btn.querySelector('.eye-closed')?.classList.toggle('hidden', isPassword);
        });
      });

      // Password validation
      function updateIcon(elementId, isValid, isReq) {
        const el = document.getElementById(elementId);
        if (!el) return;
        const icon = el.querySelector(isReq ? '.req-icon' : '.fill-icon');
        if (icon) {
          icon.classList.toggle('text-gray-300', !isValid);
          icon.classList.toggle('text-[#1a5c2a]', isValid);
        }
      }

      function validatePassword() {
        const current = currentPasswordInput?.value || '';
        const newPw = newPasswordInput?.value || '';
        const confirm = confirmPasswordInput?.value || '';

        // Requirements
        const hasLength = newPw.length >= 8;
        const hasCase = /[a-z]/.test(newPw) && /[A-Z]/.test(newPw);
        const hasSpecial = /[0-9]/.test(newPw) && /[^a-zA-Z0-9]/.test(newPw);

        updateIcon('reqLength', hasLength, true);
        updateIcon('reqCase', hasCase, true);
        updateIcon('reqSpecial', hasSpecial, true);

        // Fill status
        updateIcon('fillCurrent', current.length > 0, false);
        updateIcon('fillNew', newPw.length > 0, false);
        updateIcon('fillConfirm', confirm.length > 0 && confirm === newPw, false);

        // Enable/disable confirm button
        const allValid = current.length > 0 && hasLength && hasCase && hasSpecial && confirm === newPw && confirm.length > 0;
        if (confirmBtn) {
          confirmBtn.disabled = !allValid;
        }
      }

      currentPasswordInput?.addEventListener('input', validatePassword);
      newPasswordInput?.addEventListener('input', validatePassword);
      confirmPasswordInput?.addEventListener('input', validatePassword);

      // Submit password change
      confirmBtn?.addEventListener('click', async () => {
        const current = currentPasswordInput?.value;
        const newPw = newPasswordInput?.value;

        confirmBtn.disabled = true;
        confirmBtn.textContent = 'กำลังดำเนินการ...';

        try {
          const token = localStorage.getItem('ku_access_token');
          const res = await fetch('http://localhost:3000/api/auth/change-password', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Authorization': `Bearer ${token}`
            },
            body: JSON.stringify({ currentPassword: current, newPassword: newPw })
          });

          if (res.ok) {
            showSuccessToastWithCountdown('เปลี่ยนรหัสผ่านสำเร็จ!');
            setTimeout(() => {
              localStorage.removeItem('ku_access_token');
              localStorage.removeItem('ku_refresh_token');
              localStorage.removeItem('ku_user');
              window.location.replace('/login');
            }, 5000);
            hidePasswordModal();
          } else {
            const data = await res.json().catch(() => ({}));
            showToast(data.message || 'เกิดข้อผิดพลาดในการเปลี่ยนรหัสผ่าน', 'error');
            confirmBtn.disabled = false;
            confirmBtn.innerHTML = `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg> ยืนยันการเปลี่ยนรหัสผ่าน`;
          }
        } catch (err) {
          showToast('ไม่สามารถเชื่อมต่อกับเซิร์ฟเวอร์ได้', 'error');
          confirmBtn.disabled = false;
          confirmBtn.innerHTML = `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg> ยืนยันการเปลี่ยนรหัสผ่าน`;
        }
      });
    });
  </script>
</AuthLayout>
