---
import AuthLayout from '../layouts/AuthenticatedLayout.astro';
---

<AuthLayout title="โปรไฟล์ผู้ใช้งาน">

  <!-- ===== Profile Header Card ===== -->
  <div class="relative rounded-sm mb-6 overflow-hidden shadow-lg"
       style="background: linear-gradient(135deg, #0c2957 0%, #0a4068 45%, #006664 100%);">
    <!-- KU lime top accent bar -->
    <div class="absolute top-0 left-0 right-0 h-1.5" style="background: linear-gradient(90deg, #006664, #d4de3a, #b2bb1e);"></div>
    <!-- Decorative glows -->
    <div class="absolute -right-20 -top-20 w-80 h-80 rounded-full pointer-events-none"
         style="background: radial-gradient(circle, rgba(178,187,30,0.12) 0%, transparent 65%);"></div>
    <div class="absolute left-1/3 -bottom-10 w-56 h-56 rounded-full pointer-events-none"
         style="background: radial-gradient(circle, rgba(255,255,255,0.04) 0%, transparent 70%);"></div>
    <!-- Diagonal stripe texture -->
    <div class="absolute inset-0 pointer-events-none opacity-[0.03]"
         style="background-image: repeating-linear-gradient(45deg, #ffffff 0, #ffffff 1px, transparent 0, transparent 12px);"></div>

    <div class="relative z-10 p-6 sm:p-8 pt-8 sm:pt-9">
      <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-6">

        <!-- Left: Avatar + Info -->
        <div class="flex items-start gap-5">
          <!-- Circular avatar with lime ring -->
          <div class="shrink-0 relative">
            <div class="w-20 h-20 rounded-full flex items-center justify-center border-2" style="background: rgba(255,255,255,0.1); border-color: #b2bb1e;">
              <svg class="w-10 h-10 text-white/80" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
              </svg>
            </div>
            <div class="absolute bottom-0.5 right-0.5 w-3.5 h-3.5 rounded-full border-2 animate-pulse" style="background-color: #b2bb1e; border-color: #0c2957;"></div>
          </div>

          <!-- Name, email, badges -->
          <div class="pt-1">
            <h1 class="text-white text-xl sm:text-2xl font-semibold tracking-wide mb-1" id="profileName">กำลังโหลด...</h1>
            <p class="text-white/60 text-sm mb-3 font-light" id="profileEmail">-</p>
            <div class="flex flex-wrap items-center gap-2">
              <span class="inline-flex items-center px-3 py-1 text-xs font-bold uppercase tracking-wide rounded" style="background: rgba(178,187,30,0.2); color: #d4de3a; border: 1px solid rgba(178,187,30,0.4);" id="profileRoleBadge">-</span>
              <span class="inline-flex items-center px-3 py-1 text-xs font-medium text-white/75 border border-white/20 rounded uppercase tracking-wide" id="profileAccountType">KU Account</span>
            </div>
          </div>
        </div>

        <!-- Right: Action + Last Login -->
        <div class="flex flex-col gap-3 sm:items-end sm:pt-1">
          <button id="changePasswordBtnHeader" class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-semibold rounded border transition-colors shadow-sm" style="background: rgba(178,187,30,0.15); border-color: rgba(178,187,30,0.4); color: #d4de3a;" onmouseover="this.style.background='rgba(178,187,30,0.25)'" onmouseout="this.style.background='rgba(178,187,30,0.15)'">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
            </svg>
            เปลี่ยนรหัสผ่าน
          </button>
          <div class="text-white/50 text-xs flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span>เข้าสู่ระบบล่าสุด:</span>
            <span class="text-white/70 font-medium" id="profileLastLogin">-</span>
          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- ===== ข้อมูลส่วนตัว ===== -->
  <div class="bg-white rounded-lg border border-gray-200 shadow-sm mb-6 overflow-hidden">
    <!-- Section Header -->
    <div class="flex items-center gap-3 px-6 py-3.5 border-b border-gray-200 bg-gray-50">
      <div class="w-1 h-5 rounded-full bg-[#1a5c2a]"></div>
      <svg class="w-4.5 h-4.5 text-[#1a5c2a]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
      </svg>
      <h2 class="text-xs font-bold text-gray-700 uppercase tracking-widest">ข้อมูลส่วนตัว</h2>
    </div>

    <!-- Content Grid -->
    <div class="px-6 py-6">
      <dl class="grid grid-cols-1 md:grid-cols-3 gap-x-10 gap-y-6">
        <!-- Row 1 -->
        <div>
          <dt class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1.5">ชื่อ-นามสกุล</dt>
          <dd class="text-sm font-semibold text-gray-900" id="infoName">-</dd>
        </div>
        <div>
          <dt class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1.5">ตำแหน่งงาน</dt>
          <dd class="text-sm font-semibold text-gray-900" id="infoPosition">-</dd>
        </div>
        <div>
          <dt class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1.5">สถานะบัญชี</dt>
          <dd>
            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 text-xs font-semibold text-green-700 bg-green-50 border border-green-200 rounded" id="infoAccountStatus">
              <span class="w-1.5 h-1.5 bg-green-500 rounded-full"></span>
              ใช้งานได้ปกติ
            </span>
          </dd>
        </div>

        <!-- Row 2 -->
        <div>
          <dt class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1.5">อีเมล</dt>
          <dd class="text-sm font-semibold text-gray-900" id="infoEmail">-</dd>
        </div>
        <div>
          <dt class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1.5">หน่วยงานหลัก</dt>
          <dd class="text-sm font-semibold text-gray-900" id="infoDepartment">-</dd>
        </div>
        <div>
          <dt class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1.5">สร้างบัญชีเมื่อ</dt>
          <dd class="text-sm font-semibold text-gray-900" id="infoCreatedAt">-</dd>
        </div>

        <!-- Row 3 -->
        <div>
          <dt class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1.5">เบอร์โทรศัพท์</dt>
          <dd class="text-sm font-semibold text-gray-900" id="infoPhone">-</dd>
        </div>
        <div>
          <dt class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1.5">ส่วนงาน</dt>
          <dd class="text-sm font-semibold text-gray-900" id="infoCampus">-</dd>
        </div>
        <div>
          <dt class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1.5">KU UID</dt>
          <dd class="text-sm font-bold text-[#1a5c2a] font-mono" id="infoKuUid">-</dd>
        </div>
        <div>
          <dt class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1.5">KU Faculty ID</dt>
          <dd class="text-sm font-bold text-[#1a5c2a] font-mono" id="infoKuFacultyId">-</dd>
        </div>
      </dl>
    </div>
  </div>

  <!-- ===== Row: 3 cards side by side on desktop ===== -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6 items-start">

  <!-- ===== ลายเซ็นอิเล็กทรอนิกส์ ===== -->
  <div class="bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden h-full">
    <!-- Section Header -->
    <div class="flex items-center gap-3 px-6 py-3.5 border-b border-gray-200 bg-gray-50">
      <div class="w-1 h-5 rounded-full bg-[#1a5c2a]"></div>
      <svg class="w-4.5 h-4.5 text-[#1a5c2a]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path>
      </svg>
      <h2 class="text-xs font-bold text-gray-700 uppercase tracking-widest">ลายเซ็นอิเล็กทรอนิกส์</h2>
    </div>

    <div class="px-6 py-5">
      <div class="border border-gray-200 rounded-lg p-5 bg-gray-50/40">
        <!-- Header row -->
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
          <div class="flex items-center gap-2.5">
            <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path>
            </svg>
            <span class="text-sm font-semibold text-gray-700">ลายเซ็นของคุณ</span>
          </div>
          <div class="flex items-center gap-2">
            <button id="changeSignatureBtn" class="inline-flex items-center px-4 py-2 bg-[#1a5c2a] hover:bg-[#155222] text-white text-xs font-semibold rounded border border-[#145020] transition-colors">
              เปลี่ยนลายเซ็น
            </button>
            <button id="deleteSignatureBtn" class="inline-flex items-center px-4 py-2 bg-white hover:bg-red-50 text-red-600 text-xs font-semibold rounded border border-red-300 transition-colors">
              ลบลายเซ็น
            </button>
          </div>
        </div>

        <!-- Signature preview row -->
        <div class="mt-4 flex flex-col sm:flex-row sm:items-center gap-4" id="signatureArea">
          <div class="w-44 h-24 border border-dashed border-gray-300 rounded-lg flex items-center justify-center bg-white" id="signaturePreview">
            <p class="text-xs text-gray-400" id="signaturePlaceholder">ยังไม่มีลายเซ็น</p>
            <canvas id="signatureCanvas" class="hidden w-full h-full"></canvas>
          </div>
          <div>
            <div class="flex items-center gap-2 mb-1.5">
              <span class="text-xs text-gray-500" id="signatureType">ลายเซ็นที่วาด</span>
              <span class="inline-flex items-center gap-1 text-xs text-green-700 font-semibold" id="signatureStatus">
                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                </svg>
                ใช้งานอยู่
              </span>
            </div>
            <p class="text-xs text-gray-400" id="signatureCreatedAt">สร้างเมื่อ: -</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Signature Drawing Modal -->
  <div id="signatureModal" class="fixed inset-0 z-[9999] hidden items-center justify-center bg-black/50 backdrop-blur-sm">
    <div class="bg-white rounded-lg shadow-2xl w-full max-w-lg mx-4 overflow-hidden border border-gray-200">
      <div class="bg-[#1a5c2a] px-6 py-4 flex items-center justify-between">
        <div>
          <h3 class="text-white text-base font-bold tracking-wide">วาดลายเซ็น</h3>
          <p class="text-white/60 text-xs mt-0.5">วาดลายเซ็นของคุณในกรอบด้านล่าง</p>
        </div>
        <button id="closeSignatureModal" class="w-8 h-8 bg-white/10 hover:bg-white/20 rounded flex items-center justify-center text-white transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
      <div class="p-6">
        <div class="border-2 border-dashed border-gray-300 rounded-lg mb-4 bg-white relative" style="height: 200px;">
          <canvas id="drawCanvas" class="w-full h-full rounded-lg cursor-crosshair"></canvas>
        </div>
        <div class="flex items-center justify-between">
          <button id="clearSignature" class="px-4 py-2 text-gray-600 bg-gray-100 hover:bg-gray-200 rounded text-xs font-semibold transition-colors">
            ล้างลายเซ็น
          </button>
          <div class="flex gap-2">
            <button id="cancelSignature" class="px-4 py-2 text-gray-600 bg-white border border-gray-300 hover:bg-gray-50 rounded text-xs font-semibold transition-colors">
              ยกเลิก
            </button>
            <button id="saveSignature" class="px-4 py-2 bg-[#1a5c2a] hover:bg-[#155222] text-white rounded text-xs font-semibold transition-colors">
              บันทึกลายเซ็น
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ===== หน่วยงานที่สังกัด ===== -->
  <div class="bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden h-full">
    <!-- Section Header -->
    <div class="flex items-center gap-3 px-6 py-3.5 border-b border-gray-200 bg-gray-50">
      <div class="w-1 h-5 rounded-full bg-[#1a5c2a]"></div>
      <svg class="w-4.5 h-4.5 text-[#1a5c2a]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
      </svg>
      <h2 class="text-xs font-bold text-gray-700 uppercase tracking-widest">หน่วยงานที่สังกัด (มีได้มากกว่า 1 ส่วนงาน)</h2>
    </div>

    <div class="px-6 py-5">
      <div id="departmentList" class="grid grid-cols-1 gap-2">
        <!-- Populated by JS -->
      </div>
      <div id="departmentEmpty" class="text-center py-8">
        <p class="text-sm text-gray-400">ไม่พบข้อมูลหน่วยงาน</p>
      </div>
    </div>
  </div>

  <!-- ===== ความปลอดภัยของบัญชี ===== -->
  <div class="bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden h-full">
    <!-- Section Header -->
    <div class="flex items-center gap-3 px-6 py-3.5 border-b border-gray-200 bg-gray-50">
      <div class="w-1 h-5 rounded-full bg-[#0f2d4e]"></div>
      <svg class="w-4.5 h-4.5 text-[#0f2d4e]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
      </svg>
      <h2 class="text-xs font-bold text-gray-700 uppercase tracking-widest">ความปลอดภัยของบัญชี</h2>
    </div>

    <div class="px-6 py-5">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Security status -->
        <div class="space-y-3">
          <div class="flex items-center gap-2.5" id="emailVerificationStatus">
            <svg class="w-5 h-5 text-red-500 shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
            </svg>
            <span class="text-sm text-red-600">อีเมลยังไม่ได้รับการยืนยัน</span>
          </div>
          <div class="flex items-center gap-2.5" id="passwordStatus">
            <svg class="w-5 h-5 text-green-600 shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
            </svg>
            <span class="text-sm text-gray-700">รหัสผ่านได้รับการเข้ารหัสแล้ว</span>
          </div>
        </div>

        <!-- Password management -->
        <div>
          <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3">การจัดการรหัสผ่าน</p>
          <button id="changePasswordBtnSecurity" class="inline-flex items-center gap-2 px-5 py-2.5 bg-[#0f2d4e] hover:bg-[#0a2038] text-white text-sm font-semibold rounded border border-[#0a2038] transition-colors shadow-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
            </svg>
            เปลี่ยนรหัสผ่าน
          </button>
        </div>
      </div>
    </div>
  </div>

  </div><!-- end 3-column grid -->

  <!-- Toast Notification Container -->
  <div id="toastContainer" class="fixed top-4 right-4 z-[9999] pointer-events-none">
    <!-- Toast notifications will be dynamically added here -->
  </div>

  <!-- Change Password Modal -->
  <div id="passwordModal" class="fixed inset-0 z-[9999] hidden items-center justify-center bg-black/50 backdrop-blur-sm">
    <div class="bg-white rounded-lg shadow-2xl w-full max-w-2xl mx-4 overflow-hidden border border-gray-200">
      <!-- Modal Header -->
      <div class="bg-[#0f2d4e] px-6 py-4 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg"
            class="w-9 h-9 text-white/90" viewBox="0 0 24 24">
            <g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"><path d="M18.709 3.495C16.817 2.554 14.5 2 12 2s-4.816.554-6.709 1.495c-.928.462-1.392.693-1.841 1.419S3 6.343 3 7.748v3.49c0 5.683 4.542 8.843 7.173 10.196c.734.377 1.1.566 1.827.566s1.093-.189 1.827-.566C16.457 20.08 21 16.92 21 11.237V7.748c0-1.405 0-2.108-.45-2.834s-.913-.957-1.841-1.419"/><path d="M12 9v1m-1-.5a1 1 0 1 0 2 0a1 1 0 0 0-2 0"/><path d="M12.75 14h-1.5l.75-3.5z"/></g>
          </svg>
          <div>
            <h3 class="text-white text-base font-bold tracking-wide">เปลี่ยนรหัสผ่าน</h3>
            <p class="text-white/90 text-xs mt-0.5">เพื่อความปลอดภัยของบัญชีผู้ใช้งาน</p>
          </div>
        </div>
        <button id="closePasswordModal" class="w-8 h-8 bg-white/10 hover:bg-white/20 rounded flex items-center justify-center text-white transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>

      <!-- Modal Body -->
      <div class="p-6">
        <!-- Warning notice -->
        <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-6">
          <div class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-amber-600 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
            </svg>
            <div>
              <p class="text-xs font-bold text-amber-800 uppercase tracking-wide mb-1">ข้อควรระวัง</p>
              <p class="text-sm text-amber-700">หลังจากเปลี่ยนรหัสผ่านสำเร็จ ระบบจะส่งรหัสผ่านใหม่ไปยังอีเมลของคุณ และจะทำการออกจากระบบอัตโนมัติใน 15 วินาที</p>
            </div>
          </div>
        </div>

        <!-- Form Fields -->
        <div class="space-y-4">
          <div>
            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1.5">รหัสผ่านปัจจุบัน <span class="text-red-500 normal-case font-normal">*</span></label>
            <div class="relative">
