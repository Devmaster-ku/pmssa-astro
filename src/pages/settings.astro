    function switchTab(tab: string): void {
      document
        .querySelectorAll(".settings-panel")
        .forEach((p) => p.classList.add("hidden"));
      document.querySelectorAll(".settings-tab").forEach((t) => {
        t.classList.remove("active-tab");
        t.classList.add("text-gray-500");
        (t as HTMLElement).style.borderBottomColor = "transparent";
      });
      document.getElementById("panel-" + tab)?.classList.remove("hidden");
      const activeBtn = document.getElementById("tab-" + tab);
      if (activeBtn) {
        activeBtn.classList.add("active-tab");
        activeBtn.classList.remove("text-gray-500");
      }
    }

    function switchBudgetTab(tab: string): void {
      document
        .querySelectorAll(".budget-panel")
        .forEach((p) => p.classList.add("hidden"));
      document.querySelectorAll(".budget-tab").forEach((t) => {
        t.classList.remove("active-budget-tab");
        t.classList.add("text-gray-500");
        (t as HTMLElement).style.background = "";
        (t as HTMLElement).style.color = "";
      });
      document.getElementById("bpanel-" + tab)?.classList.remove("hidden");
      const activeBtn = document.getElementById("btab-" + tab);
      if (activeBtn) {
        activeBtn.classList.add("active-budget-tab");
        activeBtn.classList.remove("text-gray-500");
      }
    }

