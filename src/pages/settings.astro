        const json = await res.json();
        allGroups = json.data || [];
        // Populate filter dropdown — เฉพาะชื่อกลุ่มที่มีในข้อมูลจริง
        const sel = document.getElementById("groupTypeFilter");
        if (sel) {
          const seen = new Map<string, string>();
          for (const g of allGroups as any[]) {
            if (
              g.budgetTypeId &&
              g.budgetType?.nameTh &&
              !seen.has(String(g.budgetTypeId))
            ) {
              seen.set(String(g.budgetTypeId), g.budgetType.nameTh);
            }
          }
          const opts = [...seen.entries()].sort((a, b) =>
            a[1].localeCompare(b[1], "th"),
          );
          sel.innerHTML =
            '<option value="">แสดงทุกกลุ่ม</option>' +
            opts
              .map(([id, name]) => `<option value="${id}">${name}</option>`)
              .join("");
        }
        renderGroups(allGroups);
      } catch {
        if (container)
          container.innerHTML = `<div class="flex items-center justify-center py-10 text-red-400 text-sm">โหลดข้อมูลล้มเหลว</div>`;
      }
    }

    function renderExpenseDetails(data: any[]) {
      const container = document.getElementById("expenseDetailsContainer");
      if (!container) return;
      if (!data.length) {
        container.innerHTML = `<div class="flex flex-col items-center gap-2 text-gray-400 py-10"><p class="text-sm">ไม่พบข้อมูล</p></div>`;
        return;
      }

      // Build tree: attach sub items under their main parent
      const byId: Record<number, any> = {};
      for (const s of data) byId[s.id] = { ...s, children: [] };

      const roots: any[] = [];
      for (const s of data) {
        if (s.detailType === "sub" && s.parentId && byId[s.parentId]) {
          byId[s.parentId].children.push(byId[s.id]);
        } else {
          roots.push(byId[s.id]);
        }
      }

      // Sort
      roots.sort((a: any, b: any) =>
        (a.name || "").localeCompare(b.name || "", "th"),
      );
      for (const r of roots)
        r.children.sort((a: any, b: any) =>
          (a.name || "").localeCompare(b.name || "", "th"),
        );

      const actionBtns = (id: number, safeName: string) =>
        hasPermission("settings.manage")
          ? `<div class="flex gap-1 ml-1 flex-shrink-0">
          <button onclick="editBudgetItem('expense-details', ${id})" class="inline-flex items-center gap-1 px-2.5 py-1 text-xs font-medium text-[#006664] bg-[#006664]/10 hover:bg-[#006664]/20 rounded transition-colors">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
            แก้ไข
          </button>
          <button onclick="deleteItem('budget-expense-details', ${id}, '${safeName}')" class="inline-flex items-center gap-1 px-2.5 py-1 text-xs font-medium text-red-500 bg-red-50 hover:bg-red-100 rounded transition-colors">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
            ลบ
          </button>
        </div>`
          : "";

      let html = "";
      for (const main of roots) {
        const hasChildren = main.children.length > 0;
        const isCollapsed = collapsedExpenseNodes.has(main.id);
        const safeName = main.name.replace(/'/g, "\\'");

        html += `<div class="flex items-stretch border-b border-gray-100 hover:brightness-[0.97] transition-all" style="min-height:48px;background:rgba(0,102,100,0.025);">
          <div style="width:4px;flex-shrink:0;background:#006664;opacity:0.5;"></div>
          <div class="flex items-center flex-1 px-4 py-2.5 gap-2 min-w-0">
            ${
              hasChildren
                ? `<svg class="w-3.5 h-3.5 flex-shrink-0 transition-transform text-gray-400 ${isCollapsed ? "" : "rotate-90"}" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>`
                : `<span class="w-3.5 flex-shrink-0"></span>`
            }
            <div class="min-w-0 flex-1">
              <div class="flex items-center gap-2 flex-wrap">
                <span class="${hasChildren ? "cursor-pointer hover:text-[#006664]" : ""} font-semibold text-sm text-gray-800" ${hasChildren ? `onclick="toggleExpenseNode(${main.id})"` : ""}>${main.name}</span>
                <span class="inline-flex items-center px-1.5 py-0.5 text-xs font-medium rounded" style="color:#006664;background:rgba(0,102,100,0.08);border:1px solid rgba(0,102,100,0.25);">หัวข้อหลัก</span>
                ${hasChildren ? `<span class="text-xs text-gray-400">${main.children.length} หัวข้อย่อย</span>` : ""}
              </div>
              ${main.budgetGroup?.name ? `<p class="text-xs text-gray-400 mt-0.5">${main.budgetGroup.name}</p>` : ""}
            </div>
          </div>
          <div class="flex items-center gap-2 px-3 flex-shrink-0">
            ${statusBadge(main.isActive)}
            ${actionBtns(main.id, safeName)}
          </div>
        </div>`;

        if (!isCollapsed) {
          const lastIdx = main.children.length - 1;
          for (let i = 0; i < main.children.length; i++) {
            const sub = main.children[i];
            const isLast = i === lastIdx;
            const safeSubName = sub.name.replace(/'/g, "\\'");
            html += `<div class="flex items-stretch border-b border-gray-100 hover:brightness-[0.97] transition-all" style="min-height:42px;">
              <div style="width:4px;flex-shrink:0;background:#006664;opacity:0.5;"></div>
              <!-- tree guide -->
              <div style="width:22px;flex-shrink:0;display:flex;justify-content:center;position:relative;">
                <div style="position:absolute;left:50%;top:0;width:2px;height:${isLast ? "50%" : "100%"};background:rgba(0,102,100,0.2);transform:translateX(-50%);"></div>
                <div style="position:absolute;left:50%;top:50%;width:55%;height:2px;background:rgba(0,102,100,0.2);transform:translateY(-50%);"></div>
              </div>
              <div class="flex items-center flex-1 px-3 py-2 gap-2 min-w-0">
                <span class="w-5 flex-shrink-0"></span>
                <div class="min-w-0 flex-1">
                  <div class="flex items-center gap-2 flex-wrap">
                    <span class="font-medium text-sm text-gray-700">${sub.name}</span>
                  </div>
                </div>
              </div>
              <div class="flex items-center gap-2 px-3 flex-shrink-0">
                ${statusBadge(sub.isActive)}
                ${actionBtns(sub.id, safeSubName)}
              </div>
            </div>`;
          }
        }
      }
      container.innerHTML = html;
    }

    (window as any).toggleExpenseNode = function (id: number): void {
      if (collapsedExpenseNodes.has(id)) collapsedExpenseNodes.delete(id);
      else collapsedExpenseNodes.add(id);
      filterExpenseDetails();
    };

    function filterExpenseDetails(): void {
      const q = (
        (document.getElementById("expenseSearch") as HTMLInputElement)?.value || ""
      ).toLowerCase();
      const groupId =
        (document.getElementById("expenseGroupFilter") as HTMLSelectElement)?.value || "";

      const all = allExpenseDetails as any[];

      if (!q && !groupId) {
        renderExpenseDetails(all);
        return;
      }

      if (groupId) {
        const mainId = Number(groupId);
        // แสดง main นั้นเสมอ + sub ที่ตรงกับคำค้น (หรือทุก sub ถ้าไม่มีคำค้น)
        renderExpenseDetails(
          all.filter(
            (s) =>
              s.id === mainId ||
              (s.parentId === mainId &&
                (!q || s.name?.toLowerCase().includes(q))),
          ),
        );
        return;
      }

      // ค้นหาเฉพาะ text: match รายการที่ชื่อตรง + ดึง parent main มาด้วย (ไม่ดึง sub อื่น)
      const matchedIds = new Set<number>();
      for (const s of all) {
        if (s.name?.toLowerCase().includes(q)) matchedIds.add(s.id);
      }
      // sub match → ดึง parent main มาด้วย
      for (const s of all) {
        if (matchedIds.has(s.id) && s.detailType === "sub" && s.parentId)
          matchedIds.add(s.parentId);
      }
      renderExpenseDetails(all.filter((s) => matchedIds.has(s.id)));
    }

    async function loadBudgetExpenseDetails(): Promise<void> {
      const container = document.getElementById("expenseDetailsContainer");
      try {
        const res = await (window as any).apiFetch(
          `${API}/api/settings/budget-expense-details`,
        );
        if (res.status === 403) {
          if (container) container.innerHTML = noPermHtml("div");
          return;
        }
        const json = await res.json();
        allExpenseDetails = json.data || [];
        const sel = document.getElementById("expenseGroupFilter");
        if (sel) {
          const mainItems = (allExpenseDetails as any[]).filter(
            (s) => s.detailType === "main",
          );
          mainItems.sort((a: any, b: any) =>
            (a.name || "").localeCompare(b.name || "", "th"),
          );
          sel.innerHTML =
            '<option value="">ทุกหัวข้อหลัก</option>' +
            mainItems
              .map((s) => `<option value="${s.id}">${s.name}</option>`)
              .join("");
        }
        renderExpenseDetails(allExpenseDetails as any[]);
      } catch {
        if (container)
          container.innerHTML = `<div class="flex items-center justify-center py-10 text-red-400 text-sm">โหลดข้อมูลล้มเหลว</div>`;
      }
    }

    function onDetailTypeChange(): void {
      const isSub = (document.getElementById("budgetDetailTypeSub") as HTMLInputElement).checked;
      if (isSub) {
        const parentRow = document.getElementById("budgetParentRow");
        const subParentRow = document.getElementById("budgetSubParentRow");
        if (parentRow && subParentRow) {
          parentRow.classList.add("hidden");
          subParentRow.classList.remove("hidden");
        }
        // populate with all active main items
        const mainItems = allExpenseDetails
          .filter((s: any) => s.detailType === "main" && s.isActive)
          .sort((a: any, b: any) => (a.name || "").localeCompare(b.name || "", "th"));
        const subSel = document.getElementById("budgetSubParentId") as HTMLSelectElement | null;
        if (subSel) {
          subSel.innerHTML =
            '<option value="">-- เลือกหัวข้อหลัก --</option>' +
            mainItems.map((s: any) => {
              const groupName = s.budgetGroup?.name || allGroups.find((g: any) => g.id === s.budgetGroupId)?.name || "";
              return `<option value="${s.id}">${s.name}${groupName ? ` (${groupName})` : ""}</option>`;
            }).join("");
        }
      } else {
        const parentRow = document.getElementById("budgetParentRow");
        const subParentRow = document.getElementById("budgetSubParentRow");
        if (parentRow && subParentRow) {
          parentRow.classList.remove("hidden");
          subParentRow.classList.add("hidden");
        }
      }
    }

    function onExpenseGroupChange(): void {
      // no-op: group change doesn't affect sub-parent list (sub-parent shows all main items)
    }

    function openBudgetModal(type: string): void {
      if (!hasPermission("settings.manage")) {
        (window as any).showToast(
          "ท่านไม่มีสิทธิ์แก้ไขข้อมูลนี้ เนื่องจากท่านไม่ได้รับสิทธิ์จัดการการตั้งค่า",
          "error",
        );
        return;
      }
      const idEl = document.getElementById("budgetModalId") as HTMLInputElement | null;
      const typeEl = document.getElementById("budgetModalType") as HTMLInputElement | null;
      const codeEl = document.getElementById("budgetCode") as HTMLInputElement | null;
      const nameThEl = document.getElementById("budgetNameTh") as HTMLInputElement | null;
      const nameEnEl = document.getElementById("budgetNameEn") as HTMLInputElement | null;
      const isActiveRowEl = document.getElementById("budgetIsActiveRow");
      
      if (idEl) idEl.value = "";
      if (typeEl) typeEl.value = type;
      if (codeEl) codeEl.value = "";
      if (nameThEl) nameThEl.value = "";
      if (nameEnEl) nameEnEl.value = "";
      if (isActiveRowEl) isActiveRowEl.classList.add("hidden");
      // reset expense-details specific rows
      document.getElementById("budgetDetailTypeRow")?.classList.add("hidden");
      document.getElementById("budgetSubParentRow")?.classList.add("hidden");
      (document.getElementById("budgetSubParentId") as HTMLSelectElement | null)!.value = "";

      const parentRow = document.getElementById("budgetParentRow");
      const parentLabel = document.getElementById("budgetParentLabel");
      const parentSel = document.getElementById("budgetParentId") as HTMLSelectElement | null;
      const codeRow = document.getElementById("budgetCodeRow");
      const nameEnRow = document.getElementById("budgetNameEnRow");
      const nameLbl = document.getElementById("budgetNameThLabel");

      const titles: Record<string, string> = {
        subsidies: "เพิ่มงบอุดหนุน",
        "subsidy-types": "เพิ่มประเภทงบอุดหนุน",
        groups: "เพิ่มกลุ่มงบอุดหนุน",
        "expense-details": "เพิ่มรายละเอียดค่าใช้จ่าย",
      };
      document.getElementById("budgetModalTitle")!.textContent =
        titles[type as keyof typeof titles] || "เพิ่มข้อมูล";

      // groups/expense-details ไม่มี code/nameEn ใน schema
      const isNameOnly = type === "groups" || type === "expense-details";
      if (codeRow) codeRow.classList.toggle("hidden", isNameOnly);
      if (nameEnRow) nameEnRow.classList.toggle("hidden", isNameOnly);
      if (nameLbl)
        nameLbl.innerHTML = isNameOnly
          ? 'ชื่อ <span class="text-red-500">*</span>'
          : 'ชื่อ (ไทย) <span class="text-red-500">*</span>';

      if (type === "subsidies") {
        parentRow?.classList.add("hidden");
      } else if (type === "subsidy-types") {
        parentRow?.classList.remove("hidden");
        if (parentLabel) parentLabel.innerHTML = 'งบอุดหนุน <span class="text-red-500">*</span>';
        if (parentSel) parentSel.innerHTML =
          '<option value="">-- เลือกงบอุดหนุน --</option>' +
          allSubsidies
            .filter((s) => s.isActive)
            .map((s) => `<option value="${s.id}">${s.nameTh}</option>`)
            .join("");
      } else if (type === "groups") {
        parentRow?.classList.remove("hidden");
        if (parentLabel) parentLabel.innerHTML =
          'ประเภทงบอุดหนุน <span class="text-red-500">*</span>';
        if (parentSel) parentSel.innerHTML =
          '<option value="">-- เลือกประเภทงบอุดหนุน --</option>' +
          allSubsidyTypes
            .filter((s) => s.isActive)
            .map((s) => `<option value="${s.id}">${s.nameTh}</option>`)
            .join("");
      } else if (type === "expense-details") {
        parentRow?.classList.remove("hidden");
        if (parentLabel) parentLabel.innerHTML =
          'กลุ่มงบอุดหนุน <span class="text-red-500">*</span>';
        if (parentSel) parentSel.innerHTML =
          '<option value="">-- เลือกกลุ่มงบอุดหนุน --</option>' +
          allGroups
            .filter((s) => s.isActive)
            .map((s) => `<option value="${s.id}">${s.name}</option>`)
            .join("");
        // show detail type radio, reset to main
        document.getElementById("budgetDetailTypeRow")?.classList.remove("hidden");
        (document.getElementById("budgetDetailTypeMain") as HTMLInputElement | null)!.checked = true;
        document.getElementById("budgetSubParentRow")?.classList.add("hidden");
      }

      openModal("budgetModal");
    }

    function editBudgetItem(type: string, id: number): void {
      let item;
      if (type === "subsidies") item = allSubsidies.find((s) => s.id === id);
      else if (type === "subsidy-types")
        item = allSubsidyTypes.find((s) => s.id === id);
      else if (type === "groups") item = allGroups.find((s) => s.id === id);
      else if (type === "expense-details")
        item = allExpenseDetails.find((s) => s.id === id);

      if (!item) return;

      openBudgetModal(type);

      if (item) {
        (document.getElementById("budgetModalId") as HTMLInputElement | null)!.value = String(id);
        // groups และ expense-details ใช้ field `name` (ไม่มี code/nameTh)
        const isNameOnly = type === "groups" || type === "expense-details";
        (document.getElementById("budgetCode") as HTMLInputElement | null)!.value = isNameOnly
          ? ""
          : item.code || "";
        (document.getElementById("budgetNameTh") as HTMLInputElement | null)!.value = isNameOnly
          ? item.name
          : item.nameTh || "";
        (document.getElementById("budgetNameEn") as HTMLInputElement | null)!.value = item.nameEn || "";
        document.getElementById("budgetIsActiveRow")?.classList.remove("hidden");
        (document.getElementById("budgetIsActive") as HTMLInputElement | null)!.checked = item.isActive;

        const titles: Record<string, string> = {
          subsidies: "แก้ไขงบอุดหนุน",
          "subsidy-types": "แก้ไขประเภทงบอุดหนุน",
          groups: "แก้ไขกลุ่มงบอุดหนุน",
          "expense-details": "แก้ไขรายละเอียดค่าใช้จ่าย",
        };
        (document.getElementById("budgetModalTitle") as HTMLElement | null)!.textContent =
          titles[type as keyof typeof titles] || "แก้ไขข้อมูล";

        if (type === "subsidy-types" && item.subsidyId) {
          (document.getElementById("budgetParentId") as HTMLSelectElement | null)!.value = String(item.subsidyId);
        } else if (type === "groups" && item.budgetTypeId) {
          (document.getElementById("budgetParentId") as HTMLSelectElement | null)!.value = String(item.budgetTypeId);
        } else if (type === "expense-details") {
          // set detail type radio
          const isSub = item.detailType === "sub";
          (document.getElementById("budgetDetailTypeMain") as HTMLInputElement).checked = !isSub;
          (document.getElementById("budgetDetailTypeSub") as HTMLInputElement).checked = isSub;

          if (isSub) {
            // for sub: hide group row, show sub-parent row
            const parentRow = document.getElementById("budgetParentRow");
            const subParentRow = document.getElementById("budgetSubParentRow");
            if (parentRow && subParentRow) {
              parentRow.classList.add("hidden");
              subParentRow.classList.remove("hidden");
            }
            // populate sub-parent with all active main items
            const mainItems = allExpenseDetails
              .filter((s: any) => s.detailType === "main" && s.isActive && s.id !== item.id)
              .sort((a: any, b: any) => (a.name || "").localeCompare(b.name || "", "th"));
            const subSel = document.getElementById("budgetSubParentId");
            if (subSel) subSel.innerHTML =
              '<option value="">-- เลือกหัวข้อหลัก --</option>' +
              mainItems.map((s: any) => {
                const groupName = s.budgetGroup?.name || allGroups.find((g: any) => g.id === s.budgetGroupId)?.name || "";
                return `<option value="${s.id}">${s.name}${groupName ? ` (${groupName})` : ""}</option>`;
              }).join("");
            if (item.parentId && subSel) (subSel as HTMLSelectElement).value = String(item.parentId);
          } else {
            // for main: show group row, hide sub-parent row
            const parentRow = document.getElementById("budgetParentRow");
            const subParentRow = document.getElementById("budgetSubParentRow");
            if (parentRow && subParentRow) {
              parentRow.classList.remove("hidden");
              subParentRow.classList.add("hidden");
            }
            let groupId = item.budgetGroupId;
            if (groupId) {
              const parentIdEl = document.getElementById("budgetParentId") as HTMLSelectElement | null;
              if (parentIdEl) parentIdEl.value = groupId;
            }
          }
        }
      }
    }

    async function saveBudgetItem(): Promise<void> {
      const idEl = document.getElementById("budgetModalId") as HTMLInputElement | null;
      const typeEl = document.getElementById("budgetModalType") as HTMLInputElement | null;
      const codeEl = document.getElementById("budgetCode") as HTMLInputElement | null;
      const nameThEl = document.getElementById("budgetNameTh") as HTMLInputElement | null;
      const nameEnEl = document.getElementById("budgetNameEn") as HTMLInputElement | null;
      const parentIdEl = document.getElementById("budgetParentId") as HTMLSelectElement | null;
      const isActiveEl = document.getElementById("budgetIsActive") as HTMLInputElement | null;
      
      if (!idEl || !typeEl || !codeEl || !nameThEl || !nameEnEl || !parentIdEl) return;
      
      const id = idEl.value;
      const type = typeEl.value;
      const code = codeEl.value.trim();
      const nameTh = nameThEl.value.trim();
      const nameEn = nameEnEl.value.trim() || undefined;
      const parentId = parentIdEl.value ? parseInt(parentIdEl.value) : undefined;
      const isActive = id && isActiveEl ? isActiveEl.checked : undefined;

      // groups และ expense-details ใช้ field `name` แทน nameTh/code
      const isNameOnly = type === "groups" || type === "expense-details";
      if (isNameOnly) {
        if (!nameTh) {
          (window as any).showToast("กรุณากรอกชื่อ", "error");
          return;
        }
      } else {
        if (!code || !nameTh) {
          (window as any).showToast("กรุณากรอกรหัสและชื่อ", "error");
          return;
        }
      }

      // ตรวจสอบ parentId สำหรับประเภทที่ต้องการ parent
      const requiresParent = type === "subsidy-types" || type === "groups";
      if (requiresParent && !parentId) {
        const parentLabels = {
          "subsidy-types": "กรุณาเลือกงบอุดหนุน",
          "groups": "กรุณาเลือกประเภทงบอุดหนุน",
        };
        (window as any).showToast(parentLabels[type] || "กรุณาเลือกข้อมูลอ้างอิง", "error");
        return;
      }

      // expense-details: validate based on detailType
      let expenseDetailType = "main";
      let expenseSubParentId: number | undefined;
      if (type === "expense-details") {
        expenseDetailType = (document.querySelector('input[name="budgetDetailType"]:checked') as HTMLInputElement)?.value || "main";
        if (expenseDetailType === "main") {
          if (!parentId) {
            (window as any).showToast("กรุณาเลือกกลุ่มงบอุดหนุน", "error");
            return;
          }
        } else {
          const subParentVal = (document.getElementById("budgetSubParentId") as HTMLSelectElement).value;
          if (!subParentVal) {
            (window as any).showToast("กรุณาเลือกหัวข้อหลัก", "error");
            return;
          }
          expenseSubParentId = parseInt(subParentVal);
        }
      }

      const endpointMap: Record<string, string> = {
        subsidies: "budget-subsidies",
        "subsidy-types": "budget-subsidy-types",
        groups: "budget-groups",
        "expense-details": "budget-expense-details",
      };
      const endpoint = endpointMap[type as keyof typeof endpointMap];

      let body: any;
      if (type === "groups") {
        body = { name: nameTh, budgetTypeId: parentId };
      } else if (type === "expense-details") {
        if (expenseDetailType === "main") {
          body = { name: nameTh, budgetGroupId: parentId, detailType: "main" };
        } else {
          // derive budgetGroupId from parent item
          const parentMain = allExpenseDetails.find((s: any) => s.id === expenseSubParentId);
          const derivedGroupId = parentMain?.budgetGroupId ?? undefined;
          body = { name: nameTh, detailType: "sub", parentId: expenseSubParentId, budgetGroupId: derivedGroupId };
        }
      } else {
        body = { code, nameTh, nameEn };
        if (type === "subsidy-types") body = { ...body, subsidyId: parentId };
      }
      if (id) body = { ...body, isActive };

      try {
        const url = id
          ? `${API}/api/settings/${endpoint}/${id}`
          : `${API}/api/settings/${endpoint}`;
        const method = id ? "PUT" : "POST";
        const res = await (window as any).apiFetch(url, {
          method,
          body: JSON.stringify(body),
        });
        const json = await res.json();
        if (json.success) {
          (window as any).showToast(json.message, "success");
          closeModal("budgetModal");
          // Reload affected table + dependent tables
          if (type === "subsidies") {
            await loadBudgetSubsidies();
            await loadBudgetSubsidyTypes(); // types display parent subsidy name
          } else if (type === "subsidy-types") {
            await loadBudgetSubsidyTypes();
          } else if (type === "groups") {
            await loadBudgetGroups();
            await loadBudgetExpenseDetails(); // details display parent group
          } else if (type === "expense-details") {
            await loadBudgetExpenseDetails();
          }
        } else {
          (window as any).showToast(json.message || "เกิดข้อผิดพลาด", "error");
        }
      } catch {
        (window as any).showToast("ไม่สามารถเชื่อมต่อเซิร์ฟเวอร์ได้", "error");
      }
    }

    // =====================
    // Delete (generic)
    // =====================
    function deleteItem(type: string, id: number, label: string): void {
      if (type === "org" && !canManageOrg(id)) {
        (window as any).showToast(
          "ท่านไม่มีสิทธิ์แก้ไขข้อมูลนี้ เนื่องจากท่านไม่ได้สังกัดหน่วยงานที่ต้องการดำเนินการ",
          "error"
        );
        return;
      }
      const budgetTypes = [
        "budget-subsidies",
        "budget-subsidy-types",
        "budget-groups",
        "budget-expense-details",
      ];
      if (budgetTypes.includes(type) && !hasPermission("settings.manage")) {
        (window as any).showToast(
          "ท่านไม่มีสิทธิ์แก้ไขข้อมูลนี้ เนื่องจากท่านไม่ได้รับสิทธิ์จัดการการตั้งค่า",
          "error",
        );
        return;
      }
      const confirmMsg = document.getElementById("confirmMsg");
      if (confirmMsg) {
        confirmMsg.textContent = `ต้องการลบ "${label}" ใช่หรือไม่?`;
      }
      const btn = document.getElementById("confirmDeleteBtn") as HTMLButtonElement | null;
      if (!btn) return;
      btn.onclick = async () => {
        try {
          let url;
          if (type === "affiliation")
            url = `${API}/api/admin/affiliations/${id}`;
          else if (type === "org")
            url = `${API}/api/settings/organizations/${id}`;
          else url = `${API}/api/settings/${type}/${id}`;

          const res = await (window as any).apiFetch(url, { method: "DELETE" });
          const json = await res.json();
          if (json.success) {
            (window as any).showToast(json.message, "success");
            closeModal("confirmModal");
            // Remove from local state immediately for instant UI feedback,
            // then refresh from server to sync
            if (type === "org") {
              loadOrganizations();
            } else if (type === "budget-subsidies") {
              allSubsidies = allSubsidies.filter((s) => s.id !== id);
              renderSubsidies(allSubsidies);
              loadBudgetSubsidies();
              loadBudgetSubsidyTypes();
            } else if (type === "budget-subsidy-types") {
              allSubsidyTypes = allSubsidyTypes.filter((s) => s.id !== id);
              renderSubsidyTypes(allSubsidyTypes);
              loadBudgetSubsidyTypes();
            } else if (type === "budget-groups") {
              allGroups = allGroups.filter((s) => s.id !== id);
              renderGroups(allGroups);
              loadBudgetGroups();
              loadBudgetExpenseDetails();
            } else if (type === "budget-expense-details") {
              allExpenseDetails = allExpenseDetails.filter((s) => s.id !== id);
              renderExpenseDetails(allExpenseDetails);
              loadBudgetExpenseDetails();
            }
          } else {
            (window as any).showToast(
              json.message || "เกิดข้อผิดพลาด",
              "error",
            );
          }
        } catch {
          (window as any).showToast(
            "ไม่สามารถเชื่อมต่อเซิร์ฟเวอร์ได้",
            "error",
          );
        }
      };
      openModal("confirmModal");
    }

    // =====================
    // Budget sub-tab load on switch
    // =====================
    // Expose all onclick-referenced functions to window (Astro script = ES module, not global)
    // =====================
    const _w = window as any;
    _w.switchTab = switchTab;
    _w.closeModal = closeModal;
    _w.filterOrgs = filterOrgs;
    _w.openOrgModal = openOrgModal;
    _w.editOrg = editOrg;
    _w.saveOrg = saveOrg;
    _w.openBudgetModal = openBudgetModal;
    _w.editBudgetItem = editBudgetItem;
    _w.saveBudgetItem = saveBudgetItem;
    _w.deleteItem = deleteItem;
    _w.filterSubsidies = filterSubsidies;
    _w.filterSubsidyTypes = filterSubsidyTypes;
    _w.filterGroups = filterGroups;
    _w.filterExpenseDetails = filterExpenseDetails;
    _w.onDetailTypeChange = onDetailTypeChange;
    _w.onExpenseGroupChange = onExpenseGroupChange;

    const budgetTabLoaded: Record<string, boolean> = {
      subsidies: false,
      "subsidy-types": false,
      groups: false,
      "expense-details": false,
    };
    const origSwitchBudgetTab = switchBudgetTab;
    (window as any).switchBudgetTab = function (tab: string): void {
      origSwitchBudgetTab(tab);
      if (!budgetTabLoaded[tab as keyof typeof budgetTabLoaded]) {
        budgetTabLoaded[tab as keyof typeof budgetTabLoaded] = true;
        if (tab === "subsidies") loadBudgetSubsidies();
        else if (tab === "subsidy-types") loadBudgetSubsidyTypes();
        else if (tab === "groups") loadBudgetGroups();
        else if (tab === "expense-details") loadBudgetExpenseDetails();
      }
    };

    // =====================
    // Initialize
    // =====================
    document.addEventListener("DOMContentLoaded", async () => {
      // แสดงข้อมูลจาก localStorage ก่อน (fast initial render)
      const userStr = localStorage.getItem("ku_user");
      if (!userStr) {
        window.location.replace("/login");
        return;
      }

      let user: any;
      try {
        user = JSON.parse(userStr);
      } catch {
        window.location.replace("/login");
        return;
      }

      let activeAffiliation: any = null;
      try {
        activeAffiliation = JSON.parse(
          localStorage.getItem("ku_active_affiliation") || "null",
        );
      } catch {}

      const allowedRoles = [
        "super_admin",
        "univ_executive",
        "univ_officer",
        "campus_executive",
        "campus_officer",
        "faculty_executive",
        "org_admin",
        "unit_head",
        "project_lead",
        "staff",
      ];
      const role = activeAffiliation?.role;
      if (!allowedRoles.includes(role)) {
        document.getElementById("accessDenied")?.classList.remove("hidden");
        return;
      }

      currentRole = role;
      currentAffiliationOrg = activeAffiliation?.organization ?? null;
      document.getElementById("settingsContent")?.classList.remove("hidden");

      if (role !== "super_admin") {
        document.getElementById("addOrgBtn")?.classList.add("hidden");
      }

      // Fetch /api/auth/me พร้อม auto-refresh เมื่อ token หมดอายุ
      async function fetchMe() {
        let token = localStorage.getItem("ku_access_token");
        if (!token) return null;

        let res = await fetch(`${API}/api/auth/me`, {
          headers: { Authorization: `Bearer ${token}` },
        });

        if (res.status === 401) {
          const refreshToken = localStorage.getItem("ku_refresh_token");
          if (!refreshToken) {
            window.location.replace("/login");
            return null;
          }

          const rfRes = await fetch(`${API}/api/auth/refresh`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ refreshToken }),
          });
          const rfData = await rfRes.json();

          if (!rfData.success) {
            window.location.replace("/login");
            return null;
          }

          localStorage.setItem("ku_access_token", rfData.accessToken);
          localStorage.setItem("ku_refresh_token", rfData.refreshToken);
          if (rfData.user)
            localStorage.setItem("ku_user", JSON.stringify(rfData.user));

          res = await fetch(`${API}/api/auth/me`, {
            headers: { Authorization: `Bearer ${rfData.accessToken}` },
          });
        }

        const data = await res.json();
        return data.success ? data : null;
      }

      // Verify & refresh token ก่อนโหลดข้อมูล
      // ถ้า token หมดอายุจะ refresh อัตโนมัติ, ถ้า refresh ไม่สำเร็จจะ redirect login
      await fetchMe()
        .then((data) => {
          if (!data) return;
          if (data.user)
            localStorage.setItem("ku_user", JSON.stringify(data.user));
          if (data.activeAffiliation)
            localStorage.setItem(
              "ku_active_affiliation",
              JSON.stringify(data.activeAffiliation),
            );
        })
        .catch(() => {
          /* ใช้ข้อมูลจาก localStorage แทน */
        });

      // Load initial data (token is now fresh)
      await loadCampuses();
      await loadMyPermissions();
      applyBudgetPermissions();
      await loadOrganizations();
      loadPermissionMatrix();
      loadBudgetSubsidies();
      budgetTabLoaded["subsidies"] = true;
      loadBudgetSubsidyTypes();
      budgetTabLoaded["subsidy-types"] = true;
      loadBudgetGroups();
      budgetTabLoaded["groups"] = true;
    });
  </script>

