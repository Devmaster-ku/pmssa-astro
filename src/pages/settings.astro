    function filterOrgs(): void {
      const level = (document.getElementById("orgLevelFilter") as HTMLSelectElement)?.value || "";
      const q = (
        (document.getElementById("orgSearchInput") as HTMLInputElement)?.value || ""
      ).toLowerCase();
      const visible = getVisibleOrgs(allOrgs);
      const effectiveLevel = level === "university" ? "" : level;
      if (!effectiveLevel && !q) {
        renderOrgsTable(visible);
        return;
      }

      // Find directly matched orgs (within role-visible set)
      let matched = visible;
      if (effectiveLevel)
        matched = matched.filter((o) => o.orgLevel === effectiveLevel);
      if (q)
        matched = matched.filter(
          (o) =>
            o.nameTh?.toLowerCase().includes(q) ||
            o.nameEn?.toLowerCase().includes(q) ||
            o.code?.toLowerCase().includes(q),
        );

      // Include ancestors so tree context is preserved (only within visible set)
      const byId = Object.fromEntries(visible.map((o) => [o.id, o]));
      const ids = new Set(matched.map((o) => o.id));
      for (const org of matched) {
        let cur = org;
        while (cur.parentId && byId[cur.parentId]) {
          ids.add(cur.parentId);
          cur = byId[cur.parentId];
        }
      }
      renderOrgsTable(visible.filter((o) => ids.has(o.id)));
    }

    function openOrgModal(): void {
      document.getElementById("orgModalTitle")!.textContent = "เพิ่มหน่วยงาน";
      (document.getElementById("orgModalId") as HTMLInputElement).value = "";
      (document.getElementById("orgCode") as HTMLInputElement).value = "";
      (document.getElementById("orgNameTh") as HTMLInputElement).value = "";
      (document.getElementById("orgNameEn") as HTMLInputElement).value = "";
      (document.getElementById("orgLevel") as HTMLSelectElement).value = "faculty";
      document.getElementById("orgIsActiveRow")!.classList.add("hidden");

      const sel = document.getElementById("orgParentId") as HTMLSelectElement;
      sel.innerHTML =
        '<option value="">-- ไม่มีหน่วยงานแม่ --</option>' +
        allOrgs
          .filter((o) => o.isActive)
          .map(
            (o) =>
              `<option value="${o.id}">[${getOrgLevelTh(o.orgLevel)}] ${o.nameTh}</option>`,
          )
          .join("");

      // Don't call populateCampusSelect here; let updateCampusRowVisibility handle it
      (window as any).updateCampusRowVisibility();
      openModal("orgModal");
    }

    function editOrg(id: number): void {
      if (!canManageOrg(id)) {
        (window as any).showToast(
          "ท่านไม่มีสิทธิ์แก้ไขข้อมูลนี้ เนื่องจากท่านไม่ได้สังกัดหน่วยงานที่ต้องการดำเนินการ",
          "error"
        );
        return;
      }
      const org = allOrgs.find((o) => o.id === id);
      if (!org) return;

      document.getElementById("orgModalTitle")!.textContent = "แก้ไขหน่วยงาน";
      (document.getElementById("orgModalId") as HTMLInputElement).value = org.id;
      (document.getElementById("orgCode") as HTMLInputElement).value = org.code;
      (document.getElementById("orgNameTh") as HTMLInputElement).value = org.nameTh;
      (document.getElementById("orgNameEn") as HTMLInputElement).value = org.nameEn || "";
      (document.getElementById("orgLevel") as HTMLSelectElement).value = org.orgLevel;
      document.getElementById("orgIsActiveRow")!.classList.remove("hidden");
      (document.getElementById("orgIsActive") as HTMLInputElement).checked = org.isActive;

      const sel = document.getElementById("orgParentId") as HTMLSelectElement;
      sel.innerHTML =
        '<option value="">-- ไม่มีหน่วยงานแม่ --</option>' +
        allOrgs
          .filter((o) => o.id !== id && o.isActive)
          .map(
            (o) =>
              `<option value="${o.id}" ${o.id === org.parentId ? "selected" : ""}>[${getOrgLevelTh(o.orgLevel)}] ${o.nameTh}</option>`,
          )
          .join("");

      populateCampusSelect(org.campusId ?? null);
      (window as any).updateCampusRowVisibility();
      openModal("orgModal");
    }

    async function saveOrg(): Promise<void> {
      const id = (document.getElementById("orgModalId") as HTMLInputElement).value;
      const code = (document.getElementById("orgCode") as HTMLInputElement).value.trim();
      const nameTh = (document.getElementById("orgNameTh") as HTMLInputElement).value.trim();
      const nameEn =
        (document.getElementById("orgNameEn") as HTMLInputElement).value.trim() || undefined;
      const orgLevel = (document.getElementById("orgLevel") as HTMLSelectElement).value;
      const parentId = (document.getElementById("orgParentId") as HTMLSelectElement).value
        ? parseInt((document.getElementById("orgParentId") as HTMLSelectElement).value)
        : undefined;
      const campusIdRaw = (
        document.getElementById("orgCampusId") as HTMLSelectElement
      ).value;
      const campusId = campusIdRaw ? parseInt(campusIdRaw) : undefined;
      const isActive = id
        ? (document.getElementById("orgIsActive") as HTMLInputElement).checked
        : undefined;

      if (!code || !nameTh) {
        (window as any).showToast("กรุณากรอกรหัสและชื่อหน่วยงาน", "error");
        return;
      }

      try {
        const url = id
          ? `${API}/api/settings/organizations/${id}`
          : `${API}/api/settings/organizations`;
        const method = id ? "PUT" : "POST";
        const res = await (window as any).apiFetch(url, {
          method,
          body: JSON.stringify({
            code,
            nameTh,
            nameEn,
            orgLevel,
            parentId,
            campusId,
            isActive,
          }),
        });
        const json = await res.json();
        if (json.success) {
          (window as any).showToast(json.message, "success");
          closeModal("orgModal");
          await loadOrganizations();
        } else {
          (window as any).showToast(json.message || "เกิดข้อผิดพลาด", "error");
        }
      } catch {
        (window as any).showToast("ไม่สามารถเชื่อมต่อเซิร์ฟเวอร์ได้", "error");
      }
    }

