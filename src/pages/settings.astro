---
import AuthLayout from "../layouts/AuthenticatedLayout.astro";
---

<AuthLayout title="ตั้งค่าระบบ">
  <!-- Page Header -->
  <div
    class="relative rounded-sm mb-5 overflow-hidden shadow-lg"
    style="background: linear-gradient(135deg, #0c2957 0%, #0a4068 45%, #006664 100%);"
  >
    <div
      class="absolute top-0 left-0 right-0 h-1.5"
      style="background: linear-gradient(90deg, #006664, #d4de3a, #b2bb1e);"
    >
    </div>
    <div
      class="absolute -right-20 -top-20 w-80 h-80 rounded-full pointer-events-none"
      style="background: radial-gradient(circle, rgba(178,187,30,0.12) 0%, transparent 65%);"
    >
    </div>
    <div class="relative z-10 px-4 sm:px-3 py-4 pt-4">
      <div class="flex items-center gap-4">
        <div
          class="w-12 h-12 rounded-lg flex items-center justify-center shrink-0"
          style="background: rgba(178,187,30,0.2); border: 1px solid rgba(178,187,30,0.4);"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-6 h-6 text-[#d4de3a]"
            viewBox="0 0 14 14"
          >
            <g
              fill="none"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><rect
                width="13"
                height="13"
                x=".5"
                y=".5"
                rx="1"
                transform="rotate(-90 7 7)"></rect><path d="M4.5 11V6"
              ></path><circle cx="4.5" cy="4.5" r="1.5"></circle><path
                d="M9.5 3v3m0 3v2"></path><circle cx="9.5" cy="7.5" r="1.5"
              ></circle></g
            ></svg
          >
        </div>
        <div>
          <h1 class="text-white text-base sm:text-lg font-semibold">
            ตั้งค่าระบบ
          </h1>
          <p class="text-white/90 text-sm mt-0.5">
            จัดการสิทธิ์ผู้ใช้ หน่วยงาน และหมวดการใช้เงิน
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- Access Denied Message (hidden by default) -->
  <div
    id="accessDenied"
    class="hidden bg-red-50 border border-red-200 rounded-lg p-6 text-center mb-6"
  >
    <svg
      class="w-12 h-12 text-red-400 mx-auto mb-3"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
      ></path>
    </svg>
    <p class="text-red-700 font-semibold">ไม่มีสิทธิ์เข้าถึงหน้านี้</p>
    <p class="text-red-500 text-sm mt-1">
      เฉพาะ super_admin และ org_admin เท่านั้น
    </p>
  </div>

  <!-- Main Settings Content -->
  <div id="settingsContent" class="hidden">
    <!-- Tab Navigation -->
    <div class="bg-white rounded-lg border border-gray-200 shadow-sm mb-5">
      <div class="flex overflow-x-auto border-b border-gray-200">
        <button
          onclick="switchTab('permissions')"
          id="tab-permissions"
          class="settings-tab active-tab px-5 py-3.5 text-sm font-medium whitespace-nowrap flex items-center gap-2 border-b-2 transition-colors"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-5 h-5"
            viewBox="0 0 14 14"
          >
            <g
              fill="none"
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><rect width="13" height="13" x=".5" y=".5" rx="1"></rect><path
                d="M3 4.5h5"></path><circle cx="9.5" cy="4.5" r="1.5"
              ></circle><path d="M11 9.5H8m-3 0H3"></path><circle
                cx="6.5"
                cy="9.5"
                r="1.5"></circle></g
            >
          </svg>
          การจัดการสิทธิ์ในระบบ
        </button>
        <button
          onclick="switchTab('organizations')"
          id="tab-organizations"
          class="settings-tab px-5 py-3.5 text-sm font-medium whitespace-nowrap flex items-center gap-2 border-b-2 border-transparent transition-colors text-gray-500 hover:text-gray-700"
        >
          <svg
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
            ></path>
          </svg>
          ตั้งค่าหน่วยงาน
        </button>
        <button
          onclick="switchTab('budget')"
          id="tab-budget"
          class="settings-tab px-5 py-3.5 text-sm font-medium whitespace-nowrap flex items-center gap-2 border-b-2 border-transparent transition-colors text-gray-500 hover:text-gray-700"
        >
          <svg
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"
            ></path>
          </svg>
          ตั้งค่าหมวดการใช้เงิน
        </button>
      </div>
    </div>

    <!-- ===== TAB 1: การจัดการสิทธิ์ในระบบ ===== -->
    <div id="panel-permissions" class="settings-panel mb-8">
      <div
        class="bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden flex flex-col"
        style="max-height: calc(100vh - 220px);"
      >
        <!-- Header — fixed, does not scroll -->
        <div
          class="flex items-center justify-between px-5 py-4 border-b border-gray-200 bg-gray-50 shrink-0"
        >
          <div class="flex items-center gap-3">
            <div class="w-1 h-5 rounded-full bg-[#006664]"></div>
            <div>
              <h2
                class="text-sm font-bold text-gray-700 uppercase tracking-widest"
              >
                การจัดการสิทธิ์ในระบบ
              </h2>
              <p class="text-xs text-gray-600 mt-0.5">
                กำหนดให้แต่ละบทบาท สามารถเข้าถึงการดำเนินการได้ในระบบ
              </p>
            </div>
          </div>
          <div class="flex items-center gap-3">
            <span
              id="permUnsavedBadge"
              class="hidden text-xs font-medium text-amber-700 bg-amber-50 border border-amber-200 rounded px-2 py-1"
              >มีการเปลี่ยนแปลงที่ยังไม่บันทึก</span
            >
            <button
              onclick="savePermissionMatrix()"
              id="permSaveBtn"
              style="display:none"
              class="btn-primary inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-white rounded-lg transition-colors"
            >
              <svg
                class="w-4 h-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path></svg
              >
              บันทึกสิทธิ์
            </button>
          </div>
        </div>

        <!-- Legend — fixed, does not scroll -->
        <div
          class="flex items-center gap-4 px-5 py-3 border-b border-gray-100 bg-gray-50/50 text-xs text-gray-500 shrink-0"
        >
          <span class="flex items-center gap-1.5"
            ><span
              class="w-4 h-4 rounded border-2 border-[#006664] bg-[#006664] flex items-center justify-center"
              ><svg
                class="w-2.5 h-2.5 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="3"
                  d="M5 13l4 4L19 7"></path></svg
              ></span
            >มีสิทธิ์</span
          >
          <span class="flex items-center gap-1.5"
            ><span class="w-4 h-4 rounded border border-gray-300 bg-white"
            ></span>ไม่มีสิทธิ์</span
          >
        </div>

        <!-- Matrix Table — scrollable area (thead sticky inside) -->
        <div class="overflow-auto flex-1 no-scrollbar">
          <div id="permMatrixWrap">
            <div
              class="flex items-center justify-center py-10 text-gray-400 text-sm"
            >
              <svg
                class="animate-spin w-5 h-5 mr-2 text-[#006664]"
                fill="none"
                viewBox="0 0 24 24"
                ><circle
                  class="opacity-25"
                  cx="12"
                  cy="12"
                  r="10"
                  stroke="currentColor"
                  stroke-width="4"></circle><path
                  class="opacity-75"
                  fill="currentColor"
                  d="M4 12a8 8 0 018-8v8H4z"></path></svg
              >
              กำลังโหลดข้อมูล...
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ===== TAB 2: ตั้งค่าหน่วยงาน ===== -->
    <div id="panel-organizations" class="settings-panel hidden">
      <div
        class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden"
      >
        <!-- Section description -->
        <div
          class="px-5 pt-4 pb-3 flex items-start gap-3 bg-emerald-50/50 border-b border-emerald-100"
        >
          <div
            class="w-8 h-8 rounded-lg bg-[#006664] flex items-center justify-center shrink-0 mt-0.5"
          >
            <svg
              class="w-4 h-4 text-white"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
              ></path>
            </svg>
          </div>
          <div>
            <p class="text-sm font-semibold text-[#006664]">จัดการหน่วยงาน</p>
            <p class="text-xs text-gray-500 mt-0.5">
              กำหนดโครงสร้างหน่วยงาน ระดับ และความสัมพันธ์ระหว่างหน่วยงานในระบบ
            </p>
          </div>
        </div>

        <!-- Toolbar -->
        <div
          id="orgFilterRow"
          class="px-4 sm:px-5 py-3 border-b border-gray-100 flex flex-col sm:flex-row sm:items-center gap-3"
        >
          <div class="relative flex-1">
            <svg
              class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
            <input
              id="orgSearchInput"
              type="text"
              placeholder="ค้นหาหน่วยงาน..."
              oninput="filterOrgs()"
              class="w-full pl-9 pr-4 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#006664]/30 focus:border-[#006664]"
            />
          </div>
          <div class="flex items-center gap-2">
            <select
              id="orgLevelFilter"
              onchange="filterOrgs()"
              class="border border-gray-200 rounded-lg text-sm px-3 py-2 pr-8 focus:outline-none focus:ring-2 focus:ring-[#006664]/30 focus:border-[#006664] appearance-none dropdown-arrow"
            >
              <option value="">ทุกระดับ</option>
              <option value="university">มหาวิทยาลัย</option>
              <option value="campus">วิทยาเขต</option>
              <option value="faculty">คณะ/สำนัก/กอง</option>
              <option value="department">ภาควิชา/หน่วยงาน</option>
            </select>
            <button
              id="addOrgBtn"
              onclick="openOrgModal()"
              class="btn-primary flex items-center gap-2 px-4 py-2.5 text-sm font-semibold text-white rounded-lg transition-colors shadow-md"
            >
              <svg
                class="w-4 h-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 4v16m8-8H4"></path></svg
              >
              เพิ่มหน่วยงาน
            </button>
          </div>
        </div>

        <!-- Tree -->
        <div id="orgsTreeContainer">
          <div class="flex flex-col items-center gap-2 text-gray-400 py-12">
            <svg
              class="w-10 h-10 opacity-30 animate-spin"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
            </svg>
            <p class="text-sm">กำลังโหลดข้อมูล...</p>
          </div>
        </div>
      </div>
    </div>

    <!-- ===== TAB 3: ตั้งค่าหมวดการใช้เงิน ===== -->
    <div id="panel-budget" class="settings-panel hidden">
      <!-- Budget Sub-tabs -->
      <div class="bg-white rounded-lg border border-gray-200 shadow-sm mb-4">
        <div
          class="flex overflow-x-auto border-b border-gray-200 px-2 pt-2 gap-1"
        >
          <button
            onclick="switchBudgetTab('subsidies')"
            id="btab-subsidies"
            class="budget-tab active-budget-tab px-4 py-2.5 text-sm font-medium whitespace-nowrap rounded-t-lg transition-colors"
          >
            งบอุดหนุน
          </button>
          <button
            onclick="switchBudgetTab('subsidy-types')"
            id="btab-subsidy-types"
            class="budget-tab px-4 py-2.5 text-sm font-medium whitespace-nowrap rounded-t-lg transition-colors text-gray-500 hover:text-gray-700 hover:bg-gray-50"
          >
            ประเภทงบอุดหนุน
          </button>
          <button
            onclick="switchBudgetTab('groups')"
            id="btab-groups"
            class="budget-tab px-4 py-2.5 text-sm font-medium whitespace-nowrap rounded-t-lg transition-colors text-gray-500 hover:text-gray-700 hover:bg-gray-50"
          >
            กลุ่มงบอุดหนุน
          </button>
          <button
            onclick="switchBudgetTab('expense-details')"
            id="btab-expense-details"
            class="budget-tab px-4 py-2.5 text-sm font-medium whitespace-nowrap rounded-t-lg transition-colors text-gray-500 hover:text-gray-700 hover:bg-gray-50"
          >
            รายละเอียดค่าใช้จ่าย
          </button>
        </div>
      </div>

      <!-- Budget Panel: งบอุดหนุน -->
      <div id="bpanel-subsidies" class="budget-panel">
        <div
          class="bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden"
        >
          <div
            class="flex items-center justify-between px-5 py-4 border-b border-gray-200 bg-gray-50"
          >
            <div class="flex items-center gap-3">
              <div class="w-1 h-5 rounded-full bg-[#b2bb1e]"></div>
              <h2
                class="text-sm font-bold text-gray-700 uppercase tracking-widest"
              >
                งบอุดหนุน
              </h2>
            </div>
            <button
              id="addSubsidyBtn"
              onclick="openBudgetModal('subsidies')"
              class="btn-primary inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-white rounded-lg transition-colors"
            >
              <svg
                class="w-4 h-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 4v16m8-8H4"></path></svg
              >
              เพิ่มงบอุดหนุน
            </button>
          </div>
          <div
            id="subsidyFilterRow"
            class="px-4 sm:px-5 py-3 border-b border-gray-100 flex items-center gap-3"
          >
            <div class="relative flex-1">
              <svg
                class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
              </svg>
              <input
                id="subsidySearch"
                type="text"
                placeholder="ค้นหางบอุดหนุน (รหัส, ชื่อ)..."
                oninput="filterSubsidies()"
                class="w-full pl-9 pr-4 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#006664]/30 focus:border-[#006664]"
              />
            </div>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead id="subsidiesTableHead" class="bg-gray-50 border-b border-gray-200">
                <tr>
                  <th
                    class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider"
                    >รหัส</th
                  >
                  <th
                    class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider"
                    >ชื่อ (ไทย)</th
                  >
                  <th
                    class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider"
                    >ชื่อ (อังกฤษ)</th
                  >
                  <th
                    class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider"
                    >สถานะ</th
                  >
                  <th
                    class="text-right px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider"
                    >จัดการ</th
                  >
                </tr>
              </thead>
              <tbody id="subsidiesTableBody" class="divide-y divide-gray-100">
                <tr
                  ><td colspan="5" class="text-center py-8 text-gray-400"
                    >กำลังโหลดข้อมูล...</td
                  ></tr
                >
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Budget Panel: ประเภทงบอุดหนุน -->
      <div id="bpanel-subsidy-types" class="budget-panel hidden">
        <div
          class="bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden"
        >
          <div
            class="flex items-center justify-between px-5 py-4 border-b border-gray-200 bg-gray-50"
          >
            <div class="flex items-center gap-3">
              <div class="w-1 h-5 rounded-full bg-[#b2bb1e]"></div>
              <h2
                class="text-sm font-bold text-gray-700 uppercase tracking-widest"
              >
                ประเภทงบอุดหนุน
              </h2>
            </div>
            <button
              id="addSubsidyTypeBtn"
              onclick="openBudgetModal('subsidy-types')"
              class="btn-primary inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-white rounded-lg transition-colors"
            >
              <svg
                class="w-4 h-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 4v16m8-8H4"></path></svg
              >
              เพิ่มประเภทงบอุดหนุน
            </button>
          </div>
          <div
            id="subsidyTypeFilterRow"
            class="px-4 sm:px-5 py-3 border-b border-gray-100 flex flex-col sm:flex-row sm:items-center gap-3"
          >
            <div class="relative flex-1">
              <svg
                class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
              </svg>
              <input
                id="subsidyTypeSearch"
                type="text"
                placeholder="ค้นหาประเภทงบอุดหนุน (รหัส, ชื่อ)..."
                oninput="filterSubsidyTypes()"
                class="w-full pl-9 pr-4 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[#006664]/30 focus:border-[#006664]"
              />
            </div>
            <select
              id="subsidyTypeFilter"
              onchange="filterSubsidyTypes()"
              class="border border-gray-200 rounded-lg text-sm px-3 py-2 pr-8 focus:outline-none focus:ring-2 focus:ring-[#006664]/30 focus:border-[#006664] appearance-none dropdown-arrow"
            >
              <option value="">ทุกงบอุดหนุน</option>
            </select>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead id="subsidyTypesTableHead" class="bg-gray-50 border-b border-gray-200">
                <tr>
                  <th
                    class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider"
                    >รหัส</th
                  >
                  <th
                    class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider"
                    >ชื่อ (ไทย)</th
                  >
                  <th
                    class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider"
                    >งบอุดหนุน</th
                  >
                  <th
                    class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider"
