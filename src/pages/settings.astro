    (window as any).updateCampusRowVisibility = function (): void {
      const level = (document.getElementById("orgLevel") as HTMLSelectElement)
        .value;
      const campusRow = document.getElementById("orgCampusRow") as HTMLElement;
      const parentRow = document.getElementById("orgParentRow") as HTMLElement;
      if (!campusRow || !parentRow) return;

      // คณะ/สำนัก/กอง (faculty): แสดงวิทยาเขต ซ่อนหน่วยงานแม่
      if (level === "faculty") {
        campusRow.classList.remove("hidden");
        parentRow.classList.add("hidden");
        (document.getElementById("orgParentId") as HTMLSelectElement).value =
          "";
        // Preserve the currently selected campus value instead of clearing it
        const currentCampusId = (document.getElementById("orgCampusId") as HTMLSelectElement).value;
        populateCampusSelect(currentCampusId ? parseInt(currentCampusId) : null);
        // ภาควิชา/หน่วยงานย่อย (department): ซ่อนวิทยาเขต แสดงหน่วยงานแม่
      } else if (level === "department") {
        campusRow.classList.add("hidden");
        (document.getElementById("orgCampusId") as HTMLSelectElement).value =
          "";
        parentRow.classList.remove("hidden");
        // Preserve the currently selected parent organization
        const currentParentId = (document.getElementById("orgParentId") as HTMLSelectElement).value;
        updateParentByLevel(currentParentId ? parseInt(currentParentId) : null, "faculty");
        // วิทยาเขต (campus): ซ่อนวิทยาเขต แสดงหน่วยงานแม่ (มหาวิทยาลัย) - auto-select university
      } else if (level === "campus") {
        campusRow.classList.add("hidden");
        (document.getElementById("orgCampusId") as HTMLSelectElement).value =
          "";
        parentRow.classList.remove("hidden");
        // Find the university and auto-select it
        const univ = allOrgs.find((o) => o.isActive && o.orgLevel === "university");
        updateParentByLevel(univ?.id ?? null, "university");
        // มหาวิทยาลัย: ซ่อนทั้งหน่วยงานแม่และวิทยาเขต
      } else {
        campusRow.classList.add("hidden");
        (document.getElementById("orgCampusId") as HTMLSelectElement).value =
          "";
        parentRow.classList.add("hidden");
        (document.getElementById("orgParentId") as HTMLSelectElement).value =
          "";
      }
    };

    function updateParentByLevel(selectedId?: number | null, filterByLevel?: string): void {
      const sel = document.getElementById("orgParentId") as HTMLSelectElement;
      let filtered = allOrgs.filter((o) => o.isActive);
      if (filterByLevel) {
        filtered = filtered.filter((o) => o.orgLevel === filterByLevel);
      }
      sel.innerHTML =
        '<option value="">-- ไม่มีหน่วยงานแม่ --</option>' +
        filtered
          .map(
            (o) =>
              `<option value="${o.id}" ${o.id === selectedId ? "selected" : ""}>[${getOrgLevelTh(o.orgLevel)}] ${o.nameTh}</option>`,
          )
          .join("");
    }

    function populateCampusSelect(selectedId?: number | null): void {
      const sel = document.getElementById("orgCampusId") as HTMLSelectElement;
      if (!sel) return;
      
      // Collect campuses from multiple sources
      const campusList: { id: number; nameTh: string }[] = [];
      const seenIds = new Set<number>();
      
      // 1. Priority: from allCampuses table (has proper structure)
      console.log("DEBUG: populateCampusSelect - allCampuses:", allCampuses?.length ?? 0, allCampuses?.map((c: any) => ({ id: c.id, nameTh: c.nameTh })));
      if (allCampuses && allCampuses.length > 0) {
        for (const c of allCampuses) {
          if (!seenIds.has(c.id)) {
            campusList.push({ id: c.id, nameTh: c.nameTh });
            seenIds.add(c.id);
          }
        }
      }
      
      // 2. Extract campuses from faculty organizations' campusId field
      // (This is the fallback when campuses are referenced but not created as org-level records)
      const facultiesWithCampus = allOrgs.filter(
        (o) => o.isActive && o.orgLevel === "faculty" && o.campusId
      );
      console.log("DEBUG: Faculty orgs with campusId:", facultiesWithCampus.length, 
        facultiesWithCampus.map((o: any) => ({ id: o.id, campusId: o.campusId, nameTh: o.nameTh })));
      
      for (const fac of facultiesWithCampus) {
        if (!seenIds.has(fac.campusId)) {
          // Try to find campus name from allCampuses first
          const campusFromTable = allCampuses?.find((c) => c.id === fac.campusId);
          if (campusFromTable) {
            console.log("DEBUG: Found campus from table:", fac.campusId, campusFromTable.nameTh);
            campusList.push({ id: fac.campusId, nameTh: campusFromTable.nameTh });
            seenIds.add(fac.campusId);
          }
        }
      }
      
      // 3. Fallback: from campus-level organizations in allOrgs
      const campusOrgs = allOrgs.filter((o) => o.isActive && o.orgLevel === "campus");
      console.log("DEBUG: Campus-level orgs:", campusOrgs.length);
      for (const org of campusOrgs) {
        if (!seenIds.has(org.id)) {
          campusList.push({ id: org.id, nameTh: org.nameTh });
          seenIds.add(org.id);
        }
      }
      
      // 4. Deep fallback: extract unique campus names from faculty "campus" property (if available)
      // This is for cases where campus name is stored but no ID mapping exists yet
      if (campusList.length === 0) {
        const uniqueCampusNames = new Set<string>();
        for (const fac of allOrgs.filter((o) => o.isActive && o.orgLevel === "faculty")) {
          // Some systems might have campus info stored as a property (check if it exists)
          if ((fac as any).campus) {
            uniqueCampusNames.add((fac as any).campus);
          }
        }
        
        // Create virtual IDs for these campus names (use stringified hash)
        let campusCount = (allCampuses?.length ?? 0) + 100; // Offset to avoid conflicts
        for (const campusName of Array.from(uniqueCampusNames).sort()) {
          campusList.push({ id: campusCount++, nameTh: campusName });
        }
      }
      
      // Sort by name
      campusList.sort((a, b) =>
        (a.nameTh || "").localeCompare(b.nameTh || "", "th"),
      );
      
      console.log("DEBUG: Final campus list:", campusList);
      
      // Build options HTML
      let optionsHtml = '<option value="">-- เลือกวิทยาเขต --</option>';
      if (campusList.length > 0) {
        optionsHtml += campusList
          .map(
            (c) =>
              `<option value="${c.id}" ${c.id === selectedId ? "selected" : ""}>${c.nameTh}</option>`,
          )
          .join("");
      } else {
        optionsHtml += '<option value="" disabled style="color: #999;">ไม่พบข้อมูลวิทยาเขต</option>';
      }
      
      sel.innerHTML = optionsHtml;
    }

    // Return the subset of orgs the current role is allowed to see
    function getVisibleOrgs(orgs: any[]): any[] {
      const role = currentRole;
      const affOrg = currentAffiliationOrg;

      if (role === "super_admin") return orgs;

      if (["univ_executive", "univ_officer"].includes(role)) {
        return orgs.filter((o) => o.orgLevel === "university");
      }

      if (["campus_executive", "campus_officer"].includes(role)) {
        const byId = Object.fromEntries(orgs.map((o) => [o.id, o]));
        // Walk up from current org to find campus ancestor
        let cur = byId[affOrg?.id];
        while (cur && cur.orgLevel !== "campus") cur = byId[cur.parentId];
        if (!cur) return [];
        return collectSubtree(orgs, cur.id);
      }

      if (["faculty_executive", "org_admin"].includes(role)) {
        return collectSubtree(orgs, affOrg?.id);
      }

      if (["unit_head", "project_lead", "staff"].includes(role)) {
        return orgs.filter((o) => o.id === affOrg?.id);
      }

      return orgs;
    }

    // Return org with given rootId + all its descendants
    function collectSubtree(orgs: any[], rootId: number): any[] {
      const ids = new Set<number>();
      function collect(id: number) {
        if (!id) return;
        ids.add(id);
        orgs.filter((o) => o.parentId === id).forEach((c) => collect(c.id));
      }
      collect(rootId);
      return orgs.filter((o) => ids.has(o.id));
    }

    // Check if current user has permission to edit/delete the given org
    function canManageOrg(orgId: number): boolean {
      if (currentRole === "super_admin") return true;
      if (!currentAffiliationOrg) return false;
      return collectSubtree(allOrgs, currentAffiliationOrg.id).some(
        (o) => o.id === orgId
      );
    }

    async function loadOrganizations(): Promise<void> {
      const container = document.getElementById("orgsTreeContainer");
      if (!container) return;
      try {
        const res = await (window as any).apiFetch(
          `${API}/api/settings/organizations/all`,
        );
        if (res.status === 403) {
          container.innerHTML = noPermHtml("div");
          const filterRow = document.getElementById("orgFilterRow");
          if (filterRow) filterRow.style.display = "none";
          return;
        }
        const json = await res.json();
        if (!json.success) {
          container.innerHTML = `<div class="flex flex-col items-center gap-2 text-gray-400 py-12"><svg class="w-10 h-10 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg><p class="text-sm">ไม่พบข้อมูล</p></div>`;
          return;
        }
        allOrgs = json.data;
        renderOrgsTable(getVisibleOrgs(allOrgs));
      } catch {
        container.innerHTML = `<div class="flex flex-col items-center gap-2 text-red-400 py-12"><p class="text-sm">โหลดข้อมูลล้มเหลว</p></div>`;
      }
    }

    function buildOrgGuide(
      depth: number,
      parentHasMore: boolean[],
      ancestorLevels: string[],
    ): string {
      // parentHasMore[i] = true  → ancestor at depth i still has siblings after this path
      // ancestorLevels[i]       → orgLevel of ancestor at depth i (for colored lines)
      if (depth === 0) return "";
      const GW = 22;
      const cfg = ORG_LEVEL_CFG as Record<
        string,
        { color: string; bg: string; rowBg: string; label: string }
      >;
      let html = '<div class="flex flex-shrink-0 items-stretch self-stretch">';
      for (let i = 0; i < depth - 1; i++) {
        const col = (cfg[ancestorLevels[i]]?.color || "#9ca3af") + "44";
        if (parentHasMore[i]) {
          html += `<div style="width:${GW}px;display:flex;justify-content:center;align-items:stretch;"><div style="width:2px;background:${col};border-radius:1px;"></div></div>`;
        } else {
          html += `<div style="width:${GW}px;"></div>`;
        }
      }
      const hasMoreSiblings = parentHasMore[depth - 1];
      const col = (cfg[ancestorLevels[depth - 1]]?.color || "#9ca3af") + "44";
      html += `<div style="width:${GW}px;position:relative;min-height:48px;">
        <div style="position:absolute;left:50%;top:0;width:2px;height:50%;background:${col};transform:translateX(-50%);border-radius:1px;"></div>
        ${hasMoreSiblings ? `<div style="position:absolute;left:50%;top:50%;width:2px;height:50%;background:${col};transform:translateX(-50%);border-radius:1px;"></div>` : ""}
        <div style="position:absolute;left:50%;top:50%;width:55%;height:2px;background:${col};transform:translateY(-50%);border-radius:1px;"></div>
      </div>`;
      html += "</div>";
      return html;
    }

    function countDescendants(node: any): number {
      let count = node.children.length;
      for (const c of node.children) count += countDescendants(c);
      return count;
    }

    (window as any).toggleOrgNode = function (id: number): void {
      if (collapsedOrgNodes.has(id)) {
        collapsedOrgNodes.delete(id);
      } else {
        collapsedOrgNodes.add(id);
      }
      renderOrgsTable(allOrgs);
    };

    function renderOrgsTable(orgs: any[]): void {
      const container = document.getElementById("orgsTreeContainer");
      if (!container) return;
      if (!orgs.length) {
        container.innerHTML = `<div class="flex flex-col items-center gap-3 py-12 text-gray-400"><svg class="w-10 h-10 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg><p class="text-sm">ไม่พบข้อมูล</p></div>`;
        return;
      }

      // Build tree from the orgs subset
      const nodeMap: Record<number, any> = {};
      for (const o of orgs) nodeMap[o.id] = { ...o, children: [] };
      const roots: any[] = [];
      for (const o of orgs) {
        if (o.parentId && nodeMap[o.parentId]) {
          nodeMap[o.parentId].children.push(nodeMap[o.id]);
        } else {
          roots.push(nodeMap[o.id]);
        }
      }

      // Sort by level order then code
      function sortNodes(list: any[]) {
        list.sort((a, b) =>
          (a.code ?? "").localeCompare(b.code ?? "", undefined, {
            numeric: true,
            sensitivity: "base",
          }),
        );
        list.forEach((n) => sortNodes(n.children));
      }
      sortNodes(roots);

      // Flatten tree into rows, skipping children of collapsed nodes
      const rows: {
        node: any;
        depth: number;
        parentHasMore: boolean[];
        ancestorLevels: string[];
      }[] = [];
      function flatten(
        node: any,
        depth: number,
        parentHasMore: boolean[],
        ancestorLevels: string[],
      ) {
        rows.push({
          node,
          depth,
          parentHasMore: [...parentHasMore],
          ancestorLevels: [...ancestorLevels],
        });
        if (!collapsedOrgNodes.has(node.id)) {
          for (let i = 0; i < node.children.length; i++) {
            flatten(
              node.children[i],
              depth + 1,
              [...parentHasMore, i < node.children.length - 1],
              [...ancestorLevels, node.orgLevel],
            );
          }
        }
      }
      roots.forEach((r) => flatten(r, 0, [], []));

      // Render
      container.innerHTML = rows
        .map(({ node, depth, parentHasMore, ancestorLevels }) => {
          const cfg = ORG_LEVEL_CFG[node.orgLevel] || ORG_LEVEL_CFG.department;
          const safe = node.nameTh.replace(/'/g, "\\'");
          const guide = buildOrgGuide(depth, parentHasMore, ancestorLevels);
          const hasChildren = node.children.length > 0;
          const isCollapsed = collapsedOrgNodes.has(node.id);
          const descCount = hasChildren ? countDescendants(node) : 0;

          const isUniv = node.orgLevel === "university";
          const isCampus = node.orgLevel === "campus";
          const isFaculty = node.orgLevel === "faculty";

          // Left accent bar — full-height colored strip by level
          const accentW = isUniv ? 4 : isCampus ? 3 : isFaculty ? 3 : 2;
          const accentOp = isUniv
            ? 1
            : isCampus
              ? 0.75
              : isFaculty
                ? 0.55
                : 0.35;
          const accentBar = `<div style="width:${accentW}px;flex-shrink:0;align-self:stretch;background:${cfg.color};opacity:${accentOp};border-radius:0 2px 2px 0;"></div>`;

          // Row height and name weight per level
          const minH = isUniv ? "56px" : isCampus ? "52px" : "44px";
          const nameWt = isUniv
            ? "font-bold text-[0.9rem]"
            : isCampus
              ? "font-semibold text-sm"
              : "font-medium text-sm";
          const rowBorder = `border-bottom:1px solid ${cfg.color}18;`;

          const chevron = hasChildren
            ? `<svg class="w-3 h-3 flex-shrink-0 transition-transform ${isCollapsed ? "" : "rotate-90"}" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color:${cfg.color}88;">
               <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
             </svg>`
            : `<span style="width:12px;flex-shrink:0;display:inline-block;"></span>`;

          const countBadge = hasChildren
            ? `<span class="inline-flex items-center px-1.5 py-0.5 text-xs font-medium rounded-md" style="color:${cfg.color};background:${cfg.bg};border:1px solid ${cfg.color}33;">${descCount}</span>`
            : "";

          const nameArea = hasChildren
            ? `<div class="flex-1 min-w-0 py-2.5 pr-2 cursor-pointer select-none" onclick="toggleOrgNode(${node.id})" title="${isCollapsed ? "แสดงหน่วยงานย่อย" : "ซ่อนหน่วยงานย่อย"}">
              <div class="flex items-center gap-2 flex-wrap">
                ${chevron}
                <span class="${nameWt} text-gray-800 leading-snug hover:text-[#006664] transition-colors">${node.nameTh}</span>
                <code class="font-mono text-xs text-gray-400 bg-gray-100 px-1.5 py-0.5 rounded">${node.code}</code>
                ${countBadge}
              </div>
              ${node.nameEn ? `<p class="text-xs text-gray-400 mt-0.5 ml-[14px]">${node.nameEn}</p>` : ""}
            </div>`
            : `<div class="flex-1 min-w-0 py-2.5 pr-2">
              <div class="flex items-center gap-2 flex-wrap">
                <span style="width:12px;flex-shrink:0;display:inline-block;"></span>
                <span class="${nameWt} text-gray-800 leading-snug">${node.nameTh}</span>
                <code class="font-mono text-xs text-gray-400 bg-gray-100 px-1.5 py-0.5 rounded">${node.code}</code>
              </div>
              ${node.nameEn ? `<p class="text-xs text-gray-400 mt-0.5 ml-[14px]">${node.nameEn}</p>` : ""}
            </div>`;

          return `<div class="flex items-center hover:brightness-[0.97] transition-all" style="min-height:${minH};background:${cfg.rowBg};${rowBorder}">
          ${accentBar}
          ${guide}
          <div class="w-7 h-7 flex items-center justify-center flex-shrink-0 mx-2.5" style="color:${cfg.color}">
            ${
              node.orgLevel === "campus"
                ? `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24">
                  <path fill="currentColor" fill-rule="evenodd" d="M10.75 2h2c1.886 0 2.828 0 3.414.586S16.75 4.114 16.75 6v15.25h5a.75.75 0 0 1 0 1.5h-20a.75.75 0 0 1 0-1.5h5V6c0-1.886 0-2.828.586-3.414S8.864 2 10.75 2M9 12a.75.75 0 0 1 .75-.75h4a.75.75 0 0 1 0 1.5h-4A.75.75 0 0 1 9 12m0 3a.75.75 0 0 1 .75-.75h4a.75.75 0 0 1 0 1.5h-4A.75.75 0 0 1 9 15m2.75 3.25a.75.75 0 0 1 .75.75v2.25H11V19a.75.75 0 0 1 .75-.75M9.25 7a2.75 2.75 0 1 1 5.5 0a2.75 2.75 0 0 1-5.5 0" clip-rule="evenodd"/>
                  <path fill="currentColor" d="M10.75 7a1.25 1.25 0 1 1 2.5 0a1.25 1.25 0 0 1-2.5 0" opacity=".5"/>
                  <path fill="currentColor" d="M20.913 5.889c.337.504.337 1.206.337 2.611v12.75h.5a.75.75 0 0 1 0 1.5h-20a.75.75 0 1 1 0-1.5h.5V8.5c0-1.405 0-2.107.337-2.611a2 2 0 0 1 .552-.552c.441-.295 2.537-.332 3.618-.336q-.005.437-.004.91V7.25H4.25a.75.75 0 1 0 0 1.5h2.503v1.5H4.25a.75.75 0 0 0 0 1.5h2.503v1.5H4.25a.75.75 0 0 0 0 1.5h2.503v6.5h10v-6.5h2.497a.75.75 0 1 0 0-1.5h-2.497v-1.5h2.497a.75.75 0 1 0 0-1.5h-2.497v-1.5h2.497a.75.75 0 0 0 0-1.5h-2.497V5.91q.001-.471-.004-.91c1.081.005 3.17.042 3.612.337a2 2 0 0 1 .552.552" opacity=".5"/>
                </svg>`
                : node.orgLevel === "faculty"
                  ? `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 512 512">
                  <path fill="currentColor" d="M440 464V16H72v448H16v32h480v-32Zm-32 0H272v-64h-32v64H104V48h304Z"/>
                  <path fill="currentColor" d="M160 304h32v32h-32zm80 0h32v32h-32zm80 0h32v32h-32zm-160-96h32v32h-32zm80 0h32v32h-32zm80 0h32v32h-32zm-160-96h32v32h-32zm80 0h32v32h-32zm80 0h32v32h-32z"/>
                </svg>`
                  : node.orgLevel === "department"
                    ? `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 256 256" style="color:#B2BB1E">
                  <path fill="currentColor" d="M176 32v192a16 16 0 0 1-16 16H96a16 16 0 0 1-16-16V32a16 16 0 0 1 16-16h64a16 16 0 0 1 16 16" opacity=".2"/>
                  <path fill="currentColor" d="M140 128a12 12 0 1 1-12-12a12 12 0 0 1 12 12m-12-56a12 12 0 1 0-12-12a12 12 0 0 0 12 12m0 112a12 12 0 1 0 12 12a12 12 0 0 0-12-12"/>
                </svg>`
                    : `<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24">
                  <path fill="currentColor" d="m12 4.05l9.46 7.358a.75.75 0 1 1-.92 1.184l-.79-.614V20a.75.75 0 0 1-1.5 0v-9.189L12 5.951l-6.25 4.86V20a.75.75 0 0 1-1.5 0v-8.022l-.79.614a.75.75 0 0 1-.92-1.184l1.71-1.33V7.5c0-.69.56-1.25 1.25-1.25h1a1.25 1.25 0 0 1 1.242 1.111zM6.25 8.425V7.75h-.5V8.8z"/>
                  <path fill="currentColor" d="M10.5 14.75a.25.25 0 0 0-.25.25v5a.75.75 0 0 1-1.5 0v-5c0-.966.784-1.75 1.75-1.75h3c.966 0 1.75.784 1.75 1.75v5a.75.75 0 0 1-1.5 0v-5a.25.25 0 0 0-.25-.25z" opacity=".5"/>
