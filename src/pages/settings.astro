            }
          </div>
          ${nameArea}
          <div class="flex items-center gap-2 px-3 flex-shrink-0">
            <span class="hidden sm:inline-flex px-2 py-0.5 text-xs font-medium rounded whitespace-nowrap" style="color:${cfg.color};background:${cfg.bg};border:1px solid ${cfg.color}33;">${cfg.label}</span>
            ${statusBadge(node.isActive)}
            <div class="flex gap-1 ml-1">
              <button onclick="editOrg(${node.id})" class="inline-flex items-center gap-1 px-2.5 py-1 text-xs font-medium text-[#006664] bg-[#006664]/10 hover:bg-[#006664]/20 rounded transition-colors">
