    async function loadBudgetGroups(): Promise<void> {
      const container = document.getElementById("groupsTableBody");
      try {
        const res = await (window as any).apiFetch(
          `${API}/api/settings/budget-groups`,
        );
        if (res.status === 403) {
          if (container) container.innerHTML = noPermHtml("div");
          return;
