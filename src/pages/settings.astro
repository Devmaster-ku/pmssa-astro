    async function loadPermissionMatrix() {
      const wrap = document.getElementById("permMatrixWrap");
      if (!wrap) return;
      try {
        const res = await (window as any).apiFetch(
          `${API}/api/settings/permissions/matrix`,
        );
        if (res.status === 403) {
          wrap.innerHTML = noPermHtml("div");
          return;
        }
        const json = await res.json();
        if (!json.success) throw new Error(json.message);

        // สร้าง state
        permMatrix = {};
        for (const mod of json.modules) {
          for (const perm of mod.permissions) {
            permMatrix[perm.code] = { ...perm.roles };
          }
        }
        permMatrixOrig = JSON.parse(JSON.stringify(permMatrix));

        renderPermissionMatrix(json.roles, json.modules);
        const saveBtn = document.getElementById("permSaveBtn") as HTMLElement | null;
        if (saveBtn) saveBtn.style.display = "inline-flex";
      } catch (e) {
        wrap.innerHTML = `<div class="text-center py-10 text-red-400 text-sm">โหลดข้อมูลล้มเหลว</div>`;
      }
    }

    function renderPermissionMatrix(roles: string[], modules: any[]): void {
      const wrap = document.getElementById("permMatrixWrap");
      if (!wrap) return;

      const colW = "min-w-[80px] w-20";
      const headerCols = roles
        .map(
          (role) => `
        <th class="${colW} text-center px-1 py-3 text-xs font-semibold text-gray-600 border-l border-gray-200 leading-tight whitespace-pre-line">${ROLE_LABELS[role] || role}</th>
      `,
        )
        .join("");

      let bodyRows = "";
      for (const mod of modules) {
        // Module header row
        bodyRows += `<tr class="bg-[#006664]/8">
          <td colspan="${roles.length + 1}" class="px-4 py-2 text-xs font-bold text-[#006664] uppercase tracking-widest" style="background:rgba(0,102,100,0.06)">
            ${mod.moduleTh}
          </td>
        </tr>`;

        for (const perm of mod.permissions) {
          const checkboxes = roles
            .map((role) => {
              const checked = permMatrix[perm.code]?.[role] ? "checked" : "";
              return `<td class="${colW} text-center px-1 py-2.5 border-l border-gray-100">
              <input type="checkbox" data-perm="${perm.code}" data-role="${role}"
                class="perm-checkbox w-4 h-4 accent-[#006664] cursor-pointer rounded"
                ${checked} onchange="onPermCheckboxChange(this)" />
            </td>`;
            })
            .join("");

          bodyRows += `<tr class="hover:bg-gray-50/70 border-t border-gray-100">
            <td class="px-4 py-2.5 text-sm text-gray-700 min-w-[180px]">${perm.nameTh}</td>
            ${checkboxes}
          </tr>`;
        }
      }

      wrap.innerHTML = `
        <table class="w-full text-sm border-collapse">
          <thead class="bg-gray-50 border-b-2 border-gray-200 sticky top-0 z-10">
            <tr>
              <th class="text-left px-4 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wider min-w-[180px]">สิทธิ์</th>
              ${headerCols}
            </tr>
          </thead>
          <tbody>${bodyRows}</tbody>
        </table>`;
    }

    (window as any).onPermCheckboxChange = function onPermCheckboxChange(
      el: HTMLInputElement,
    ) {
      const code = el.dataset.perm!;
      const role = el.dataset.role!;
      if (!permMatrix[code]) permMatrix[code] = {};
      permMatrix[code][role] = el.checked;
      document.getElementById("permUnsavedBadge")!.classList.remove("hidden");
    };

    (window as any).savePermissionMatrix =
      async function savePermissionMatrix() {
        const btn = document.getElementById("permSaveBtn") as HTMLButtonElement;
        btn.disabled = true;
        btn.textContent = "กำลังบันทึก...";

        const matrix: {
          role: string;
          permissionCode: string;
          granted: boolean;
        }[] = [];
        for (const [code, roles] of Object.entries(permMatrix)) {
          for (const [role, granted] of Object.entries(
            roles as Record<string, boolean>,
          )) {
            matrix.push({ role, permissionCode: code, granted });
          }
        }

        try {
          const res = await (window as any).apiFetch(
            `${API}/api/settings/permissions/matrix`,
            {
              method: "PUT",
              body: JSON.stringify({ matrix }),
            },
          );
          const json = await res.json();
          if (json.success) {
            permMatrixOrig = JSON.parse(JSON.stringify(permMatrix));
            document
              .getElementById("permUnsavedBadge")!
              .classList.add("hidden");
            (window as any).showToast("บันทึกสิทธิ์สำเร็จ", "success");
          } else {
            (window as any).showToast(
              json.message || "เกิดข้อผิดพลาด",
              "error",
            );
          }
        } catch {
          (window as any).showToast(
            "ไม่สามารถเชื่อมต่อเซิร์ฟเวอร์ได้",
            "error",
          );
        } finally {
          btn.disabled = false;
          btn.innerHTML = `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> บันทึกสิทธิ์`;
        }
      };

