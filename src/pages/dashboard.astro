  <!-- ═══════════════════════════════════════════════
       FOOTER TIMESTAMP
  ════════════════════════════════════════════════ -->
  <div class="flex items-center justify-center gap-2 text-xs text-gray-400 pb-4">
    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
    </svg>
    อัปเดตล่าสุด: <span class="font-medium" id="footerTimestamp">—</span>
  </div>

  <script>
    const API = import.meta.env.PUBLIC_API_URL;
    document.addEventListener('DOMContentLoaded', () => {
      // แสดงชื่อจาก localStorage ก่อน (fast initial render)
      const userStr = localStorage.getItem('ku_user');
      if (userStr) {
        try {
          const user = JSON.parse(userStr);
          const welcomeEl = document.getElementById('welcomeText');
          if (welcomeEl) welcomeEl.textContent = `ยินดีต้อนรับ, ${user.nameTh || user.nameEn || user.username}`;
        } catch (e) { /* ignore */ }
      }

      // Fetch /api/auth/me พร้อม auto-refresh เมื่อ token หมดอายุ
      async function fetchMe() {
        let token = localStorage.getItem('ku_access_token');
        if (!token) return null;

        let res = await fetch(`${API}/api/auth/me`, {
          headers: { Authorization: `Bearer ${token}` },
        });

        // ถ้า 401 → ลอง refresh token
        if (res.status === 401) {
          const refreshToken = localStorage.getItem('ku_refresh_token');
          if (!refreshToken) { window.location.replace('/login'); return null; }

          const refreshRes = await fetch(`${API}/api/auth/refresh`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ refreshToken }),
          });
          const refreshData = await refreshRes.json();

          if (!refreshData.success) { window.location.replace('/login'); return null; }

          // บันทึก token ใหม่
          localStorage.setItem('ku_access_token', refreshData.accessToken);
          localStorage.setItem('ku_refresh_token', refreshData.refreshToken);
          if (refreshData.user) localStorage.setItem('ku_user', JSON.stringify(refreshData.user));

          // retry /me ด้วย token ใหม่
          res = await fetch(`${API}/api/auth/me`, {
            headers: { Authorization: `Bearer ${refreshData.accessToken}` },
          });
        }

        const data = await res.json();
        return data.success ? data : null;
      }

      fetchMe().then((data) => {
        if (!data) return;

        const welcomeEl = document.getElementById('welcomeText');
        if (welcomeEl) {
          const u = data.user;
          welcomeEl.textContent = `ยินดีต้อนรับ, ${u.nameTh || u.nameEn || u.username}`;
        }

        const facultyEl = document.getElementById('facultyInfo');
        if (facultyEl) {
          const org = data.activeAffiliation?.organization;
          // ถ้าสังกัด department → ใช้ parent (faculty) เป็นหน่วยงานหลัก
          const mainOrg = (org?.orgLevel === 'department' && org?.parent) ? org.parent : org;
          const orgName = mainOrg?.nameTh;
          facultyEl.textContent = orgName ? `สังกัดหน่วยงานหลัก: ${orgName}` : '';
        }
      }).catch(() => { /* ปล่อยให้แสดงค่าจาก localStorage */ });

      // Date/time strings
      const now = new Date();
      const dateStr = now.toLocaleDateString('th-TH', {
        day: '2-digit', month: '2-digit', year: 'numeric',
        hour: '2-digit', minute: '2-digit'
      });
      const timestampStr = now.toLocaleDateString('th-TH', {
        day: '2-digit', month: '2-digit', year: 'numeric',
        hour: '2-digit', minute: '2-digit', second: '2-digit'
      });

      const dateTimeEl = document.getElementById('currentDateTime');
      if (dateTimeEl) dateTimeEl.textContent = dateStr + ' น.';

      const lastLoginEl = document.getElementById('lastLogin');
      if (lastLoginEl) lastLoginEl.textContent = dateStr;

      const lastLoginMobileEl = document.getElementById('lastLoginMobile');
      if (lastLoginMobileEl) lastLoginMobileEl.textContent = dateStr;

      const footerEl = document.getElementById('footerTimestamp');
      if (footerEl) footerEl.textContent = timestampStr + ' น.';

      document.querySelectorAll('.chart-update-time').forEach(el => {
        el.textContent = now.toLocaleTimeString('th-TH', { hour: '2-digit', minute: '2-digit' }) + ' น.';
      });

      // โหลดประกาศสำคัญ
      loadDashboardAnnouncements();
    });

    async function loadDashboardAnnouncements() {
      const loading = document.getElementById('dashAnnLoading');
      const empty = document.getElementById('dashAnnEmpty');
      const list = document.getElementById('dashAnnList');
      if (!loading || !empty || !list) return;

      try {
        const token = localStorage.getItem('ku_access_token');
        const res = await fetch(`${API}/api/maintenance/announcements`, {
          headers: { Authorization: `Bearer ${token}` },
        });
        const data = await res.json();

        loading.classList.add('hidden');

        if (!data.success || !data.data?.length) {
          empty.classList.remove('hidden');
          return;
        }

        const typeConfig: Record<string, { dot: string; badge: string }> = {
          info:    { dot: 'bg-blue-500',  badge: 'bg-blue-50 text-blue-700 border-blue-200' },
          warning: { dot: 'bg-amber-500', badge: 'bg-amber-50 text-amber-700 border-amber-200' },
          success: { dot: 'bg-green-500', badge: 'bg-green-50 text-green-700 border-green-200' },
          danger:  { dot: 'bg-red-500',   badge: 'bg-red-50 text-red-700 border-red-200' },
        };

        list.innerHTML = data.data.slice(0, 5).map((ann: any) => {
          const cfg = typeConfig[ann.type] ?? typeConfig.info;
          const date = new Date(ann.createdAt).toLocaleDateString('th-TH', { day: 'numeric', month: 'short', year: 'numeric' });
          return `
            <li class="px-4 sm:px-6 py-3 flex items-start gap-3">
              <div class="mt-1.5 w-2 h-2 rounded-full flex-shrink-0 ${cfg.dot}"></div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-[#0a1f3d] line-clamp-1">${ann.title}</p>
                <p class="text-xs text-gray-500 line-clamp-2 mt-0.5">${ann.content}</p>
                <p class="text-xs text-gray-400 mt-1">${date}</p>
              </div>
            </li>
          `;
        }).join('');

        list.classList.remove('hidden');
      } catch {
        loading?.classList.add('hidden');
        empty?.classList.remove('hidden');
      }
    }
  </script>

