---
import AuthLayout from '../layouts/AuthenticatedLayout.astro';
---

<AuthLayout title="แผงควบคุม">

  <!-- ═══════════════════════════════════════════════
       HERO BANNER — Welcome & KPIs
  ════════════════════════════════════════════════ -->
  <div class="relative rounded-sm overflow-hidden mb-6 shadow-lg"
       style="background: linear-gradient(135deg, #0c2957 0%, #0a4068 45%, #006664 100%);">
    <!-- KU lime top accent bar -->
    <div class="absolute top-0 left-0 right-0 h-1.5" style="background: linear-gradient(90deg, #006664, #d4de3a, #b2bb1e);"></div>
    <!-- Decorative glows -->
    <div class="absolute -right-20 -top-20 w-80 h-80 rounded-full pointer-events-none"
         style="background: radial-gradient(circle, rgba(178,187,30,0.12) 0%, transparent 65%);"></div>
    <div class="absolute left-1/3 -bottom-10 w-56 h-56 rounded-full pointer-events-none"
         style="background: radial-gradient(circle, rgba(255,255,255,0.04) 0%, transparent 70%);"></div>
    <!-- Diagonal stripe texture -->
    <div class="absolute inset-0 pointer-events-none opacity-[0.03]"
         style="background-image: repeating-linear-gradient(45deg, #ffffff 0, #ffffff 1px, transparent 0, transparent 12px);"></div>

    <div class="relative z-10 p-5 sm:p-5">
      <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-5">

        <!-- ── LEFT: Identity Block ── -->
        <div class="flex items-start gap-4 min-w-0">
          <!-- KU Logo box -->
          <div class="mt-3 w-16 h-16 sm:w-20 sm:h-20 bg-white rounded-xl flex items-center justify-center shrink-0 shadow-md p-2">
            <svg xmlns="http://www.w3.org/2000/svg" class=" w-24 h-24" viewBox="0 0 24 24">
              <path fill="currentColor" d="M15.71 12.71a6 6 0 1 0-7.42 0a10 10 0 0 0-6.22 8.18a1 1 0 0 0 2 .22a8 8 0 0 1 15.9 0a1 1 0 0 0 1 .89h.11a1 1 0 0 0 .88-1.1a10 10 0 0 0-6.25-8.19M12 12a4 4 0 1 1 4-4a4 4 0 0 1-4 4"/>
            </svg>
          </div>

          <div class="min-w-0">
            <!-- System label -->
            <p class="text-[#b2bb1e] text-lg font-semibold tracking-widest uppercase mb-1">
              KU · Project Management System
            </p>
            <!-- Welcome -->
            <h2 class="text-white text-base sm:text-lg font-bold leading-tight" id="welcomeText">
              ยินดีต้อนรับ
            </h2>
            <p class="text-white/80 text-sm truncate mt-0.5" id="facultyInfo">สังกัดหน่วยงาน: —</p>

            <!-- Status row -->
            <div class="flex flex-wrap items-center gap-x-5 gap-y-1.5 mt-3">
              <span class="flex items-center gap-1.5 text-xs font-medium text-white/90">
                <span class="w-2 h-2 rounded-full animate-pulse" style="background-color: #b2bb1e;"></span>
                ระบบพร้อมใช้งาน
              </span>
              <span class="flex items-center gap-1.5 text-xs text-white/50">
                <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
                ผู้ใช้ออนไลน์: <span class="text-white/80 ml-0.5" id="onlineCount">0</span>
              </span>
              <span class="flex items-center gap-1.5 text-xs text-white/50">
                <svg class="w-3.5 h-3.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                เข้าสู่ระบบล่าสุด: <span class="text-white/80 ml-0.5" id="lastLogin">—</span>
              </span>
            </div>
          </div>
        </div>

        <!-- ── RIGHT: KPI Stat Cards ── -->
        <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-2 xl:grid-cols-4 gap-3 lg:min-w-110 xl:min-w-150">

          <!-- โครงการทั้งหมด -->
          <div class="relative bg-gradient-to-br from-slate-50 to-slate-100 border border-slate-200/60 rounded-xs shadow-md hover:shadow-lg transition-all duration-300 overflow-hidden group">
            <!-- Status Indicator -->
            <div class="absolute top-0 left-0 right-0 h-0.5 bg-gradient-to-r from-slate-700 to-slate-900"></div>
            <!-- Content -->
            <div class="px-3 pt-3 pb-2.5">
              <div class="flex items-center justify-between mb-1">
                <div class="w-8 h-8 rounded-lg flex items-center justify-center shadow-sm bg-gradient-to-br from-slate-600 to-slate-800 border border-slate-700/20">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white" viewBox="0 0 24 24">
                    <g fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.5"><path stroke-linejoin="round" d="M11.007 21H9.605c-3.585 0-5.377 0-6.491-1.135S2 16.903 2 13.25s0-5.48 1.114-6.615S6.02 5.5 9.605 5.5h3.803c3.585 0 5.378 0 6.492 1.135c.857.873 1.054 2.156 1.1 4.365"/><path d="M17.5 22a4.5 4.5 0 1 0 0-9a4.5 4.5 0 0 0 0 9Z"/><path stroke-linejoin="round" d="m19.5 18l-.586.554c-.667.63-1 .946-1.414.946m-2-1.5l.586.554c.667.63 1 .946 1.414.946m0 0v-4M16 5.5l-.1-.31c-.494-1.54-.742-2.31-1.331-2.75C13.979 2 13.197 2 11.632 2h-.264c-1.565 0-2.348 0-2.937.44c-.59.44-.837 1.21-1.332 2.75L7 5.5"/></g>
                  </svg>
                </div>
                <div class="text-[12px] font-semibold text-slate-600 uppercase tracking-wider">ทั้งหมด</div>
              </div>
              <div class="text-2xl font-bold tracking-tight text-slate-900 mb-1" id="statTotal">0</div>
              <div class="text-[12px] font-semibold text-slate-600 uppercase tracking-wider">โครงการทั้งหมด</div>
            </div>
          </div>

          <!-- รออนุมัติ -->
          <div class="relative bg-gradient-to-br from-amber-50 to-orange-50 border border-amber-200/60 rounded-xs shadow-md hover:shadow-lg transition-all duration-300 overflow-hidden group">
            <!-- Status Indicator -->
            <div class="absolute top-0 left-0 right-0 h-0.5 bg-gradient-to-r from-amber-500 to-orange-600"></div>
            <!-- Content -->
            <div class="px-3 pt-3 pb-2.5">
              <div class="flex items-center justify-between mb-1">
                <div class="w-8 h-8 rounded-lg flex items-center justify-center shadow-sm bg-gradient-to-br from-amber-500 to-orange-600 border border-amber-600/20">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-white" viewBox="0 0 48 48">
                    <path fill="currentColor" d="M21.616 3.366a1.25 1.25 0 0 1 1.768 0l5.25 5.25a1.25 1.25 0 0 1 0 1.768l-5.25 5.25a1.25 1.25 0 0 1-1.768-1.768l3.337-3.337q-.473-.03-.953-.029c-8.56 0-15.5 6.94-15.5 15.5S15.44 41.5 24 41.5c8.14 0 14.814-6.274 15.45-14.25c.055-.688.61-1.25 1.3-1.25s1.255.561 1.207 1.25C41.315 36.608 33.521 44 24 44c-9.941 0-18-8.059-18-18S14.059 8 24 8q.245 0 .489.007l-2.873-2.873a1.25 1.25 0 0 1 0-1.768m11.268 18.768a1.25 1.25 0 0 0-1.768-1.768L22.5 28.982l-3.366-3.366a1.25 1.25 0 0 0-1.768 1.768l4.25 4.25a1.25 1.25 0 0 0 1.768 0z"/>
                  </svg>
                </div>
                <div class="text-[12px] font-semibold text-amber-600 uppercase tracking-wider">รอดำเนินการ</div>
              </div>
              <div class="text-2xl font-bold tracking-tight text-amber-900 mb-1" id="statPending">0</div>
              <div class="text-[12px] font-semibold text-amber-600 uppercase tracking-wider">รออนุมัติ</div>
            </div>
          </div>

          <!-- อนุมัติแล้ว -->
          <div class="relative bg-gradient-to-br from-emerald-50 to-green-50 border border-emerald-200/60 rounded-xs shadow-md hover:shadow-lg transition-all duration-300 overflow-hidden group">
            <!-- Status Indicator -->
            <div class="absolute top-0 left-0 right-0 h-0.5 bg-gradient-to-r from-emerald-500 to-green-600"></div>
            <!-- Content -->
            <div class="px-3 pt-3 pb-2.5">
              <div class="flex items-center justify-between mb-1">
                <div class="w-8 h-8 rounded-lg flex items-center justify-center shadow-sm bg-gradient-to-br from-emerald-500 to-green-600 border border-emerald-600/20">
                  <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                </div>
                <div class="text-[12px] font-semibold text-emerald-600 uppercase tracking-wider">สำเร็จ</div>
              </div>
              <div class="text-2xl font-bold tracking-tight text-emerald-900 mb-1" id="statApproved">0</div>
              <div class="text-[12px] font-semibold text-emerald-600 uppercase tracking-wider">อนุมัติแล้ว</div>
            </div>
          </div>

          <!-- กำลังดำเนินการ -->
          <div class="relative bg-gradient-to-br from-blue-50 to-indigo-50 border border-blue-200/60 rounded-xs shadow-md hover:shadow-lg transition-all duration-300 overflow-hidden group">
            <!-- Status Indicator -->
            <div class="absolute top-0 left-0 right-0 h-0.5 bg-gradient-to-r from-blue-500 to-indigo-600"></div>
            <!-- Content -->
            <div class="px-3 pt-3 pb-2.5">
              <div class="flex items-center justify-between mb-1">
                <div class="w-8 h-8 rounded-lg flex items-center justify-center shadow-sm bg-gradient-to-br from-blue-500 to-indigo-600 border border-blue-600/20">
                  <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                  </svg>
                </div>
                <div class="text-[12px] font-semibold text-blue-600 uppercase tracking-wider">ดำเนินการ</div>
              </div>
              <div class="text-2xl font-bold tracking-tight text-blue-900 mb-1" id="statInProgress">0</div>
              <div class="text-[12px] font-semibold text-blue-600 uppercase tracking-wider">กำลังดำเนินการ</div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════
       TOOLBAR — Date / Filter / Actions
  ════════════════════════════════════════════════ -->
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm px-4 sm:px-6 py-3 mb-5 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
    <!-- Left: Breadcrumb + DateTime -->
    <div>
      <div class="flex items-center gap-2 text-xs text-gray-600 mb-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24">
          <path fill="currentColor" d="M20.913 5.889c.337.504.337 1.206.337 2.611v12.75h.5a.75.75 0 0 1 0 1.5h-20a.75.75 0 1 1 0-1.5h.5V8.5c0-1.405 0-2.107.337-2.611a2 2 0 0 1 .552-.552c.441-.295 2.537-.332 3.618-.336q-.005.437-.004.91V7.25H4.25a.75.75 0 1 0 0 1.5h2.503v1.5H4.25a.75.75 0 0 0 0 1.5h2.503v1.5H4.25a.75.75 0 0 0 0 1.5h2.503v6.5h10v-6.5h2.497a.75.75 0 1 0 0-1.5h-2.497v-1.5h2.497a.75.75 0 1 0 0-1.5h-2.497v-1.5h2.497a.75.75 0 0 0 0-1.5h-2.497V5.91q.001-.471-.004-.91c1.081.005 3.17.042 3.612.337a2 2 0 0 1 .552.552" opacity=".5"/><path fill="currentColor" fill-rule="evenodd" d="M10.75 2h2c1.886 0 2.828 0 3.414.586S16.75 4.114 16.75 6v15.25h5a.75.75 0 0 1 0 1.5h-20a.75.75 0 0 1 0-1.5h5V6c0-1.886 0-2.828.586-3.414S8.864 2 10.75 2m1 16.25a.75.75 0 0 1 .75.75v2.25H11V19a.75.75 0 0 1 .75-.75m-2-4.25a.75.75 0 0 0 0 1.5h4a.75.75 0 0 0 0-1.5zM9 11.75a.75.75 0 0 1 .75-.75h4a.75.75 0 0 1 0 1.5h-4a.75.75 0 0 1-.75-.75m.75-3.25a.75.75 0 0 0 0 1.5h4a.75.75 0 0 0 0-1.5zM9 6.25a.75.75 0 0 1 .75-.75h4a.75.75 0 0 1 0 1.5h-4A.75.75 0 0 1 9 6.25" clip-rule="evenodd"/>
        </svg>
        <span class=" font-bold text-[#b2bb1e]">หน้าแรก</span>
        <span class="text-gray-300">›</span>
        <span class="text-gray-600 font-medium">แผงควบคุม</span>
      </div>
      <p class="text-xs text-gray-400">ข้อมูล ณ วันที่ <span class="text-gray-600 font-medium" id="currentDateTime">—</span></p>
    </div>

    <!-- Right: Controls -->
    <div class="flex flex-wrap items-center gap-2 sm:gap-3">
      <div class="flex items-center gap-2">
        <span class="text-xs text-gray-500 hidden sm:inline whitespace-nowrap">ช่วงเวลา:</span>
        <select class="border border-gray-300 rounded-lg px-3 py-1.5 text-xs text-gray-700 bg-white focus:outline-none focus:ring-2 focus:ring-[#0f2d5e]/30 focus:border-[#0f2d5e]">
          <option>30 วันล่าสุด</option>
          <option>7 วันล่าสุด</option>
          <option>90 วันล่าสุด</option>
          <option>ทั้งหมด</option>
        </select>
      </div>
      <label class="flex items-center gap-1.5 text-xs text-gray-600 cursor-pointer select-none">
        <input type="checkbox" class="rounded border-gray-300 text-[#0f2d5e]">
        โครงการของฉัน
      </label>
      <button class="flex items-center gap-1.5 px-3 py-1.5 border border-gray-300 text-gray-600 rounded-lg text-xs hover:border-[#0f2d5e] hover:text-[#0f2d5e] transition-colors" id="refreshBtn">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
        </svg>
        รีเฟรช
      </button>
      <button class="flex items-center gap-1.5 px-4 py-1.5 bg-[#0f2d5e] text-white rounded-lg text-xs font-medium hover:bg-[#0a1f3d] transition-colors shadow-sm">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        <span class="hidden sm:inline">สร้างโครงการใหม่</span>
        <span class="sm:hidden">สร้าง</span>
      </button>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════
       SECTION TITLE: ภาพรวมระบบ
  ════════════════════════════════════════════════ -->
  <div class="flex items-center gap-3 mb-4">
    <div class="w-1 h-6 bg-[#0f2d5e] rounded-full"></div>
    <h2 class="text-base font-bold text-[#0a1f3d] tracking-wide">ภาพรวมระบบ</h2>
    <div class="flex-1 border-t border-gray-200"></div>
  </div>

  <!-- ═══════════════════════════════════════════════
       MANAGEMENT CARDS — Row 1 (4 columns)
  ════════════════════════════════════════════════ -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4 mb-3 sm:mb-4">

    <!-- จัดการโครงการ -->
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm hover:shadow-md hover:border-[#0f2d5e]/30 transition-all cursor-pointer group">
      <div class="p-4 sm:p-5">
        <div class="flex items-start justify-between mb-4">
          <div class="w-11 h-11 bg-amber-50 rounded-lg flex items-center justify-center border border-amber-200 group-hover:bg-amber-100 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-amber-600" viewBox="0 0 24 24">
              <g fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.5"><path stroke-linejoin="round" d="M11.007 21H9.605c-3.585 0-5.377 0-6.491-1.135S2 16.903 2 13.25s0-5.48 1.114-6.615S6.02 5.5 9.605 5.5h3.803c3.585 0 5.378 0 6.492 1.135c.857.873 1.054 2.156 1.1 4.365"/><path d="M17.5 22a4.5 4.5 0 1 0 0-9a4.5 4.5 0 0 0 0 9Z"/><path stroke-linejoin="round" d="m19.5 18l-.586.554c-.667.63-1 .946-1.414.946m-2-1.5l.586.554c.667.63 1 .946 1.414.946m0 0v-4M16 5.5l-.1-.31c-.494-1.54-.742-2.31-1.331-2.75C13.979 2 13.197 2 11.632 2h-.264c-1.565 0-2.348 0-2.937.44c-.59.44-.837 1.21-1.332 2.75L7 5.5"/></g>
            </svg>
          </div>
          <span class="text-2xl sm:text-3xl font-bold text-[#0a1f3d]" id="cardProjectCount">0</span>
        </div>
        <h3 class="text-sm sm:text-base font-semibold text-[#0a1f3d] mb-0.5 group-hover:text-[#0f2d5e]">จัดการโครงการ</h3>
        <p class="text-xs text-gray-500">ดูและจัดการโครงการทั้งหมดในระบบ</p>
      </div>
      <div class="border-t border-gray-100 px-4 sm:px-5 py-2 flex items-center justify-between">
        <span class="text-xs text-[#0f2d5e] font-medium">เข้าสู่โมดูล</span>
        <svg class="w-4 h-4 text-gray-400 group-hover:text-[#0f2d5e] group-hover:translate-x-0.5 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </div>
    </div>

    <!-- การอนุมัติ -->
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm hover:shadow-md hover:border-[#0f2d5e]/30 transition-all cursor-pointer group">
      <div class="p-4 sm:p-5">
        <div class="flex items-start justify-between mb-4">
          <div class="w-11 h-11 bg-emerald-50 rounded-lg flex items-center justify-center border border-emerald-200 group-hover:bg-emerald-100 transition-colors">
            <svg class="w-7 h-7 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <span class="text-2xl sm:text-3xl font-bold text-[#0a1f3d]" id="cardApprovalCount">0</span>
        </div>
        <h3 class="text-sm sm:text-base font-semibold text-[#0a1f3d] mb-0.5 group-hover:text-[#0f2d5e]">การอนุมัติโครงการ</h3>
        <p class="text-xs text-gray-500">อนุมัติหรือปฏิเสธโครงการในระบบ</p>
      </div>
      <div class="border-t border-gray-100 px-4 sm:px-5 py-2 flex items-center justify-between">
        <span class="text-xs text-[#0f2d5e] font-medium">เข้าสู่โมดูล</span>
        <svg class="w-4 h-4 text-gray-400 group-hover:text-[#0f2d5e] group-hover:translate-x-0.5 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </div>
    </div>

    <!-- แจ้งเตือนสิ้นสุดโครงการ -->
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm hover:shadow-md hover:border-[#0f2d5e]/30 transition-all cursor-pointer group">
      <div class="p-4 sm:p-5">
        <div class="flex items-start justify-between mb-4">
          <div class="w-11 h-11 bg-red-50 rounded-lg flex items-center justify-center border border-red-200 group-hover:bg-red-100 transition-colors">
            <svg class="w-7 h-7 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
            </svg>
          </div>
          <span class="text-2xl sm:text-3xl font-bold text-[#0a1f3d]" id="cardAlertCount">0</span>
        </div>
        <h3 class="text-sm sm:text-base font-semibold text-[#0a1f3d] mb-0.5 group-hover:text-[#0f2d5e]">แจ้งเตือนสิ้นสุดโครงการ</h3>
        <p class="text-xs text-gray-500">โครงการที่ใกล้ถึงกำหนดส่งหรือสิ้นสุด</p>
      </div>
      <div class="border-t border-gray-100 px-4 sm:px-5 py-2 flex items-center justify-between">
        <span class="text-xs text-[#0f2d5e] font-medium">เข้าสู่โมดูล</span>
