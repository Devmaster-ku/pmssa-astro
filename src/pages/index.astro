    <script>
      // ── Auth redirect ──
      (function () {
        if (localStorage.getItem('ku_access_token')) {
          window.location.replace('/dashboard');
        }
      })();

      // ── Slideshow ──
      const totalSlides = 8;
      let current = 1;

      function goSlide(n) {
        for (let i = 1; i <= totalSlides; i++) {
          const slide = document.getElementById(`bgSlide${i}`);
          const dot = document.getElementById(`dot${i}`);
          if (i === n) {
            slide.classList.add('active');
            dot.classList.add('active');
          } else {
            slide.classList.remove('active');
            dot.classList.remove('active');
          }
        }
        current = n;
      }

      setInterval(() => {
        let next = current + 1;
        if (next > totalSlides) next = 1;
        goSlide(next);
      }, 60000); // สลับทุก 1 นาที

      // ── KU ALL LOGIN placeholder ──
      document.getElementById('btnKuAll').addEventListener('click', (e) => {
        e.preventDefault();
        alert('KU ALL LOGIN: กำลังพัฒนา — ติดต่อผู้ดูแลระบบ');
      });
    </script>
