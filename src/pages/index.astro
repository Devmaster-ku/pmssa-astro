---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="th">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/images/ku_favicon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="PMS KASETSART ระบบบริหารโครงการ เพื่อขับเคลื่อนยุทธศาสตร์ มหาวิทยาลัยเกษตรศาสตร์" />
    <title>PMS KASETSART — หน้าหลัก</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --teal:       #006664;
        --teal-dark:  #004847;
        --teal-light: #e0f2f1;
        --gold:       #C9A84C;
        --gold-dark:  #9a7a2e;
        --gold-light: #fdf3d7;
        --gree:      #b2bb1e;
        --gree-dark: #214d4a;
        --gree-light: #e0f2f1;
        --white:      #ffffff;
        --text:       #1a2e2e;
        --text-muted: rgba(255,255,255,0.7);
      }

      html, body {
        height: 100%;
        font-family: 'Sarabun', 'Inter', system-ui, sans-serif;
        overflow: hidden;
        color: var(--white);
      }

      /* ──────────────────────────────
         BACKGROUND SLIDESHOW
      ────────────────────────────── */
      .bg-wrap {
        position: fixed; inset: 0; z-index: 0;
      }
      .bg-slide {
        position: absolute; inset: 0;
        background-size: cover;
        background-position: center;
        opacity: 0;
        transform: scale(1.05);
        transition: opacity 1.8s ease, transform 10s ease;
      }
      .bg-slide.active { opacity: 1; transform: scale(1); }
      .bg-slide-1 { background-image: url('/images/ku_city.jpg'); }
      .bg-slide-2 { background-image: url('/images/ku_city2.jpg'); }
      .bg-slide-3 { background-image: url('/images/ku_city3.jpg'); }
      .bg-slide-4 { background-image: url('/images/ku_city4.jpg'); }
      .bg-slide-5 { background-image: url('/images/ku_city5.jpg'); }
      .bg-slide-6 { background-image: url('/images/ku_city6.jpg'); }
      .bg-slide-7 { background-image: url('/images/ku_city7.jpg'); }
      .bg-slide-8 { background-image: url('/images/ku_city8.jpg'); }

      /* Gradient overlay — lighter in hero, translucent */
      .bg-overlay {
        position: fixed; inset: 0; z-index: 1;
        background:
          linear-gradient(
            to bottom,
            rgba(0,40,38,0.50) 0%,
            rgba(0,30,28,0.35) 40%,
            rgba(0,40,38,0.80) 85%,
            rgba(0,30,28,0.95) 100%
          );
      }

      /* Gold top stripe */
      .gold-bar {
        position: fixed; top: 0; left: 0; right: 0;
        height: 4px; z-index: 100;
        background: linear-gradient(90deg, var(--teal), var(--gold), var(--teal));
      }

      /* ──────────────────────────────
         NAVBAR
      ────────────────────────────── */
      .navbar {
        position: fixed; top: 4px; left: 0; right: 0;
        z-index: 50;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 60px;
        background: rgba(0,30,28,0.3);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(255,255,255,0.08);
      }
      .nav-brand {
        display: flex;
        align-items: center;
        gap: 14px;
        text-decoration: none;
        color: inherit;
      }
      .nav-logo {
        width: 42px; height: 42px;
        border-radius: 50%;
        background: linear-gradient(145deg, var(--teal-dark), var(--teal));
        display: grid; place-items: center;
        font-size: 22px; font-weight: 900; color: #fff;
        letter-spacing: -1px;
        box-shadow: 0 0 0 3px rgba(201,168,76,0.35);
        flex-shrink: 0;
        position: relative; /* allow pseudo-element */
        padding-bottom: 10px;
      }
      .nav-logo::after {
        content: '';
        position: absolute;
        left: 8px;
        right: 8px;
        bottom: 10px;
        height: 3px;
        background: #b2bb1e; /* underline color matching text */
        border-radius: 1px;
      }
      .nav-brand-text { line-height: 1.2; }
      .nav-brand-name {
        font-size: 16px; font-weight: 800;
        letter-spacing: 0.2px; color: #fff;
      }
      .nav-brand-sub {
        font-size: 14px; color: rgba(255,255,255,0.85);
        font-weight: 400;
      }
      .nav-links {
        display: flex; align-items: center; gap: 8px;
      }
      .nav-link {
        padding: 8px 18px;
        border-radius: 8px;
        font-size: 14px; font-weight: 500;
        color: rgba(255,255,255,0.8);
        text-decoration: none;
        transition: background 0.2s, color 0.2s;
        border: 1px solid transparent;
      }
      .nav-link:hover {
        background: rgba(255,255,255,0.1);
        color: #fff;
      }
      .nav-link.primary {
        background: var(--teal);
        color: #fff;
        border-color: var(--teal);
        font-weight: 600;
        box-shadow: 0 2px 10px rgba(0,102,100,0.35);
      }
      .nav-link.primary:hover {
        background: var(--teal-dark);
        box-shadow: 0 4px 16px rgba(0,102,100,0.45);
        transform: translateY(-1px);
      }

      /* ──────────────────────────────
         HERO
      ────────────────────────────── */
      .hero {
        position: relative; z-index: 10;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 60px 40px 80px;
      }

      .hero-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(255,255,255,0.1);
        border: 1px solid rgba(255,255,255,0.2);
        backdrop-filter: blur(8px);
        border-radius: 50px;
        padding: 6px 20px;
        font-size: 13px;
        font-weight: 600;
        color: rgba(255,255,255,0.9);
        letter-spacing: 0.5px;
        margin-bottom: 32px;
      }
      .hero-eyebrow::before {
        content: '';
        width: 7px; height: 7px;
        border-radius: 50%;
        background: #7effda;
        box-shadow: 0 0 8px #7effda;
        animation: blink 2.5s ease-in-out infinite;
      }
      @keyframes blink { 0%,100%{opacity:1} 50%{opacity:.3} }

      .hero-title {
        /* match login page title sizing/spacing */
        font-size: clamp(30px, 3.2vw, 36px);
        font-weight: 800;
        line-height: 1.6;
        letter-spacing: -0.5px;
        margin-bottom: 10px;
        text-shadow: 0 2px 16px rgba(0,0,0,0.35);
      }
      .hero-title-accent {
        /* keep gradient but use similar sizing to login accent */
        font-size: 0.7em;
        background: linear-gradient(135deg, #ffd97d, var(--gold));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        display: block;
        margin-top: 5px;
      }
      .hero-title-accent-ku {
        background: linear-gradient(135deg, #ffd97d, var(--gold));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        display: block;
        margin-top: 0px;
      }

      .hero-subtitle {
        font-size: clamp(15px, 1.8vw, 18px);
        font-weight: 400;
        color: rgba(255,255,255,0.99);
        line-height: 1.8;
        max-width: 560px;
        margin: 25px auto 48px;
      }

      /* CTA buttons */
      .cta-group {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 16px;
        flex-wrap: wrap;
        margin-bottom: 48px;
      }

      .cta-btn {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 12px 34px;
        border-radius: 12px;
        font-size: 15.5px;
        font-weight: 700;
        font-family: inherit;
        cursor: pointer;
        text-decoration: none;
        border: none;
        letter-spacing: 0.2px;
        transition: transform 0.2s, box-shadow 0.2s;
        position: relative;
        overflow: hidden;
      }
      .cta-btn::before {
        content: '';
        position: absolute; inset: 0;
        background: linear-gradient(to bottom, rgba(255,255,255,0.15), transparent);
        pointer-events: none;
      }
      .cta-btn:hover { transform: translateY(-3px); }
      .cta-btn:active { transform: translateY(0); }

      /* Primary: KU ALL LOGIN */
      .cta-btn-kuall {
        background: linear-gradient(135deg, var(--gree-dark), var(--gree));
        color: #fff;
        box-shadow: 0 4px 20px rgba(33, 77, 74, 0.4);
      }
      .cta-btn-kuall:hover {
        box-shadow: 0 8px 32px rgba(33, 77, 74, 0.55);
      }
      .cta-btn-kuall .btn-icon {
        width: 32px; height: 32px;
        border-radius: 50%;
        background: rgba(255,255,255,0.25);
        display: grid; place-items: center;
        font-size: 14px;
      }

      /* Secondary: ลงชื่อเข้าใช้ปกติ */
      .cta-btn-normal {
        background: rgba(255,255,255,0.12);
        color: #fff;
        border: 1.5px solid rgba(255,255,255,0.3);
        backdrop-filter: blur(10px);
        box-shadow: 0 4px 16px rgba(0,0,0,0.2);
      }
      .cta-btn-normal:hover {
        background: rgba(255,255,255,0.2);
        border-color: rgba(255,255,255,0.5);
        box-shadow: 0 8px 24px rgba(0,0,0,0.3);
      }

      /* ──────────────────────────────
         STATS BAR
      ────────────────────────────── */
      .stats-bar {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 48px;
        flex-wrap: wrap;
      }
      .stat-item {
        text-align: center;
        position: relative;
      }
      .stat-item + .stat-item::before {
        content: '';
        position: absolute;
        left: -24px; top: 50%;
        transform: translateY(-50%);
        width: 1px; height: 36px;
        background: rgba(255,255,255,0.15);
      }
      .stat-value {
        font-size: 28px;
        font-weight: 800;
        color: #fff;
        line-height: 1;
        margin-bottom: 4px;
      }
      .stat-label {
        font-size: 12px;
        color: rgba(255,255,255,0.55);
        font-weight: 400;
        letter-spacing: 0.3px;
      }

      /* ──────────────────────────────
         FEATURES ROW (bottom anchor)
      ────────────────────────────── */
      .features-row {
        position: fixed; bottom: 0; left: 0; right: 0;
        z-index: 20;
        display: flex;
        align-items: stretch;
        backdrop-filter: blur(16px);
        background: rgba(0,30,28,0.6);
        border-top: 1px solid rgba(255,255,255,0.1);
      }
      .feature-block {
        flex: 1;
        padding: 20px 28px;
        border-right: 1px solid rgba(255,255,255,0.08);
        display: flex;
        align-items: center;
        gap: 14px;
      }
      .feature-block:last-child { border-right: none; }
      .feature-icon {
        width: 40px; height: 40px;
        border-radius: 10px;
        background: rgba(0,102,100,0.25);
        border: 1px solid rgba(0,102,100,0.35);
        display: grid; place-items: center;
        font-size: 18px;
        flex-shrink: 0;
      }
      .feature-title {
        font-size: 13.5px; font-weight: 700;
        margin-bottom: 2px;
      }
      .feature-desc {
        font-size: 12px;
        color: rgba(255,255,255,0.5);
      }

      /* ── Slide dots indicator ── */
      .slide-dots {
        position: fixed; bottom: 100px; left: 50%;
        transform: translateX(-50%);
        z-index: 20;
        display: flex; gap: 8px;
      }
      .dot {
        width: 8px; height: 8px;
        border-radius: 50%;
        background: rgba(255,255,255,0.3);
        border: 1px solid rgba(255,255,255,0.4);
        transition: background 0.3s, transform 0.3s;
        cursor: pointer;
      }
      .dot.active {
        background: var(--gold);
        transform: scale(1.3);
        border-color: var(--gold);
      }

      /* ── Responsive ── */
      @media (max-width: 768px) {
        .navbar { padding: 14px 24px; }
        .nav-link:not(.primary) { display: none; }
        .hero { padding: 100px 24px 120px; }
        .features-row { flex-direction: column; }
        .feature-block { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.08); padding: 14px 20px; }
        html, body { overflow: auto; }
      }
    </style>
  </head>
  <body>

    <!-- ── Decorative bar ── -->
    <div class="gold-bar"></div>

    <!-- ── Slideshow background ── -->
    <div class="bg-wrap">
      <div class="bg-slide bg-slide-1 active" id="bgSlide1"></div>
      <div class="bg-slide bg-slide-2" id="bgSlide2"></div>
      <div class="bg-slide bg-slide-3" id="bgSlide3"></div>
      <div class="bg-slide bg-slide-4" id="bgSlide4"></div>
      <div class="bg-slide bg-slide-5" id="bgSlide5"></div>
      <div class="bg-slide bg-slide-6" id="bgSlide6"></div>
      <div class="bg-slide bg-slide-7" id="bgSlide7"></div>
      <div class="bg-slide bg-slide-8" id="bgSlide8"></div>
    </div>
    <div class="bg-overlay"></div>

    <!-- ── Navbar ── -->
    <nav class="navbar">
      <a href="/" class="nav-brand">
        <div class="nav-logo">KU</div>
        <div class="nav-brand-text">
          <div class="nav-brand-name">PMS KASETSART</div>
          <div class="nav-brand-sub">มหาวิทยาลัยเกษตรศาสตร์</div>
        </div>
      </a>
      <div class="nav-links">
        <a href="#" class="nav-link">เกี่ยวกับระบบ</a>
        <a href="#" class="nav-link">ติดต่อ</a>
        <a href="/login" class="nav-link primary">เข้าสู่ระบบ</a>
      </div>
    </nav>

    <!-- ── Hero ── -->
    <section class="hero">
      <div class="hero-eyebrow">ระบบบริหารโครงการ | Project Management System</div>

      <h1 class="hero-title">
        PMS KASETSART
        <span class="hero-title-accent">ระบบบริหารโครงการ เพื่อขับเคลื่อนยุทธศาสตร์<br>
          <span class="hero-title-accent-ku">มหาวิทยาลัยเกษตรศาสตร์</span>
        </span>
      </h1>

      <p class="hero-subtitle">
        เครื่องมือบริหารจัดการโครงการระดับมหาวิทยาลัยที่ออกแบบมาเพื่อ<br>
        ขับเคลื่อนยุทธศาสตร์และเป้าหมายองค์กรอย่างมีประสิทธิภาพ
      </p>

      <!-- CTA GROUP -->
      <div class="cta-group flex items-center justify-center gap-4 flex-wrap mb-12">
        <!-- KU ALL LOGIN -->
        <a href="#" class="cta-btn cta-btn-kuall inline-flex items-center gap-2 px-8 py-3 rounded-xl text-sm font-bold transition-all duration-200 hover:transform hover:-translate-y-1" id="btnKuAll">
          <span class="btn-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 48 48">
              <path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" d="M24 43.5c9.043-3.117 15.489-10.363 16.5-19.589c.28-4.005.257-8.025-.071-12.027a2.54 2.54 0 0 0-2.468-2.366c-4.091-.126-8.846-.808-12.52-4.427a2.05 2.05 0 0 0-2.881 0c-3.675 3.619-8.43 4.301-12.52 4.427a2.54 2.54 0 0 0-2.468 2.366A79.4 79.4 0 0 0 7.5 23.911C8.512 33.137 14.957 40.383 24 43.5"/><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" d="M17.612 19.804h12.776c.484 0 .877.392.877.877v9.442a.877.877 0 0 1-.877.877H17.612a.877.877 0 0 1-.877-.877V20.68c0-.485.393-.878.877-.878"/><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" d="M19.192 19.804V17.79a4.805 4.805 0 0 1 9.608 0v2.014"/><circle cx="23.996" cy="25.402" r="1.863" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          ลงชื่อเข้าใช้ด้วย KU ALL LOGIN
        </a>
        <!-- Normal login -->
        <a href="/login" class="cta-btn cta-btn-normal inline-flex items-center gap-2 px-8 py-3 rounded-xl text-sm font-bold transition-all duration-200 hover:transform hover:-translate-y-1">
          <span class="btn-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 48 48">
              <path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" d="M24 34.798c4.715-2.505 7.788-5.876 7.788-8.658V14.956h-7.776z"/><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" d="M23.397 38.362c.379.184.827.184 1.206 0c6.087-2.964 10.63-7.542 10.63-12.222V12.882c0-.763-.62-1.382-1.383-1.382H24h0h-9.85c-.763 0-1.382.619-1.382 1.382V26.14c0 4.68 4.542 9.258 10.63 12.222ZM16 5.5H9.5a4 4 0 0 0-4 4V16m37 0V9.5a4 4 0 0 0-4-4H32M5.5 32v6.5a4 4 0 0 0 4 4H16m16 0h6.5a4 4 0 0 0 4-4V32"/>
            </svg>
          </span>
          ลงชื่อเข้าใช้งานปกติ
        </a>
      </div>

      <!-- Stats bar -->
      <div class="stats-bar flex items-center justify-center gap-12 flex-wrap">
        <div class="stat-item">
          <div class="stat-value">5,000+</div>
          <div class="stat-label">โครงการในระบบ</div>
        </div>
        <div class="stat-item">
          <div class="stat-value">1,500+</div>
          <div class="stat-label">ผู้ใช้งาน</div>
        </div>
        <div class="stat-item">
          <div class="stat-value">20+</div>
          <div class="stat-label">คณะ/หน่วยงาน</div>
        </div>
        <div class="stat-item">
          <div class="stat-value">99.9%</div>
          <div class="stat-label">ความพึงพอใจ</div>
        </div>
      </div>
    </section>

    <!-- ── Slide dots ── -->
    <div class="slide-dots">
      <div class="dot active" id="dot1" onclick="goSlide(1)"></div>
      <div class="dot" id="dot2" onclick="goSlide(2)"></div>
      <div class="dot" id="dot3" onclick="goSlide(3)"></div>
      <div class="dot" id="dot4" onclick="goSlide(4)"></div>
      <div class="dot" id="dot5" onclick="goSlide(5)"></div>
      <div class="dot" id="dot6" onclick="goSlide(6)"></div>
      <div class="dot" id="dot7" onclick="goSlide(7)"></div>
      <div class="dot" id="dot8" onclick="goSlide(8)"></div>
    </div>

    <!-- ── Features bottom bar ── -->
    <div class="features-row">
      <div class="feature-block">
        <div class="feature-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24">
            <path fill="currentColor" d="M4 2v6H2V2zM2 22v-6h2v6zm3-10c0 1.11-.89 2-2 2a2 2 0 1 1 2-2m11-8c4.42 0 8 3.58 8 8s-3.58 8-8 8c-3.6 0-6.64-2.38-7.65-5.65L6 12l2.35-2.35C9.36 6.38 12.4 4 16 4m0 2c-3.31 0-6 2.69-6 6s2.69 6 6 6s6-2.69 6-6s-2.69-6-6-6m-1 7V8h1.5v4.2l3 1.8l-.82 1.26z"/>
          </svg>
        </div>
        <div>
          <div class="feature-title">ติดตามความคืบหน้าโครงการ</div>
          <div class="feature-desc">รายงานผลแบบเรียลไทม์ ทุกที่ทุกเวลา</div>
        </div>
      </div>
      <div class="feature-block">
