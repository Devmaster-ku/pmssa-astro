  <!-- Air Datepicker CDN -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/air-datepicker@3.5.3/air-datepicker.css" />
  <script is:inline src="https://cdn.jsdelivr.net/npm/air-datepicker@3.5.3/air-datepicker.js"></script>

  <style is:global>
    .air-datepicker { --adp-accent-color: #006664; --adp-color-secondary: #006664; }
    .air-datepicker-nav--title { font-weight: 600; }
  </style>

  <script>
    const API =
      (import.meta as any).env.PUBLIC_API_URL || "http://localhost:3000";

    // ── State ──
    let currentStep = 1;
    let projectId = 0;
    let projectData: any = null;
    let implData: any = null;

    // Widget data
    let operators: {
      userId: number | null;
      operatorName: string;
      responsibility: string;
    }[] = [];
    let fundingSources: {
      fundingGroup: string;
      fundingName: string;
      amount: string;
      fundingType: string;
    }[] = [];
    let workPlans: {
      title: string;
      description: string;
      startDate: string;
      endDate: string;
      responsiblePerson: string;
      status: string;
    }[] = [];
    let budgetUsages: any[] = [];
    let signatories: {
      userId: number | null;
      signatoryName: string;
      positionTitle: string;
    }[] = [];

    // ── Helpers ──
    function formatBaht(v: any) {
      const n = parseFloat(String(v ?? 0));
      if (isNaN(n)) return "0.00";
      return n.toLocaleString("th-TH", {
        minimumFractionDigits: 2,
        maximumFractionDigits: 2,
      });
    }

    function getParam(key: string) {
      return new URLSearchParams(window.location.search).get(key) || "";
    }

    // ── Step navigation ──
    function setStep(n: number) {
      currentStep = n;
      document.getElementById("step1")!.classList.toggle("hidden", n !== 1);
      document.getElementById("step2")!.classList.toggle("hidden", n !== 2);
      document.getElementById("step3")!.classList.toggle("hidden", n !== 3);
      document.getElementById("stepBadge")!.textContent = `${n}/3`;
      window.scrollTo({ top: 0, behavior: "smooth" });

      const circles = [1, 2, 3].map(
        (i) => document.getElementById(`stepCircle${i}`)!,
      );
      const labels = [1, 2, 3].map(
        (i) => document.getElementById(`stepLabel${i}`)!,
      );

      circles.forEach((c, i) => {
        const step = i + 1;
        if (step < n) {
          c.className =
            "w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold border-2 transition-all bg-green-500 border-green-500 text-white";
          c.innerHTML =
            '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>';
        } else if (step === n) {
          c.className =
            "w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold border-2 transition-all bg-teal-500 border-teal-500 text-white";
          c.innerHTML = String(step);
        } else {
          c.className =
            "w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold border-2 transition-all bg-white/10 border-white/30 text-white/50";
          c.innerHTML = String(step);
        }
        labels[i].className =
          step <= n
            ? "text-white text-xs font-semibold hidden sm:block"
            : "text-white/50 text-xs hidden sm:block";
      });

      const line1 = document.getElementById("stepLine1")!;
      const line2 = document.getElementById("stepLine2")!;
      line1.className = `flex-1 h-0.5 mx-2 rounded transition-all min-w-[20px] ${n > 1 ? "bg-green-400" : "bg-white/20"}`;
      line2.className = `flex-1 h-0.5 mx-2 rounded transition-all min-w-[20px] ${n > 2 ? "bg-green-400" : "bg-white/20"}`;

      if (n === 3) renderSummary();
    }

    // ── Render functions ──
    function renderOperators() {
      const c = document.getElementById("operatorsList")!;
      if (!operators.length) {
        c.innerHTML =
          '<div class="flex flex-col items-center justify-center py-6 bg-white rounded-xl border border-dashed border-gray-300 shadow-sm"><p class="text-xs text-gray-400">ยังไม่มีผู้ดำเนินโครงการ — กด "เพิ่มผู้ดำเนินโครงการ" เพื่อเพิ่ม</p></div>';
        return;
      }
      c.innerHTML = operators
        .map(
          (op, idx) => `
        <div class="flex flex-col md:flex-row md:items-center gap-4 bg-white rounded-xl border border-gray-200 p-4 shadow-sm relative">
          <div class="hidden md:flex w-10 h-10 rounded-full bg-[#f0f4ff] text-indigo-700 font-bold items-center justify-center shrink-0 text-sm">
            ${idx + 1}
          </div>
          <div class="flex flex-1 gap-3 items-center mb-1 md:hidden">
            <div class="w-8 h-8 rounded-full flex-shrink-0 bg-[#f0f4ff] text-indigo-700 font-bold flex items-center justify-center text-xs">
              ${idx + 1}
            </div>
            <span class="text-xs font-bold text-indigo-800">ผู้ดำเนินโครงการ</span>
          </div>
