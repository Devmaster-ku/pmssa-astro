    function getTotalFunding(): number {
      return fundingSources.reduce((sum, f) => {
        return sum + (parseFloat(String(f.amount || 0).replace(/,/g, "")) || 0);
      }, 0);
    }

    function getEffectiveAmount(bu: any): number {
      const amt = parseFloat(String(bu.amount || 0).replace(/,/g, "")) || 0;
      if (bu.expenseType === "custom") {
        const qty = parseInt(String(bu.personnelCount || 0)) || 0;
        return amt * qty;
      }
      return amt;
    }

    function updateBudgetCards() {
      const initial = getTotalFunding();
      document.getElementById("budgetCardInitial")!.textContent =
        `${formatBaht(initial)} บาท`;

      // Funding breakdown list
      const listEl = document.getElementById("budgetCardFundingList");
      if (listEl) {
        if (!fundingSources.length) {
          listEl.innerHTML = '';
        } else {
          let otherCount = 0;
          const rows = fundingSources
            .filter((f: any) => f.fundingGroup === "main" ||
              (parseFloat(String(f.amount || 0).replace(/,/g, "")) || 0) > 0 ||
              (f.fundingName && f.fundingName.trim()))
            .map((f: any) => {
              let label: string;
              if (f.fundingGroup === "main") label = "แหล่งเงินหลัก";
              else if (f.fundingGroup === "supplement") label = "แหล่งเงินเสริม";
              else { otherCount++; label = `แหล่งเงินอื่นๆ${otherCount > 1 ? " #" + otherCount : ""}`; }
              const name = f.fundingName ? f.fundingName : "—";
              const amt = parseFloat(String(f.amount || 0).replace(/,/g, "")) || 0;
              return `<div class="flex items-center justify-between gap-2">
                <span class="text-[10px] text-gray-500 truncate"><span class="font-medium text-gray-600">${label}</span>: ${name}</span>
                <span class="text-[10px] font-semibold text-[#006664] whitespace-nowrap">${formatBaht(amt)}</span>
              </div>`;
            });
          listEl.innerHTML = rows.join("");
        }
      }

      let totalUsed = 0;
      budgetUsages.forEach((bu: any) => {
        totalUsed += getEffectiveAmount(bu);
      });
      document.getElementById("budgetCardUsed")!.textContent =
        `${formatBaht(totalUsed)} บาท`;
      const remaining = initial - totalUsed;
      const remEl = document.getElementById("budgetCardRemaining")!;
      remEl.textContent = `${formatBaht(remaining)} บาท`;
      remEl.className = `text-lg font-bold ${remaining < 0 ? "text-rose-600" : "text-amber-700"}`;
    }

    function updateCustomNet(idx: number) {
      const net = getEffectiveAmount(budgetUsages[idx]);
      const el = document.getElementById(`customNet_${idx}`);
      if (el) el.textContent = `${formatBaht(net)} บาท`;
    }
    (window as any).updateCustomNet = updateCustomNet;

