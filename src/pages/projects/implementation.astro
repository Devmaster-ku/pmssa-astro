                    : '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"></path>'}
                </svg> 
                <span id="wpToggleText_${idx}">${wp.isCollapsed ? 'แสดง' : 'ซ่อน'}</span>
              </button>
              <button type="button" onclick="removeWorkPlan(${idx})" class="w-8 h-8 flex items-center justify-center text-rose-500 bg-rose-50 hover:bg-rose-100 hover:text-rose-700 rounded-md transition-colors cursor-pointer" title="ลบแผนงาน">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
              </button>
            </div>
          </div>
          <div id="wpBody_${idx}" class="${wp.isCollapsed ? 'hidden' : 'block'}">
          <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-4">
            <div class="md:col-span-2">
              <label class="block text-[13px] font-semibold text-[#0a1f3d] mb-1.5">ชื่อแผนงาน</label>
              <input type="text" value="${wp.title || ''}" onchange="updateWPSummaryTitle(${idx}, this.value)" placeholder="วางแผนออกแบบกิจกรรม..." class="w-full px-4 py-2 text-sm border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#006664]/30 focus:border-[#006664] transition-colors"/>
            </div>
            <div>
              <label class="block text-[13px] font-semibold text-[#0a1f3d] mb-1.5">วันที่เริ่ม</label>
              <div class="relative">
                <input type="text" readonly value="${sDateStr !== '—' ? sDateStr : ''}" placeholder="mm/dd/yyyy" class="wp-start-picker w-full px-4 py-2 text-sm border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#006664]/30 focus:border-[#006664] transition-colors cursor-pointer bg-white" data-idx="${idx}"/>
                <svg class="w-4 h-4 text-gray-400 absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
              </div>
            </div>
            <div>
              <label class="block text-[13px] font-semibold text-[#0a1f3d] mb-1.5">วันที่สิ้นสุด</label>
              <div class="relative">
                <input type="text" readonly value="${eDateStr !== '—' ? eDateStr : ''}" placeholder="mm/dd/yyyy" class="wp-end-picker w-full px-4 py-2 text-sm border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#006664]/30 focus:border-[#006664] transition-colors cursor-pointer bg-white" data-idx="${idx}"/>
                <svg class="w-4 h-4 text-gray-400 absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
              </div>
            </div>
          </div>
          <div class="mb-4">
            <label class="block text-[13px] font-semibold text-[#0a1f3d] mb-1.5">คำอธิบายแผนงาน <span class="text-gray-400 font-normal text-xs">(รายละเอียดเพิ่มเติม, วัตถุประสงค์, กลุ่มเป้าหมาย)</span></label>
            <textarea rows="2" onchange="workPlans[${idx}].description=this.value" placeholder="รายละเอียดเพิ่มเติมของแผนงาน..." class="w-full px-4 py-2 text-sm border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-[#006664]/30 focus:border-[#006664] resize-none transition-colors leading-relaxed">${wp.description || ''}</textarea>
          </div>

          <div class="bg-[#f4fbfc] rounded-lg p-3 sm:p-4 border border-[#e0f2f2] flex flex-col md:flex-row items-center justify-between text-center md:text-left gap-2 sm:gap-4 mt-2">
            <div class="flex-1 w-full flex flex-col items-center">
              <p class="text-[11px] font-bold text-[#006664] mb-1 uppercase tracking-wider">ระยะเวลา</p>
              <p class="text-[15px] font-black text-[#006664]" id="wpDurationDisplay_${idx}">${durationStr}</p>
            </div>
            <div class="hidden md:block w-px h-8 bg-[#ccfbf1]"></div>
            <div class="flex-1 w-full flex flex-col items-center">
              <p class="text-[11px] font-bold text-[#00a896] mb-1 uppercase tracking-wider">เริ่มต้น</p>
              <p class="text-[14px] font-bold text-[#006664]" id="wpStartTextDisplay_${idx}">${sDateStr}</p>
            </div>
            <div class="hidden md:block w-px h-8 bg-[#ccfbf1]"></div>
            <div class="flex-1 w-full flex flex-col items-center">
              <p class="text-[11px] font-bold text-rose-500 mb-1 uppercase tracking-wider">สิ้นสุด</p>
              <p class="text-[14px] font-bold text-rose-600" id="wpEndTextDisplay_${idx}">${eDateStr}</p>
            </div>
          </div>
          </div>
        </div>`;
          }
        )
        .join("");

      setTimeout(() => {
        const ADP = (window as any).AirDatepicker;
        const opts = (window as any).__airPickerOpts;
        if(!ADP || !opts) return;
        
        document.querySelectorAll('.wp-start-picker').forEach((el: any) => {
          const idx = parseInt(el.getAttribute('data-idx'));
          const dpStr = workPlans[idx].startDate;
          new ADP(el, {
            ...opts,
            selectedDates: dpStr ? [new Date(dpStr)] : [],
            onSelect({ date }: any) {
              workPlans[idx].startDate = date ? toISODate(date) : '';
              if((window as any).updateWPDurationUI) (window as any).updateWPDurationUI(idx);
            }
          });
        });
        document.querySelectorAll('.wp-end-picker').forEach((el: any) => {
          const idx = parseInt(el.getAttribute('data-idx'));
          const dpStr = workPlans[idx].endDate;
          new ADP(el, {
            ...opts,
            selectedDates: dpStr ? [new Date(dpStr)] : [],
            onSelect({ date }: any) {
              workPlans[idx].endDate = date ? toISODate(date) : '';
              if((window as any).updateWPDurationUI) (window as any).updateWPDurationUI(idx);
            }
          });
        });
      }, 0);
    }

    // ── Signatory dropdown helpers ──
    function buildSignatoryDropdown(idx: number, currentName: string, currentUserId: number | null) {
      const hasSelection = !!currentUserId;
      const escaped = currentName.replace(/"/g, '&quot;').replace(/'/g, '&#39;');
      return `
        <div class="relative">
          <input
            type="text"
            id="sigDropInput_${idx}"
            value="${escaped}"
            oninput="onSignatoryInput(${idx},this.value)"
            onfocus="onSignatoryFocus(${idx})"
            onblur="onSignatoryBlur(${idx})"
            placeholder="ค้นหาชื่อผู้บุคลากรในหน่วยงาน..."
            autocomplete="off"
            class="w-full px-3 ${hasSelection ? 'pr-8 border-[#006664]/40 bg-teal-50/40' : 'pr-3 border-gray-200'} py-2 text-sm border rounded-md focus:outline-none focus:ring-2 focus:ring-[#006664]/30 focus:border-[#006664]"
          />
          <button type="button" id="sigDropClear_${idx}" onmousedown="onSignatoryClear(${idx})"
            class="${hasSelection ? 'flex' : 'hidden'} absolute right-2 top-1/2 -translate-y-1/2 items-center justify-center w-4 h-4 rounded-full bg-gray-400 hover:bg-rose-400 text-white text-[10px] leading-none cursor-pointer"
            title="ล้างการเลือก">✕</button>
          <div id="sigDropList_${idx}" class="absolute z-50 w-full bg-white border border-gray-200 rounded-md shadow-lg mt-1 hidden max-h-52 overflow-y-auto text-sm"></div>
        </div>`;
    }

    function renderSignatoryList(idx: number, query: string) {
      const list = document.getElementById(`sigDropList_${idx}`);
      if (!list) return;
      const q = query.trim().toLowerCase();
      const filtered = q
        ? signatoryUserOptions.filter(u => u.nameTh.toLowerCase().includes(q))
        : signatoryUserOptions;
      if (!filtered.length) {
        list.innerHTML = '<div class="px-3 py-2 text-xs text-gray-400">ไม่พบรายชื่อ</div>';
      } else {
        list.innerHTML = filtered.slice(0, 50).map(u => {
          const safeName = u.nameTh.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/'/g,'&#39;').replace(/"/g,'&quot;');
          const safePos = (u.positionTitle || "").replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/'/g,'&#39;').replace(/"/g,'&quot;');
          return `<div class="px-3 py-2 cursor-pointer hover:bg-teal-50 hover:text-teal-700 border-b border-gray-50 last:border-0"
            onmousedown="onSignatorySelect(${idx},${u.id},'${safeName}','${safePos}')">
            <div class="text-sm font-medium text-gray-800">${u.nameTh.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')}</div>
            ${u.positionTitle ? `<div class="text-[10px] text-gray-400 mt-0.5">${u.positionTitle.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')}</div>` : ''}
          </div>`;
        }).join('');
      }
      list.classList.remove('hidden');
    }

    // ── Expense dropdown helpers ──
    function buildExpenseDropdown(idx: number, currentName: string, isCustom: boolean, expenseDetailId?: number | null) {
      if (isCustom) {
        return `<input type="text" value="${currentName.replace(/"/g, '&quot;')}" onchange="budgetUsages[${idx}].expenseName=this.value" placeholder="ระบุชื่อค่าใช้จ่าย..." class="w-full px-3 py-2 text-sm border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-[#006664]/30 focus:border-[#006664]"/>`;
      }
      const escaped = currentName.replace(/"/g, '&quot;').replace(/'/g, '&#39;');
      const hasSelection = !!expenseDetailId;
      return `
        <div class="relative" id="expDropWrap_${idx}">
          <input type="text"
            id="expDropInput_${idx}"
            value="${escaped}"
            oninput="onExpenseInput(${idx},this.value)"
            onfocus="onExpenseFocus(${idx})"
            onblur="onExpenseBlur(${idx})"
            placeholder="ค้นหาหรือพิมพ์ชื่อค่าใช้จ่าย..."
            autocomplete="off"
            class="w-full px-3 ${hasSelection ? 'pr-8' : 'pr-3'} py-2 text-sm border ${hasSelection ? 'border-[#006664]/40 bg-teal-50/40' : 'border-gray-200'} rounded-md focus:outline-none focus:ring-2 focus:ring-[#006664]/30 focus:border-[#006664]"
          />
          <button type="button" id="expDropClear_${idx}" onmousedown="onExpenseClear(${idx})"
            class="${hasSelection ? 'flex' : 'hidden'} absolute right-2 top-1/2 -translate-y-1/2 items-center justify-center w-4 h-4 rounded-full bg-gray-400 hover:bg-rose-400 text-white text-[10px] leading-none cursor-pointer"
            title="ล้างการเลือก">✕</button>
          <div id="expDropList_${idx}" class="absolute z-50 w-full bg-white border border-gray-200 rounded-md shadow-lg mt-1 hidden max-h-52 overflow-y-auto text-sm"></div>
        </div>`;
    }

    function renderExpenseList(idx: number, query: string) {
      const list = document.getElementById(`expDropList_${idx}`);
      if (!list) return;
      const q = query.trim().toLowerCase();
      const filtered = q
        ? expenseDetailOptions.filter(o => o.name.toLowerCase().includes(q))
        : expenseDetailOptions;
      if (!filtered.length) {
        list.innerHTML = '<div class="px-3 py-2 text-xs text-gray-400">ไม่พบรายการ</div>';
      } else {
        list.innerHTML = filtered.map(o => {
          const safe = o.name.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
          return `<div class="px-3 py-2 cursor-pointer hover:bg-teal-50 hover:text-teal-700" onmousedown="onExpenseSelect(${idx},${o.id},'${safe}')">${safe}</div>`;
        }).join('');
      }
      list.classList.remove('hidden');
    }

    (window as any).onExpenseInput = (idx: number, value: string) => {
      budgetUsages[idx].expenseName = value;
      budgetUsages[idx].expenseDetailId = null;
      // hide clear button when typing freely
      const clearBtn = document.getElementById(`expDropClear_${idx}`);
      if (clearBtn) clearBtn.classList.add('hidden');
      const input = document.getElementById(`expDropInput_${idx}`) as HTMLInputElement;
      if (input) { input.classList.remove('pr-8', 'border-[#006664]/40', 'bg-teal-50/40'); input.classList.add('pr-3', 'border-gray-200'); }
      renderExpenseList(idx, value);
    };
    (window as any).onExpenseFocus = (idx: number) => {
      const input = document.getElementById(`expDropInput_${idx}`) as HTMLInputElement;
      renderExpenseList(idx, input?.value || '');
    };
    (window as any).onExpenseBlur = (idx: number) => {
      setTimeout(() => {
        const list = document.getElementById(`expDropList_${idx}`);
        if (list) list.classList.add('hidden');
      }, 150);
    };
    (window as any).onExpenseSelect = (idx: number, detailId: number, name: string) => {
      budgetUsages[idx].expenseName = name;
      budgetUsages[idx].expenseDetailId = detailId;
      const input = document.getElementById(`expDropInput_${idx}`) as HTMLInputElement;
      if (input) {
        input.value = name;
        input.classList.add('pr-8', 'border-[#006664]/40', 'bg-teal-50/40');
        input.classList.remove('pr-3', 'border-gray-200');
      }
      const clearBtn = document.getElementById(`expDropClear_${idx}`);
      if (clearBtn) clearBtn.classList.replace('hidden', 'flex');
      const list = document.getElementById(`expDropList_${idx}`);
      if (list) list.classList.add('hidden');
    };
    (window as any).onExpenseClear = (idx: number) => {
      budgetUsages[idx].expenseName = '';
      budgetUsages[idx].expenseDetailId = null;
      const input = document.getElementById(`expDropInput_${idx}`) as HTMLInputElement;
      if (input) {
        input.value = '';
        input.classList.remove('pr-8', 'border-[#006664]/40', 'bg-teal-50/40');
        input.classList.add('pr-3', 'border-gray-200');
        input.focus();
      }
      const clearBtn = document.getElementById(`expDropClear_${idx}`);
      if (clearBtn) clearBtn.classList.replace('flex', 'hidden');
      renderExpenseList(idx, '');
    };

    // ── Signatory dropdown handlers ──
    (window as any).onSignatoryInput = (idx: number, value: string) => {
      signatories[idx].signatoryName = value;
      signatories[idx].userId = null;
      const clearBtn = document.getElementById(`sigDropClear_${idx}`);
      if (clearBtn) clearBtn.classList.add('hidden');
      const input = document.getElementById(`sigDropInput_${idx}`) as HTMLInputElement;
      if (input) { input.classList.remove('pr-8', 'border-[#006664]/40', 'bg-teal-50/40'); input.classList.add('pr-3', 'border-gray-200'); }
      renderSignatoryList(idx, value);
    };
    (window as any).onSignatoryFocus = (idx: number) => {
      const input = document.getElementById(`sigDropInput_${idx}`) as HTMLInputElement;
      renderSignatoryList(idx, input?.value || '');
    };
    (window as any).onSignatoryBlur = (idx: number) => {
      setTimeout(() => {
        const list = document.getElementById(`sigDropList_${idx}`);
        if (list) list.classList.add('hidden');
      }, 150);
    };
    (window as any).onSignatorySelect = (idx: number, userId: number, name: string, positionTitle: string) => {
      const userOpt = signatoryUserOptions.find(u => u.id === userId);
      signatories[idx].userId = userId;
      signatories[idx].signatoryName = name;
      signatories[idx].positionTitle = positionTitle;
      signatories[idx].positions = userOpt?.positions || (positionTitle ? [positionTitle] : []);
      signatories[idx].positionIndex = 0;
      const input = document.getElementById(`sigDropInput_${idx}`) as HTMLInputElement;
      if (input) {
        input.value = name;
        input.classList.add('pr-8', 'border-[#006664]/40', 'bg-teal-50/40');
        input.classList.remove('pr-3', 'border-gray-200');
      }
      const clearBtn = document.getElementById(`sigDropClear_${idx}`);
      if (clearBtn) clearBtn.classList.replace('hidden', 'flex');
      const list = document.getElementById(`sigDropList_${idx}`);
      if (list) list.classList.add('hidden');
      // auto-fill ตำแหน่ง
      const posInput = document.getElementById(`sigPos_${idx}`) as HTMLInputElement;
      if (posInput) posInput.value = positionTitle;
      // แสดง/ซ่อน ปุ่มสลับตำแหน่ง
      const toggleBtn = document.getElementById(`sigToggle_${idx}`);
      const hasMulti = signatories[idx].positions.length > 1;
      if (toggleBtn) toggleBtn.classList[hasMulti ? 'remove' : 'add']('hidden');
      if (posInput) { posInput.classList[hasMulti ? 'add' : 'remove']('pr-8'); posInput.classList[hasMulti ? 'remove' : 'add']('pr-3'); }
    };
    (window as any).onSignatoryClear = (idx: number) => {
      signatories[idx].signatoryName = '';
      signatories[idx].userId = null;
      signatories[idx].positions = [];
      signatories[idx].positionIndex = 0;
      const input = document.getElementById(`sigDropInput_${idx}`) as HTMLInputElement;
      if (input) {
        input.value = '';
        input.classList.remove('pr-8', 'border-[#006664]/40', 'bg-teal-50/40');
        input.classList.add('pr-3', 'border-gray-200');
        input.focus();
      }
      const clearBtn = document.getElementById(`sigDropClear_${idx}`);
      if (clearBtn) clearBtn.classList.replace('flex', 'hidden');
      // ล้างช่องตำแหน่งและซ่อนปุ่มสลับตำแหน่ง
      signatories[idx].positionTitle = '';
      const toggleBtn = document.getElementById(`sigToggle_${idx}`);
      if (toggleBtn) toggleBtn.classList.add('hidden');
      const posInput = document.getElementById(`sigPos_${idx}`) as HTMLInputElement;
      if (posInput) { posInput.value = ''; posInput.classList.remove('pr-8'); posInput.classList.add('pr-3'); }
      renderSignatoryList(idx, '');
    };
    (window as any).onTogglePosition = (idx: number) => {
      const s = signatories[idx];
      if (!s.positions || s.positions.length <= 1) return;
      s.positionIndex = ((s.positionIndex || 0) + 1) % s.positions.length;
      s.positionTitle = s.positions[s.positionIndex];
      const posInput = document.getElementById(`sigPos_${idx}`) as HTMLInputElement;
      if (posInput) posInput.value = s.positionTitle;
    };

    // ── Sub-item dropdown helpers ──
    function buildSubDropdown(mainIdx: number, subIdx: number, currentName: string, subDetailId?: number | null, mainDetailId?: number | null) {
      const escaped = currentName.replace(/"/g, '&quot;').replace(/'/g, '&#39;');
      const hasSelection = !!subDetailId;
      const key = `${mainIdx}_${subIdx}`;
      return `
        <div class="relative" id="subDropWrap_${key}">
          <input type="text"
            id="subDropInput_${key}"
            value="${escaped}"
            oninput="onSubInput(${mainIdx},${subIdx},this.value)"
            onfocus="onSubFocus(${mainIdx},${subIdx},${mainDetailId ?? 'null'})"
            onblur="onSubBlur(${mainIdx},${subIdx})"
            placeholder="ค้นหาหรือพิมพ์ชื่อค่าใช้จ่ายย่อย..."
            autocomplete="off"
            class="w-full px-2 ${hasSelection ? 'pr-7' : 'pr-2'} py-1.5 text-xs border ${hasSelection ? 'border-[#006664]/40 bg-teal-50/40' : 'border-gray-200'} rounded focus:outline-none focus:ring-1 focus:ring-[#006664]/30"
          />
          <button type="button" id="subDropClear_${key}" onmousedown="onSubClear(${mainIdx},${subIdx},${mainDetailId ?? 'null'})"
            class="${hasSelection ? 'flex' : 'hidden'} absolute right-1.5 top-1/2 -translate-y-1/2 items-center justify-center w-3.5 h-3.5 rounded-full bg-gray-400 hover:bg-rose-400 text-white text-[9px] leading-none cursor-pointer"
            title="ล้างการเลือก">✕</button>
          <div id="subDropList_${key}" class="absolute z-50 w-full bg-white border border-gray-200 rounded-md shadow-lg mt-1 hidden max-h-48 overflow-y-auto text-xs"></div>
        </div>`;
    }

    function renderSubList(mainIdx: number, subIdx: number, query: string, mainDetailId: number | null) {
      const key = `${mainIdx}_${subIdx}`;
      const list = document.getElementById(`subDropList_${key}`);
      if (!list) return;
      const pool = mainDetailId
        ? subExpenseDetailOptions.filter(o => o.parentId === mainDetailId)
        : subExpenseDetailOptions;
      const q = query.trim().toLowerCase();
      const filtered = q ? pool.filter(o => o.name.toLowerCase().includes(q)) : pool;
      if (!filtered.length) {
        list.innerHTML = mainDetailId
          ? '<div class="px-3 py-2 text-gray-400">ไม่พบรายการย่อยภายใต้หัวข้อหลักนี้</div>'
          : '<div class="px-3 py-2 text-gray-400">ไม่พบรายการ</div>';
      } else {
        list.innerHTML = filtered.map(o => {
          const safe = o.name.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
          return `<div class="px-3 py-2 cursor-pointer hover:bg-teal-50 hover:text-teal-700" onmousedown="onSubSelect(${mainIdx},${subIdx},${o.id},'${safe}')">${safe}</div>`;
        }).join('');
      }
      list.classList.remove('hidden');
    }

    (window as any).onSubInput = (mainIdx: number, subIdx: number, value: string) => {
      budgetUsages[mainIdx].subItems[subIdx].expenseName = value;
      budgetUsages[mainIdx].subItems[subIdx].expenseDetailId = null;
      const key = `${mainIdx}_${subIdx}`;
      const clearBtn = document.getElementById(`subDropClear_${key}`);
