                <input type="text" id="opInput${idx}" value="${op.operatorName || ""}" onchange="operators[${idx}].operatorName=this.value" onfocus="_focusOp(${idx}, this)" oninput="_searchOp(${idx}, this)" placeholder="เช่น รศ.ดร. ชื่อ นามสกุล" class="w-full pl-3 pr-9 py-2.5 text-sm text-[#0a1f3d] border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500/30 focus:border-indigo-500 transition-colors bg-white placeholder:text-gray-400" autocomplete="off"/>
                <svg class="w-4 h-4 text-gray-400 absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                <div id="opDropdown${idx}" class="hidden absolute z-30 left-0 right-0 mt-1 bg-white border border-gray-200 rounded-md shadow-xl overflow-hidden max-h-52 overflow-y-auto"></div>
