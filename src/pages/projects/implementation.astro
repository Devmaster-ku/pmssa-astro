                <input type="text" value="${fs.fundingName || ""}" onchange="fundingSources[${idx}].fundingName=this.value" placeholder="${idx === 0 ? 'เงินรายได้ของหน่วยงาน' : 'แหล่งเงินเพิ่มเติม (ถ้ามี)'}" class="w-full px-3 py-2.5 text-[13px] border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-cyan-500/30 focus:border-cyan-500 text-[#0a1f3d]"/>
              </div>
              <div>
                <label class="block text-[11px] font-semibold text-[#0a1f3d] mb-1.5">จำนวนเงิน (บาท) ${idx === 0 ? '<span class="text-rose-500">*</span>' : ''}</label>
                <input type="text" inputmode="decimal" value="${fmtAmt(fs.amount)}" onfocus="this.value=fundingSources[${idx}].amount||''" oninput="numOnly(this);fundingSources[${idx}].amount=this.value;updateFundingSummaryCustom();updateBudgetCards();" onblur="fundingSources[${idx}].amount=this.value.replace(/,/g,'');this.value=fmtAmt(this.value);updateFundingSummaryCustom();updateBudgetCards();" placeholder="0.00" class="w-full px-3 py-2.5 text-[13px] border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-cyan-500/30 focus:border-cyan-500 text-[#0a1f3d]"/>
              </div>
              <div>
                <label class="block text-[11px] font-semibold text-[#0a1f3d] mb-1.5">ประเภทแหล่งเงิน ${idx === 0 ? '<span class="text-rose-500">*</span>' : ''}</label>
                <select onchange="fundingSources[${idx}].fundingType=this.value" class="w-full px-3 py-2.5 text-[13px] border border-gray-200 rounded-lg bg-white focus:outline-none focus:ring-2 focus:ring-cyan-500/30 focus:border-cyan-500 appearance-none text-[#0a1f3d]">
                  <option value="">${idx === 0 ? 'เงินรายได้ของหน่วยงาน' : 'อื่นๆ'}</option>
                  <option value="งบประมาณแผ่นดิน" ${fs.fundingType === "งบประมาณแผ่นดิน" ? "selected" : ""}>งบประมาณแผ่นดิน</option>
                  <option value="งบประมาณมหาวิทยาลัย" ${fs.fundingType === "งบประมาณมหาวิทยาลัย" ? "selected" : ""}>งบประมาณมหาวิทยาลัย</option>
                  <option value="เงินรายได้ของหน่วยงาน" ${fs.fundingType === "เงินรายได้ของหน่วยงาน" ? "selected" : ""}>เงินรายได้ของหน่วยงาน</option>
                  <option value="แหล่งทุนภายนอก" ${fs.fundingType === "แหล่งทุนภายนอก" ? "selected" : ""}>แหล่งทุนภายนอก</option>
                  <option value="เอกชน" ${fs.fundingType === "เอกชน" ? "selected" : ""}>เอกชน</option>
