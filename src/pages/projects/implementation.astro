    // ── Thai locale & Air Datepicker init ──
    const thaiMonths = ['มกราคม','กุมภาพันธ์','มีนาคม','เมษายน','พฤษภาคม','มิถุนายน','กรกฎาคม','สิงหาคม','กันยายน','ตุลาคม','พฤศจิกายน','ธันวาคม'];
    const thaiMonthsShort = ['ม.ค.','ก.พ.','มี.ค.','เม.ย.','พ.ค.','มิ.ย.','ก.ค.','ส.ค.','ก.ย.','ต.ค.','พ.ย.','ธ.ค.'];
    const thaiDays = ['อาทิตย์','จันทร์','อังคาร','พุธ','พฤหัสบดี','ศุกร์','เสาร์'];
    const thaiDaysShort = ['อา','จ','อ','พ','พฤ','ศ','ส'];
    const thaiDaysMin = ['อา','จ','อ','พ','พฤ','ศ','ส'];

    function formatThaiDate(isoStr: string): string {
      if (!isoStr) return '';
      const d = new Date(isoStr);
      if (isNaN(d.getTime())) return isoStr;
      const day = d.getDate();
      const month = thaiMonthsShort[d.getMonth()];
      const buddhistYear = d.getFullYear() + 543;
      return `${day} ${month} ${buddhistYear}`;
    }

    function toISODate(d: Date): string {
      const y = d.getFullYear();
      const m = String(d.getMonth() + 1).padStart(2, '0');
      const dd = String(d.getDate()).padStart(2, '0');
      return `${y}-${m}-${dd}`;
    }

    function updateDateSummary() {
      const sdEl = document.getElementById('startDate') as HTMLInputElement;
      const edEl = document.getElementById('endDate') as HTMLInputElement;
      const panel = document.getElementById('dateSummaryPanel');
      if (!sdEl || !edEl || !panel) return;

      const sdVal = sdEl.value;
      const edVal = edEl.value;

      const headerBox = document.getElementById('headerProjectDateBox');
      const headerSd = document.getElementById('headerProjectStartDate');
      const headerEd = document.getElementById('headerProjectEndDate');

      if (sdVal && edVal) {
        if (headerBox) {
          headerBox.classList.remove('hidden');
          headerBox.classList.add('flex', 'flex-col', 'sm:flex-row');
        }
        if (headerSd) headerSd.textContent = formatThaiDate(sdVal);
        if (headerEd) headerEd.textContent = formatThaiDate(edVal);
      } else {
        if (headerBox) {
          headerBox.classList.add('hidden');
          headerBox.classList.remove('flex', 'flex-col', 'sm:flex-row');
        }
      }

      if (!sdVal && !edVal) {
        panel.classList.add('hidden');
        return;
      }

      panel.classList.remove('hidden');

      const sd = sdVal ? new Date(sdVal) : null;
      const ed = edVal ? new Date(edVal) : null;

      const sumSd = document.getElementById('summaryStartDate');
      const sumEd = document.getElementById('summaryEndDate');
      const sumDur = document.getElementById('summaryDuration');
      const sumDurDet = document.getElementById('summaryDurationDetail');
      const bar = document.getElementById('summaryProgressBar');
      const pctTxt = document.getElementById('summaryProgressPct');

      if (sumSd) sumSd.textContent = sdVal ? formatThaiDate(sdVal) : '—';
      if (sumEd) sumEd.textContent = edVal ? formatThaiDate(edVal) : '—';

      const now = new Date();
      now.setHours(0,0,0,0);

      if (sd && ed && ed >= sd) {
        const diffTime = Math.abs(ed.getTime() - sd.getTime());
        const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24)) + 1;
        const totalDuration = diffDays;
        
        let years = Math.floor(totalDuration / 365);
        let remainDays = totalDuration % 365;
        let months = Math.floor(remainDays / 30);
        let days = remainDays % 30;

        let txt = [];
        if (years > 0) txt.push(`${years} ปี`);
        if (months > 0) txt.push(`${months} เดือน`);
        if (days > 0) txt.push(`${days} วัน`);
        
        if (sumDur) sumDur.textContent = `${totalDuration} วัน`;
        if (sumDurDet) sumDurDet.textContent = `( ${txt.join(' ')} )`;

        // Calculate progress percentage based on today's date
        let pct = 0;
        if (now > ed) {
          pct = 100;
        } else if (now > sd) {
          const pass = Math.abs(now.getTime() - sd.getTime());
          const passDays = Math.ceil(pass / (1000 * 60 * 60 * 24));
          pct = Math.round((passDays / totalDuration) * 100);
        }

        if (pctTxt) pctTxt.textContent = `${pct}%`;
        if (bar) bar.style.width = `${pct}%`;

      } else {
        if (sumDur) sumDur.textContent = '—';
        if (sumDurDet) sumDurDet.textContent = '';
        if (pctTxt) pctTxt.textContent = '0%';
        if (bar) bar.style.width = '0%';
      }
    }

    function initDatePickers() {
      const ADP = (window as any).AirDatepicker;
      if (!ADP) { console.warn('AirDatepicker not loaded'); return; }

      const thaiLocale = {
        days: thaiDays,
        daysShort: thaiDaysShort,
        daysMin: thaiDaysMin,
        months: thaiMonths,
        monthsShort: thaiMonthsShort,
        today: 'วันนี้',
        clear: 'ล้าง',
        dateFormat: (d: Date) => {
          const day = d.getDate();
          const month = thaiMonthsShort[d.getMonth()];
          const buddhistYear = d.getFullYear() + 543;
          return `${day} ${month} ${buddhistYear}`;
        },
        firstDay: 0,
      };

      const buddhistDateFormat = (d: Date) => {
        const day = d.getDate();
        const month = thaiMonthsShort[d.getMonth()];
        const buddhistYear = d.getFullYear() + 543;
        return `${day} ${month} ${buddhistYear}`;
      };

      const sharedOpts = {
        locale: thaiLocale,
        dateFormat: buddhistDateFormat,
        navTitles: {
          days: (dp: any) => {
            const d = dp.viewDate;
            return `${thaiMonths[d.getMonth()]} ${d.getFullYear() + 543}`;
          },
          months: (dp: any) => {
            return `${dp.viewDate.getFullYear() + 543}`;
          },
          years: (dp: any) => {
            const y1 = dp.viewDate.getFullYear();
            return `${y1 + 543} - ${y1 + 543 + 9}`;
          },
        },
        autoClose: true,
        isMobile: false,
        buttons: ['today', 'clear'],
      };

      (window as any).__airPickerOpts = sharedOpts;

      (window as any).__startPicker = new ADP('#startDateDisplay', {
        ...sharedOpts,
        onSelect({ date }: any) {
          if (date) {
            (document.getElementById('startDate') as HTMLInputElement).value = toISODate(date);
          } else {
            (document.getElementById('startDate') as HTMLInputElement).value = '';
          }
          updateDateSummary();
        },
      });

      (window as any).__endPicker = new ADP('#endDateDisplay', {
        ...sharedOpts,
        onSelect({ date }: any) {
          if (date) {
            (document.getElementById('endDate') as HTMLInputElement).value = toISODate(date);
          } else {
             (document.getElementById('endDate') as HTMLInputElement).value = '';
          }
          updateDateSummary();
        },
      });
    }

    // Ensure apiFetch is ready before booting
    let allProvinces: any[] = [];
    async function initProvinceAutocomplete() {
      try {
        const res = await (window as any).apiFetch(`${API}/api/provinces`);
        const result = await res.json();
        if (result.success) {
          allProvinces = result.data;
        }
      } catch (e) {
        console.error("Failed to load provinces", e);
      }

      const input = document.getElementById("province") as HTMLInputElement;
      const dropdown = document.getElementById("provinceDropdown");

      if (!input || !dropdown) return;

      function renderList(filterText: string) {
        const query = filterText.toLowerCase();
        const filtered = allProvinces.filter(p => p.nameTh.toLowerCase().includes(query));
        dropdown!.innerHTML = '';

        if (filtered.length === 0) {
          dropdown!.innerHTML = `<div class="px-4 py-3 text-sm text-gray-500 text-center">ไม่พบจังหวัดที่ค้นหา</div>`;
        } else {
          filtered.forEach(p => {
            const div = document.createElement("div");
            div.className = "px-4 py-2.5 text-sm text-gray-700 hover:bg-teal-50 cursor-pointer border-b border-gray-50 last:border-0";
            div.textContent = p.nameTh;
            div.onmousedown = (e) => {
              // Prevent input blur before click registers
              e.preventDefault(); 
              input.value = p.nameTh;
              dropdown!.classList.add('hidden');
            };
            dropdown!.appendChild(div);
          });
        }
        dropdown!.classList.remove('hidden');
      }

      input.addEventListener('focus', () => renderList(input.value));
      input.addEventListener('input', () => renderList(input.value));
      input.addEventListener('blur', () => {
        dropdown.classList.add('hidden');
      });
    }

    function startApp() {
      initDatePickers();
      initProvinceAutocomplete();
      boot();
      setTimeout(updateDateSummary, 500); // trigger after data loads
    }
    
    // ── User Autocomplete for Operators ──
    let userList: any[] = [];
    async function loadUsers() {
      try {
        const res = await (window as any).apiFetch(`${API}/api/users`);
        const data = await res.json();
        if (data.success) {
          userList = data.data;
        }
      } catch (e) {
        console.error('Failed to load users', e);
      }
    }
    
    (window as any)._focusOp = async (idx: number, el: HTMLInputElement) => {
      if (userList.length === 0) await loadUsers();
      (window as any)._searchOp(idx, el);
    };

    (window as any)._searchOp = (idx: number, el: HTMLInputElement) => {
      const p = document.getElementById(`opDropdown${idx}`);
      if (!p) return;
      const q = el.value.trim().toLowerCase();
      if (!q) { p.classList.add('hidden'); return; }
      
      const filtered = userList.filter(u =>
        (u.nameTh || '').toLowerCase().includes(q) ||
        (u.email || '').toLowerCase().includes(q)
      ).slice(0, 15);
      
      p.innerHTML = filtered.length === 0
        ? '<div class="px-4 py-3 text-xs text-gray-400">ไม่พบรายชื่อ</div>'
        : filtered.map(u => {
            const name = (u.nameTh || '').replace(/"/g, '&quot;');
            return `<button type="button" class="w-full px-4 py-2 text-left hover:bg-indigo-50 group" data-uid="${u.id}" data-uname="${name}" onclick="_pickOp(${idx}, this)">
              <p class="text-[12px] font-medium text-[#0a1f3d] group-hover:text-indigo-600">${u.nameTh || ''}</p>
              <p class="text-[10px] text-gray-400">${u.email || ''}</p>
            </button>`;
          }).join('');
      p.classList.remove('hidden');
    };

    (window as any)._pickOp = (idx: number, btn: HTMLElement) => {
      const id = Number(btn.dataset.uid);
      const name = btn.dataset.uname || '';
      operators[idx].userId = id;
      operators[idx].operatorName = name;
      renderOperators();
    };

    document.addEventListener('click', (e) => {
      operators.forEach((_, idx) => {
        const wrap = document.getElementById(`opWrap${idx}`);
        if (wrap && !wrap.contains(e.target as Node)) {
          document.getElementById(`opDropdown${idx}`)?.classList.add('hidden');
        }
      });
    });

    if ((window as any).apiFetch) {
      startApp();
    } else {
      window.addEventListener("load", startApp);
    }
  </script>
</AuthLayout>
