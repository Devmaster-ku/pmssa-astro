              <span class="md:hidden text-xs font-bold">ลบผู้ดำเนินโครงการ</span>
            </button>
          </div>
        </div>`,
        )
        .join("");
    }

    function renderFunding() {
      const c = document.getElementById("fundingList")!;
      if (!fundingSources.length) {
        c.innerHTML =
          '<p class="text-xs text-gray-400 py-3 text-center">ยังไม่มีแหล่งเงิน — กด "เพิ่ม" เพื่อเพิ่ม</p>';
        return;
      }
      c.innerHTML = fundingSources
        .map(
          (fs, idx) => `
        <div class="mb-5 last:mb-0">
          <div class="flex items-center gap-2 mb-2">
            <div class="w-5 h-5 rounded-full ${idx === 0 ? 'bg-cyan-500' : 'bg-gray-400'} text-white flex items-center justify-center text-[11px] font-bold shrink-0">${idx + 1}</div>
            <p class="text-[12px] font-bold text-[#0a1f3d]">
              ${idx === 0 ? 'แหล่งเงินหลัก <span class="text-rose-500">*</span>' : (idx === 1 ? 'แหล่งเงินเสริม <span class="text-gray-500 font-normal">(ถ้ามี)</span>' : 'แหล่งเงินอื่นๆ')}
