      updateFundingSummaryCustom();
      updateBudgetCards();
    }
    
    (window as any).updateFundingSummaryCustom = () => {
       const initialBudgetStr = document.getElementById("infoInitialBudget") ? document.getElementById("infoInitialBudget")!.textContent : "0";
       const initialBudget = parseFloat((initialBudgetStr || "0").replace(/,/g, '')) || 0;
       
       let mainTotal = 0;
       if(fundingSources.length > 0) {
         mainTotal = parseFloat(fundingSources[0].amount) || 0;
       }
       
       const pct = initialBudget > 0 ? (mainTotal / initialBudget) * 100 : (mainTotal > 0 ? 100 : 0);
       
       const totalStr = " " + formatBaht(mainTotal) + " <span class='text-[14px] font-bold'>บาท</span>";
       const mainFundingTotalEl = document.getElementById("mainFundingTotal");
       if(mainFundingTotalEl) mainFundingTotalEl.innerHTML = totalStr;
       
       const fundingPercentEl = document.getElementById("fundingPercent");
       if(fundingPercentEl) fundingPercentEl.textContent = pct.toFixed(1) + "%";
       
       const pb = document.getElementById("fundingProgressBar");
       if(pb) pb.style.width = Math.min(100, pct) + "%";
       
       const alertBox = document.getElementById("fundingStatusAlert");
       if(pct >= 100 && alertBox) {
          alertBox.className = "bg-green-100 border border-green-200 text-[#009b3a] text-[11px] px-3 py-2 rounded-lg font-medium";
          alertBox.innerHTML = "สมบูรณ์: แหล่งเงินหลักครบตามงบประมาณโครงการ";
          if(pb) pb.className = "h-full bg-[#00c34a] rounded-full transition-all";
          if(fundingPercentEl) fundingPercentEl.className = "text-[10px] font-bold text-[#00c34a]";
          if(mainFundingTotalEl) mainFundingTotalEl.className = "text-[18px] font-bold text-[#00c34a]";
          document.getElementById("fundingSummary")!.className = "mt-5 bg-[#ebffed] rounded-xl border border-gray-200 p-5 shadow-sm";
       } else if(alertBox) {
          alertBox.className = "bg-orange-50 border border-orange-200 text-orange-700 text-[11px] px-3 py-2 rounded-lg font-medium";
          alertBox.innerHTML = "คำเตือน: แหล่งเงินหลักยังไม่ครบตามงบประมาณโครงการ";
          if(pb) pb.className = "h-full bg-orange-500 rounded-full transition-all";
          if(fundingPercentEl) fundingPercentEl.className = "text-[10px] font-bold text-orange-600";
          if(mainFundingTotalEl) mainFundingTotalEl.className = "text-[18px] font-bold text-orange-500";
          document.getElementById("fundingSummary")!.className = "mt-5 bg-orange-50 rounded-xl border border-gray-200 p-5 shadow-sm";
       }
    };

    const thMonths = ['ม.ค.', 'ก.พ.', 'มี.ค.', 'เม.ย.', 'พ.ค.', 'มิ.ย.', 'ก.ค.', 'ส.ค.', 'ก.ย.', 'ต.ค.', 'พ.ย.', 'ธ.ค.'];
    const inlineFormatDate = (dString: string) => {
      if(!dString) return "—";
      const d = new Date(dString);
      if(isNaN(d.valueOf())) return "—";
      return d.getDate().toString().padStart(2, '0') + ' ' + thMonths[d.getMonth()] + ' ' + (d.getFullYear() + 543);
    };
    
    (window as any).updateWPDurationUI = (idx: number) => {
      const wp = workPlans[idx];
      let durationStr = "—";
      let sDateStr = inlineFormatDate(wp.startDate);
      let eDateStr = inlineFormatDate(wp.endDate);
      if (wp.startDate && wp.endDate) {
        const sd = new Date(wp.startDate);
        const ed = new Date(wp.endDate);
        if (!isNaN(sd.valueOf()) && !isNaN(ed.valueOf())) {
          const diffTime = ed.valueOf() - sd.valueOf();
          const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24)) + 1;
          durationStr = diffDays > 0 ? `${diffDays} วัน` : "0 วัน";
        }
      }

      const durEl = document.getElementById(`wpDurationDisplay_${idx}`);
      const startEl = document.getElementById(`wpStartTextDisplay_${idx}`);
      const endEl = document.getElementById(`wpEndTextDisplay_${idx}`);
      if(durEl) durEl.textContent = durationStr;
      if(startEl) startEl.textContent = sDateStr;
      if(endEl) endEl.textContent = eDateStr;
      
      const sumStartEl = document.getElementById(`wpSummaryStart_${idx}`);
      const sumEndEl = document.getElementById(`wpSummaryEnd_${idx}`);
      if(sumStartEl) sumStartEl.textContent = sDateStr !== '—' ? sDateStr : 'ยังไม่ระบุ';
      if(sumEndEl) sumEndEl.textContent = eDateStr !== '—' ? eDateStr : 'ยังไม่ระบุ';
    };

    (window as any).updateWPSummaryTitle = (idx: number, val: string) => {
      workPlans[idx].title = val;
      const sel = document.getElementById(`wpSummaryTitle_${idx}`);
      if(sel) sel.innerHTML = val || '<span class="text-gray-400 italic font-normal">ยังไม่มีชื่อแผนงาน</span>';
    };

    (window as any).toggleWorkPlan = (idx: number) => {
      workPlans[idx].isCollapsed = !workPlans[idx].isCollapsed;
      const bodyEl = document.getElementById(`wpBody_${idx}`);
      const btnTextEl = document.getElementById(`wpToggleText_${idx}`);
      const btnIconEl = document.getElementById(`wpToggleIcon_${idx}`);
      
      if (bodyEl && btnTextEl && btnIconEl) {
         if (workPlans[idx].isCollapsed) {
           bodyEl.classList.add('hidden');
           bodyEl.classList.remove('block');
           document.getElementById(`wpSummary_${idx}`)?.classList.remove('hidden');
           document.getElementById(`wpSummary_${idx}`)?.classList.add('flex');
           btnTextEl.textContent = 'แสดง';
           btnIconEl.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>';
         } else {
           bodyEl.classList.remove('hidden');
           bodyEl.classList.add('block');
           document.getElementById(`wpSummary_${idx}`)?.classList.add('hidden');
           document.getElementById(`wpSummary_${idx}`)?.classList.remove('flex');
           btnTextEl.textContent = 'ซ่อน';
           btnIconEl.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"></path>';
         }
      }
    };

