---
import AuthLayout from "../../layouts/AuthenticatedLayout.astro";
---

<AuthLayout title="การดำเนินโครงการ">
  <!-- ══ PAGE HEADER ══ -->
  <div
    class="relative rounded-sm overflow-hidden mb-5 shadow-lg"
    style="background: linear-gradient(135deg, #0c2957 0%, #0a4068 45%, #006664 100%);"
  >
    <div
      class="absolute top-0 left-0 right-0 h-1.5"
      style="background: linear-gradient(90deg, #006664, #b2bb1e, #006664);"
    >
    </div>
    <div
      class="absolute -right-20 -top-20 w-80 h-80 rounded-full pointer-events-none"
      style="background: radial-gradient(circle, rgba(0,102,100,0.15) 0%, transparent 65%);"
    >
    </div>
    <div
      class="absolute inset-0 pointer-events-none opacity-[0.03]"
      style="background-image: repeating-linear-gradient(45deg, #ffffff 0, #ffffff 1px, transparent 0, transparent 12px);"
    >
    </div>

    <div class="relative z-10 p-5 sm:p-6">
      <div
        class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3"
      >
        <div class="flex items-start gap-3">
          <a
            href="/projects"
            class="mt-1 shrink-0 w-8 h-8 rounded-lg bg-white/10 hover:bg-white/20 border border-white/20 flex items-center justify-center transition-colors"
            title="กลับ"
          >
            <svg
              class="w-4 h-4 text-white"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 19l-7-7 7-7"></path>
            </svg>
          </a>
          <div>
            <div class="flex items-center gap-2 flex-wrap">
              <h1 class="text-white text-lg font-bold leading-tight">
                การดำเนินโครงการ
              </h1>
              <span
                class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-teal-500/90 text-white border border-teal-400/50"
              >
                ดำเนินการ
              </span>
            </div>
            <p class="text-white/70 text-sm mt-0.5" id="headerBreadcrumb">
              แผนและการใช้งบประมาณดำเนินการ
            </p>
          </div>
        </div>
        <div class="shrink-0 flex items-center gap-2 sm:mt-1">
          <span class="text-white/50 text-xs">ขั้นตอน</span>
          <span
            id="stepBadge"
            class="px-3 py-1 rounded-full text-sm font-bold bg-teal-500 text-white"
            >1/3</span
          >
        </div>
      </div>

      <!-- Step Nav -->
      <div class="mt-5 flex items-center gap-0">
        <div class="flex items-center gap-2">
          <div
            id="stepCircle1"
            class="w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold border-2 transition-all bg-teal-500 border-teal-500 text-white"
          >
            1
          </div>
          <span
            id="stepLabel1"
            class="text-white text-xs font-semibold hidden sm:block"
            >ข้อมูลการดำเนินโครงการ</span
          >
        </div>
        <div
          id="stepLine1"
          class="flex-1 h-0.5 mx-2 rounded transition-all bg-white/20 min-w-[20px]"
        >
        </div>
        <div class="flex items-center gap-2">
          <div
            id="stepCircle2"
            class="w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold border-2 transition-all bg-white/10 border-white/30 text-white/50"
          >
            2
          </div>
          <span id="stepLabel2" class="text-white/50 text-xs hidden sm:block"
            >งบประมาณและการประเมินผล</span
          >
        </div>
        <div
          id="stepLine2"
          class="flex-1 h-0.5 mx-2 rounded transition-all bg-white/20 min-w-[20px]"
        >
        </div>
        <div class="flex items-center gap-2">
          <div
            id="stepCircle3"
            class="w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold border-2 transition-all bg-white/10 border-white/30 text-white/50"
          >
            3
          </div>
          <span id="stepLabel3" class="text-white/50 text-xs hidden sm:block"
            >สรุปโครงการ</span
          >
        </div>
      </div>
    </div>
  </div>

  <!-- ══ LOADING STATE ══ -->
  <div
    id="pageLoading"
    class="flex flex-col items-center justify-center py-20 gap-3 text-gray-400"
  >
    <svg
      class="w-8 h-8 animate-spin opacity-40"
      fill="none"
      viewBox="0 0 24 24"
    >
      <circle
        class="opacity-25"
        cx="12"
        cy="12"
        r="10"
        stroke="currentColor"
        stroke-width="4"></circle>
      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"
      ></path>
    </svg>
    <p class="text-sm">กำลังโหลดข้อมูลโครงการ...</p>
  </div>

  <!-- ══════════════════════════════════════════════
       STEP 1: ข้อมูลการดำเนินโครงการ
  ═══════════════════════════════════════════════ -->
  <div id="step1" class="hidden space-y-4">
    <div
      class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden"
    >
      <div
        class="px-5 py-3.5 border-b border-gray-100 flex items-center justify-between bg-gray-50/60"
      >
        <div class="flex items-center gap-2">
          <div
            class="w-8 h-8 rounded-lg bg-teal-100 border border-teal-200 flex items-center justify-center"
          >
            <svg
              class="w-4 h-4 text-teal-700"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.5"
                d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
              ></path>
            </svg>
          </div>
          <div>
            <h2 class="text-sm font-bold text-[#0a1f3d]">
              ข้อมูลการดำเนินโครงการ
            </h2>
            <p class="text-[11px] text-gray-400">
              กรอกข้อมูลพื้นฐานสำหรับการดำเนินโครงการ
            </p>
          </div>
        </div>
      </div>

      <div class="p-5 space-y-5">
        <!-- Project info card -->
        <div class="relative rounded-md overflow-hidden" style="background: linear-gradient(135deg, #0a1f3d 0%, #0c3150 50%, #006664 100%);">
          <!-- Decorative elements -->
          <div class="absolute top-0 right-0 w-48 h-48 rounded-full opacity-10" style="background: radial-gradient(circle, #b2bb1e, transparent 70%); transform: translate(30%, -40%);"></div>
          <div class="absolute bottom-0 left-1/3 w-32 h-32 rounded-full opacity-5" style="background: radial-gradient(circle, #fff, transparent 70%);"></div>

          <div class="relative flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 p-5">
            <!-- Left: Project info -->
            <div class="min-w-0 flex-1">
              <p class="text-white/90 font-bold text-[15px] leading-snug line-clamp-2" id="infoProjectName">—</p>
              <p class="text-white/90 text-sm mt-1.5">รหัสโครงการ: <span class="font-mono text-white/90" id="infoProjectCode">—</span></p>
            </div>

            <!-- Right: Budget -->
            <div class="shrink-0 sm:text-right pl-0 sm:pl-4 sm:border-l sm:border-white/10">
              <p class="text-[10px] uppercase tracking-widest text-white/90 font-semibold mb-1">งบประมาณตั้งต้น</p>
              <p class="text-xl font-black text-white" id="infoInitialBudget" style="text-shadow: 0 0 20px rgba(178,187,30,0.3);">—</p>
            </div>
          </div>

          <!-- Bottom accent line -->
          <div class="h-0.5" style="background: linear-gradient(90deg, #006664, #b2bb1e, #006664);"></div>
        </div>

        <!-- ผลการดำเนินงานที่ผ่านมา -->
        <div>
          <label class="block text-sm font-semibold text-[#0a1f3d] mb-1.5"
            >ผลการดำเนินงานที่ผ่านมา</label
          >
          <textarea
            id="pastPerformance"
            rows="3"
            placeholder="อธิบายผลการดำเนินงานที่ผ่านมา (ถ้ามี)"
            class="w-full px-4 py-2.5 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-[#006664]/30 focus:border-[#006664] transition-colors resize-none leading-relaxed"
          ></textarea>
        </div>

        <!-- ความเสี่ยงและการบริหารความเสี่ยง -->
        <div>
          <label class="block text-sm font-semibold text-[#0a1f3d] mb-1.5"
            >ความเสี่ยงและการบริหารความเสี่ยง</label
          >
          <textarea
            id="riskManagement"
            rows="3"
            placeholder="ระบุความเสี่ยงและวิธีการบริหารจัดการ"
            class="w-full px-4 py-2.5 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-[#006664]/30 focus:border-[#006664] transition-colors resize-none leading-relaxed"
          ></textarea>
        </div>

        <!-- ระยะเวลาดำเนินงาน -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div>
            <label class="block text-sm font-semibold text-[#0a1f3d] mb-1.5"
              >วันที่เริ่มดำเนินงาน <span class="text-rose-500">*</span></label
            >
            <div class="relative">
              <input
                id="startDateDisplay"
                type="text"
                readonly
                placeholder="เลือกวันที่"
                class="w-full px-4 py-2.5 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-[#006664]/30 focus:border-[#006664] transition-colors cursor-pointer bg-white"
              />
              <input type="hidden" id="startDate" />
              <svg class="w-4 h-4 text-gray-400 absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
            </div>
          </div>
          <div>
            <label class="block text-sm font-semibold text-[#0a1f3d] mb-1.5"
              >วันที่สิ้นสุดดำเนินงาน <span class="text-rose-500">*</span
              ></label
            >
            <div class="relative">
              <input
                id="endDateDisplay"
                type="text"
                readonly
                placeholder="เลือกวันที่"
                class="w-full px-4 py-2.5 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-[#006664]/30 focus:border-[#006664] transition-colors cursor-pointer bg-white"
              />
              <input type="hidden" id="endDate" />
              <svg class="w-4 h-4 text-gray-400 absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
            </div>
          </div>
          <div class="relative">
            <label class="block text-sm font-semibold text-[#0a1f3d] mb-1.5"
              >จังหวัดที่จัดโครงการ</label
            >
            <input
              id="province"
              type="text"
              autocomplete="off"
              placeholder="ค้นหาจังหวัด..."
              class="w-full px-4 py-2.5 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-[#006664]/30 focus:border-[#006664] transition-colors"
            />
            <div id="provinceDropdown" class="absolute z-10 w-full mt-1 bg-white border border-gray-200 rounded-md shadow-lg hidden max-h-48 overflow-y-auto"></div>
          </div>
        </div>

        <!-- Date summary panel (hidden until both dates selected) -->
        <div id="dateSummaryPanel" class="hidden rounded-xl border border-blue-100 bg-gradient-to-br from-blue-50/50 via-white to-indigo-50/30 p-5 transition-all">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
            <!-- Start date card -->
            <div class="rounded-lg border border-blue-200 bg-white p-4 text-center">
              <p class="text-[11px] text-blue-500 font-semibold mb-1">วันที่เริ่มดำเนินงาน</p>
              <p class="text-lg font-bold text-[#0a1f3d]" id="summaryStartDate">—</p>
            </div>
            <!-- Duration card -->
            <div class="rounded-lg border border-green-200 bg-green-50/50 p-4 text-center">
              <p class="text-[11px] text-green-600 font-semibold mb-1">ระยะเวลาดำเนินงาน</p>
              <p class="text-lg font-bold text-green-700" id="summaryDuration">—</p>
              <p class="text-[10px] text-gray-400 mt-0.5" id="summaryDurationDetail"></p>
            </div>
            <!-- End date card -->
            <div class="rounded-lg border border-indigo-200 bg-white p-4 text-center">
              <p class="text-[11px] text-indigo-500 font-semibold mb-1">วันที่สิ้นสุดดำเนินงาน</p>
              <p class="text-lg font-bold text-[#0a1f3d]" id="summaryEndDate">—</p>
            </div>
          </div>
          <!-- Timeline progress -->
          <div>
            <div class="flex items-center justify-between mb-1.5">
              <span class="text-[11px] font-semibold text-gray-500">ความคืบหน้าระยะเวลา</span>
              <span class="text-[11px] font-bold text-blue-600" id="summaryProgressPct">0%</span>
            </div>
            <div class="w-full h-2.5 rounded-full bg-gray-100 overflow-hidden">
              <div id="summaryProgressBar" class="h-full rounded-full transition-all duration-500" style="width: 0%; background: linear-gradient(90deg, #3b82f6, #8b5cf6);"></div>
            </div>
          </div>
        </div>

        <!-- สถานที่จัดโครงการ + จังหวัด -->
        <div class="grid grid-cols-1 gap-4">
          <div>
            <label class="block text-sm font-semibold text-[#0a1f3d] mb-1.5"
              >สถานที่จัดโครงการ</label
            >
            <input
              id="projectLocation"
              type="text"
              placeholder="เช่น มหาวิทยาลัยเกษตรศาสตร์"
              class="w-full px-4 py-2.5 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-[#006664]/30 focus:border-[#006664] transition-colors"
            />
          </div>
          
        </div>

        <div class="border-t border-dashed border-gray-200 my-1"></div>

        <!-- ══ ผู้ดำเนินโครงการ ══ -->
        <div class="rounded-xl bg-[#f8f9fa] p-5 border border-gray-200 shadow-sm">
          <div class="flex items-center justify-between mb-5">
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5 text-[#006664]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
              <h3 class="text-[15px] font-bold text-[#006664]">ผู้ดำเนินโครงการ</h3>
            </div>
            <button
              id="btnAddOperator"
              type="button"
              class="inline-flex items-center gap-1.5 px-4 py-2.5 text-xs font-semibold text-white bg-[#006664] hover:bg-[#005554] rounded-lg transition-colors shadow-sm cursor-pointer"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"></path></svg>
              เพิ่มผู้ดำเนินโครงการ
            </button>
          </div>
          <div id="operatorsList" class="space-y-4 mb-5"></div>
          
          <div class="rounded-lg p-[1.5px]" style="background: linear-gradient(to right, #006664, #B2BB1E);">
            <div class="rounded-[6.5px] bg-white p-4">
              <div class="flex items-start gap-2.5">
                <div>
                  <h4 class="text-[14px] font-bold text-blue-700 flex items-center gap-1.5 mb-2">
                    <svg class="w-5 h-5 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path></svg> 
                    คำแนะนำ:
                  </h4>
                  <ul class="ml-6 space-y-0.5 text-[12px] text-teal-800 list-disc list-inside leading-relaxed">
                    <li>พิมพ์ชื่อหรืออีเมลเพื่อค้นหาผู้ดำเนินโครงการได้ง่ายขึ้น</li>
                    <li>ระบุหน้าที่ความรับผิดชอบอย่างชัดเจน เช่น หัวหน้าโครงการ, เลขานุการ, ผู้ประสานงาน</li>
                    <li>สามารถเพิ่มผู้ดำเนินโครงการได้หลายคนตามความเหมาะสม</li>
                  </ul>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="border-t border-dashed border-gray-200 my-1"></div>

        <!-- ══ งบประมาณและแหล่งเงิน ══ -->
        <div class="rounded-xl border border-[#b2e1e0] bg-[#f0fdfa] p-5">
          <div class="flex items-center justify-between mb-5">
            <h3 class="text-[15px] font-bold text-[#006664] flex items-center gap-2">
              <svg class="w-5 h-5 text-[#006664]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
              งบประมาณและแหล่งเงิน <span class="text-rose-500 font-normal">*</span>
            </h3>
            <button id="btnAddFunding" type="button" class="inline-flex items-center gap-1.5 px-4 py-2.5 text-xs font-semibold text-white bg-[#006664] hover:bg-[#005554] rounded-lg transition-colors shadow-sm cursor-pointer">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"></path></svg>
              เพิ่มแหล่งเงิน
            </button>
          </div>
          
          <!-- Summary Header (Budget) -->
          <div class="bg-white rounded-xl border border-gray-200 p-5 mb-5 flex justify-between items-center shadow-sm">
            <div>
              <p class="text-[11px] font-medium text-gray-500 mb-1">งบประมาณเริ่มต้น</p>
              <h4 class="text-[20px] font-bold text-[#135776]" id="displayInitialBudget">0.00 <span class="text-[14px]">บาท</span></h4>
              <p class="text-[10px] text-lime-800 mt-1">งบประมาณเริ่มต้นโครงการ</p>
            </div>
            <div class="text-right">
               <p class="text-[10px] text-gray-400 font-mono" id="displayFundingCode">—</p>
               <p class="text-[10px] text-gray-400" id="displayBudgetGroup">ไม่ระบุกลุ่มงบ</p>
               <span class="inline-block bg-blue-100 text-blue-700 text-[10px] px-2 py-0.5 rounded-full mt-1 font-semibold" id="displayProjectType">โครงการหลัก</span>
            </div>
          </div>

          <div id="fundingList" class="space-y-4"></div>
          
          <!-- Summary Footer -->
          <div id="fundingSummary" class="mt-5 bg-[#ebffed] rounded-xl border border-gray-200 p-5 shadow-sm">
             <div class="flex justify-between items-center mb-3">
               <p class="text-sm font-bold text-gray-700">แหล่งเงินหลัก:</p>
               <p class="text-lg font-bold text-[#00c34a]" id="mainFundingTotal">0.00 บาท</p>
             </div>
             <div class="flex justify-between items-center mb-1">
               <p class="text-[10px] font-bold text-gray-500">เปอร์เซ็นต์ของงบประมาณโครงการ:</p>
               <p class="text-[10px] font-bold text-[#00c34a]" id="fundingPercent">0.0%</p>
             </div>
             <div class="w-full h-1.5 bg-gray-200 rounded-full mb-3 overflow-hidden">
               <div id="fundingProgressBar" class="h-full bg-[#00c34a] rounded-full transition-all" style="width: 0%"></div>
             </div>
             <div id="fundingStatusAlert" class="bg-green-100 border border-green-200 text-[#009b3a] text-[11px] px-3 py-2.5 rounded-lg font-medium">
               สมบูรณ์: แหล่งเงินหลักครบตามงบประมาณโครงการ
             </div>
          </div>
        </div>

