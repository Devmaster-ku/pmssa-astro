---
import AuthLayout from '../../layouts/AuthenticatedLayout.astro';
---

<AuthLayout title="แก้ไขข้อมูลโครงการ">

  <!-- ══ PAGE HEADER ══ -->
  <div class="relative rounded-sm overflow-hidden mb-5 shadow-lg"
       style="background: linear-gradient(135deg, #0c2957 0%, #0a4068 45%, #006664 100%);">
    <div class="absolute top-0 left-0 right-0 h-1.5" style="background: linear-gradient(90deg, #e97316, #f59e0b, #e97316);"></div>
    <div class="absolute -right-20 -top-20 w-80 h-80 rounded-full pointer-events-none"
         style="background: radial-gradient(circle, rgba(249,115,22,0.12) 0%, transparent 65%);"></div>
    <div class="absolute inset-0 pointer-events-none opacity-[0.03]"
         style="background-image: repeating-linear-gradient(45deg, #ffffff 0, #ffffff 1px, transparent 0, transparent 12px);"></div>

    <div class="relative z-10 p-5 sm:p-6">
      <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3">
        <!-- Left: title -->
        <div class="flex items-start gap-3">
          <a href="/projects" class="mt-1 shrink-0 w-8 h-8 rounded-lg bg-white/10 hover:bg-white/20 border border-white/20 flex items-center justify-center transition-colors" title="กลับ">
            <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
            </svg>
          </a>
          <div>
            <div class="flex items-center gap-2 flex-wrap">
              <h1 class="text-white text-lg font-bold leading-tight">แก้ไขข้อมูลโครงการ</h1>
              <span id="headerTypeBadge" class="hidden inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-orange-500/90 text-white border border-orange-400/50">
                โครงการย่อย
              </span>
            </div>
            <p class="text-white/70 text-sm mt-0.5" id="headerBreadcrumb">แก้ไขข้อมูลรายละเอียดโครงการที่เลือก</p>
          </div>
        </div>
        <!-- Right: step indicator -->
        <div class="shrink-0 flex items-center gap-2 sm:mt-1">
          <span class="text-white/50 text-xs">ขั้นตอน</span>
          <span id="stepBadge" class="px-3 py-1 rounded-full text-sm font-bold bg-orange-500 text-white">1/3</span>
        </div>
      </div>

      <!-- Step Nav -->
      <div class="mt-5 flex items-center gap-0">
        <!-- Step 1 -->
        <div class="flex items-center gap-2">
          <div id="stepCircle1" class="w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold border-2 transition-all
                                        bg-orange-500 border-orange-500 text-white">1</div>
          <span id="stepLabel1" class="text-white text-xs font-semibold hidden sm:block">ข้อมูลพื้นฐาน</span>
        </div>
        <div id="stepLine1" class="flex-1 h-0.5 mx-2 rounded transition-all bg-white/20 min-w-[20px]"></div>
        <!-- Step 2 -->
        <div class="flex items-center gap-2">
          <div id="stepCircle2" class="w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold border-2 transition-all
                                        bg-white/10 border-white/30 text-white/50">2</div>
          <span id="stepLabel2" class="text-white/50 text-xs hidden sm:block">รายละเอียดโครงการ</span>
        </div>
        <div id="stepLine2" class="flex-1 h-0.5 mx-2 rounded transition-all bg-white/20 min-w-[20px]"></div>
        <!-- Step 3 -->
        <div class="flex items-center gap-2">
          <div id="stepCircle3" class="w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold border-2 transition-all
                                        bg-white/10 border-white/30 text-white/50">3</div>
          <span id="stepLabel3" class="text-white/50 text-xs hidden sm:block">เป้าหมาย/ตัวชี้วัด</span>
        </div>
      </div>
    </div>
  </div>

  <!-- ══ LOADING STATE ══ -->
  <div id="pageLoading" class="flex flex-col items-center justify-center py-20 gap-3 text-gray-400">
    <svg class="w-8 h-8 animate-spin opacity-40" fill="none" viewBox="0 0 24 24">
      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/>
    </svg>
    <p class="text-sm">กำลังโหลดข้อมูลโครงการ...</p>
  </div>

  <!-- ══ STEP 1: ข้อมูลพื้นฐาน ══ -->
  <div id="step1" class="hidden space-y-4">
    <!-- Main card -->
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
      <!-- Card header -->
      <div class="px-5 py-3.5 border-b border-gray-100 flex items-center justify-between bg-gray-50/60">
        <div class="flex items-center gap-2">
          <div class="w-8 h-8 rounded-lg bg-green-100 border border-green-200 flex items-center justify-center">
            <svg class="w-4 h-4 text-green-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
          </div>
          <h2 class="text-sm font-bold text-[#0a1f3d]">ข้อมูลพื้นฐานโครงการ</h2>
        </div>
      </div>

      <div class="p-5 space-y-5">
        <!-- โครงการหลัก section -->
        <div id="parentProjectSection" class="hidden">
          <div class="flex items-center justify-between mb-2">
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide">โครงการหลัก</p>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-semibold bg-orange-100 text-orange-700 border border-orange-200">
              โครงการย่อย
            </span>
          </div>

          <!-- Parent project info card -->
          <div class="rounded-md border border-green-200 bg-green-50 p-4">
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2">
              <div class="min-w-0">
                <p class="text-sm font-semibold text-[#0a1f3d] leading-snug" id="parentName">—</p>
                <p class="text-xs text-gray-500 mt-0.5">รหัสโครงการ: <span class="font-mono text-[#006664] font-semibold" id="parentCode">—</span></p>
              </div>
              <div class="shrink-0 text-right sm:text-right">
                <p class="text-[11px] text-gray-400">งบประมาณทั้งสิ้น</p>
                <p class="text-sm font-bold text-[#0a1f3d]" id="parentInitialBudget">—</p>
                <p class="text-[11px] text-gray-400 mt-1">หน่วยงาน</p>
                <p class="text-xs text-gray-600" id="parentOrgName">—</p>
              </div>
            </div>
            <div class="mt-2 pt-2 border-t border-green-200 flex items-center gap-1.5">
              <span class="text-[11px] text-gray-500">งบประมาณคงเหลือ:</span>
              <span class="text-sm font-bold text-rose-600" id="parentAllocatedBudget">—</span>
            </div>
          </div>
        </div>



        <!-- Project name field -->
        <div>
          <label class="block text-sm font-semibold text-[#0a1f3d] mb-1.5">
            ชื่อโครงการ
            <span class="text-rose-500 ml-0.5">*</span>
          </label>
          <textarea id="subName" rows="3"
            placeholder="กรอกชื่อโครงการย่อย ให้ชัดเจนและสามารถระบุวัตถุประสงค์ได้"
            class="w-full px-4 py-2.5 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-[#006664]/30 focus:border-[#006664] transition-colors resize-none leading-relaxed"></textarea>
        </div>

        <!-- Document reference -->
        <div>
          <label class="block text-sm font-semibold text-[#0a1f3d] mb-1.5">
            อ้างอิงเลขที่เอกสาร
            <span class="text-[11px] font-normal text-gray-400 ml-1">(ไม่บังคับ)</span>
          </label>
          <input id="docRef" type="text"
            placeholder="เช่น DOC-2024-001"
            class="w-full px-4 py-2.5 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-[#006664]/30 focus:border-[#006664] transition-colors font-mono"/>
        </div>

        <!-- Budget + หน่วยงานที่รับผิดชอบ + หัวหน้า + ผู้รับผิดชอบ -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-4">
          <!-- Budget allocation field -->
          <div class="lg:col-span-2">
            <label class="block text-sm font-semibold text-[#0a1f3d] mb-1.5">
              จำนวนเงินในปีจัดสรร
              <span class="text-rose-500 ml-0.5">*</span>
            </label>
            <div class="relative">
              <input id="subBudget" type="text" inputmode="decimal"
                placeholder="กรอกจำนวนเงิน"
                class="w-full pl-4 pr-12 py-2.5 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-[#006664]/30 focus:border-[#006664] transition-colors"/>
              <span class="absolute right-4 top-1/2 -translate-y-1/2 text-sm text-gray-400 font-medium pointer-events-none">บาท</span>
            </div>
            <p class="text-[10px] text-gray-400 mt-1" id="budgetHint">ต้องไม่เกินงบประมาณคงเหลือ</p>
          </div>

          <!-- หน่วยงานที่รับผิดชอบโครงการ -->
          <div class="lg:col-span-4">
            <label class="block text-sm font-semibold text-[#0a1f3d] mb-1.5">
              หน่วยงานที่รับผิดชอบโครงการ
              <span class="text-rose-500 ml-0.5">*</span>
            </label>
            <select id="deptSelect"
              class="w-full px-3 py-2.5 text-sm border border-gray-300 rounded-md bg-white focus:outline-none focus:ring-2 focus:ring-[#006664]/30 focus:border-[#006664] transition-colors appearance-none">
              <option value="">— เลือกหน่วยงาน —</option>
            </select>
            <p class="text-[10px] text-gray-400 mt-1">หน่วยงานหลักหรือย่อยที่รับผิดชอบโครงการนี้</p>
          </div>

          <!-- หัวหน้าโครงการ -->
          <div class="lg:col-span-3">
            <label class="block text-sm font-semibold text-[#0a1f3d] mb-1.5">
              หัวหน้าโครงการ <span class="text-rose-500">*</span>
            </label>
            <div id="leadDropdownWrap" class="relative">
              <div class="relative">
                <input id="leadSearch" type="text" autocomplete="off"
                  placeholder="พิมพ์ชื่อหรือชื่อผู้ใช้เพื่อค้นหา..."
                  class="w-full pl-4 pr-10 py-2.5 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-[#006664]/30 focus:border-[#006664] transition-colors"/>
                <svg id="leadClearBtn" class="hidden absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 cursor-pointer hover:text-rose-500"
                  fill="none" stroke="currentColor" viewBox="0 0 24 24" onclick="clearLead()">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
              </div>
              <div id="leadDropdownPanel"
                class="hidden absolute z-30 left-0 right-0 mt-1 bg-white border border-gray-200 rounded-md shadow-xl overflow-hidden max-h-52 overflow-y-auto">
                <div id="leadDropdownItems" class="py-1">
                  <p class="px-4 py-3 text-xs text-gray-400">กำลังโหลด...</p>
                </div>
              </div>
            </div>
            <p class="text-[11px] text-gray-400 mt-1" id="hintLead">เลือกหัวหน้าโครงการจากรายชื่อผู้ใช้ในระบบ</p>
          </div>

          <!-- ผู้รับผิดชอบโครงการ -->
          <div class="lg:col-span-3">
            <label class="block text-sm font-semibold text-[#0a1f3d] mb-1.5">
              ผู้รับผิดชอบโครงการ
              <span class="text-[11px] font-normal text-gray-400 ml-1">(ไม่บังคับ)</span>
            </label>
            <div id="responsibleDropdownWrap" class="relative">
              <div class="relative">
                <input id="responsibleSearch" type="text" autocomplete="off"
                  placeholder="พิมพ์ชื่อเพื่อค้นหา..."
                  class="w-full pl-4 pr-10 py-2.5 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-[#006664]/30 focus:border-[#006664] transition-colors"/>
                <svg id="responsibleClearBtn" class="hidden absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 cursor-pointer hover:text-rose-500"
                  fill="none" stroke="currentColor" viewBox="0 0 24 24" onclick="clearResponsible()">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
              </div>
              <div id="responsibleDropdownPanel"
                class="hidden absolute z-30 left-0 right-0 mt-1 bg-white border border-gray-200 rounded-md shadow-xl overflow-hidden max-h-52 overflow-y-auto">
                <div id="responsibleDropdownItems" class="py-1">
                  <p class="px-4 py-3 text-xs text-gray-400">กำลังโหลด...</p>
                </div>
              </div>
            </div>
            <p class="text-[11px] text-gray-400 mt-1">บุคคลที่รับผิดชอบดำเนินโครงการ</p>
          </div>
        </div>

        <!-- Notes -->
        <div>
          <label class="block text-sm font-semibold text-[#0a1f3d] mb-1.5">
            หมายเหตุ
            <span class="text-[11px] font-normal text-gray-400 ml-1">(ไม่บังคับ)</span>
          </label>
          <textarea id="notes" rows="3"
            placeholder="หมายเหตุเพิ่มเติม (ถ้ามี)"
            class="w-full px-4 py-2.5 text-sm border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-[#006664]/30 focus:border-[#006664] transition-colors resize-none leading-relaxed"></textarea>
        </div>
      </div>

      <!-- Card footer: next button -->
      <div class="px-5 py-4 bg-gray-50/60 border-t border-gray-100 flex items-center justify-between gap-3">
        <a href="/projects" class="text-sm text-gray-500 hover:text-[#006664] transition-colors">
          กลับไปรายการโครงการ
        </a>
        <button id="btnStep1Next"
          class="inline-flex items-center gap-2 px-5 py-2.5 bg-[#006664] hover:bg-[#005554] text-white text-sm font-semibold rounded-md transition-colors shadow-sm disabled:opacity-60">
          <svg id="step1Spinner" class="w-4 h-4 animate-spin hidden" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/>
          </svg>
          <span id="step1BtnText">บันทึกและดำเนินการต่อ</span>
          <svg id="step1Arrow" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Tip panel -->
    <div class="rounded-md border border-blue-200 bg-blue-50 px-4 py-3.5">
      <p class="text-xs font-semibold text-blue-700 mb-1.5">คำแนะนำ: ข้อมูลพื้นฐานโครงการ</p>
      <ul class="space-y-1 text-xs text-blue-600 list-disc list-inside leading-relaxed">
        <li>เลือกโครงการหลักที่ต้องการสร้างโครงการย่อยให้ถูกต้อง</li>
        <li>ประมาณการงบประมาณที่ต้องการสำหรับโครงการย่อยนี้</li>
        <li>ชื่อโครงการควรสื่อถึงกิจกรรมหรือขอบเขตงานที่ชัดเจน</li>
        <li>กำหนดงบประมาณสำรองไว้สำหรับค่าใช้จ่ายที่ไม่คาดคิด</li>
        <li>เลือกกลุ่มประมาณให้ตรงกับประเภทของกิจกรรมโครงการ</li>
      </ul>
    </div>
  </div>

  <!-- ══ STEP 2: รายละเอียดโครงการ ══ -->
  <div id="step2" class="hidden space-y-4">
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
      <!-- Card header -->
      <div class="px-5 py-3.5 border-b border-gray-100 flex items-center gap-2 bg-gray-50/60">
        <div class="w-8 h-8 rounded-lg bg-orange-100 border border-orange-200 flex items-center justify-center">
          <svg class="w-4 h-4 text-orange-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
        </div>
        <h2 class="text-sm font-bold text-[#0a1f3d]">รายละเอียดโครงการ</h2>
      </div>

      <div class="p-5 space-y-5">
        <!-- Auto code section -->
        <div>
          <div class="flex items-center justify-between mb-2">
            <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide">การสร้างรหัสโครงการ</p>
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-[11px] font-medium bg-teal-50 text-teal-700 border border-teal-200">
              รหัสโดยอัตโนมัติ
            </span>
          </div>
          <div class="rounded-md border border-teal-200 bg-teal-50 p-4">
            <p class="text-[11px] text-gray-500 mb-1">รหัสโครงการย่อย (สร้างอัตโนมัติ)</p>
            <p class="text-base font-bold text-[#006664] font-mono" id="generatedCode">—</p>
            <p class="text-[11px] text-gray-400 mt-0.5">สร้างจากรหัสหลัก: <span id="parentCodeRef" class="font-mono text-gray-600">—</span></p>
          </div>
        </div>

        <!-- Budget dropdowns: compact 4-col grid -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
          <div>
            <label class="block text-xs font-semibold text-[#0a1f3d] mb-1">
              งบประมาณ <span class="text-rose-500">*</span>
            </label>
            <select id="subsidySelect"
              class="w-full px-2.5 py-2 text-sm border border-gray-300 rounded-md bg-white focus:outline-none focus:ring-2 focus:ring-[#006664]/30 focus:border-[#006664] transition-colors appearance-none">
              <option value="">-- เลือก --</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-semibold text-[#0a1f3d] mb-1">
              ประเภทงบประมาณ <span class="text-rose-500">*</span>
            </label>
            <select id="budgetTypeSelect"
              class="w-full px-2.5 py-2 text-sm border border-gray-300 rounded-md bg-white focus:outline-none focus:ring-2 focus:ring-[#006664]/30 focus:border-[#006664] transition-colors appearance-none">
              <option value="">-- เลือก --</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-semibold text-[#0a1f3d] mb-1">
              กลุ่มประมาณ <span class="text-rose-500">*</span>
            </label>
            <select id="budgetGroupSelect"
              class="w-full px-2.5 py-2 text-sm border border-gray-300 rounded-md bg-white focus:outline-none focus:ring-2 focus:ring-[#006664]/30 focus:border-[#006664] transition-colors appearance-none">
              <option value="">-- เลือก --</option>
            </select>
          </div>
          <div>
            <label class="block text-xs font-semibold text-[#0a1f3d] mb-1">
              ปีงบประมาณ <span class="text-rose-500">*</span>
            </label>
            <select id="yearSelect"
              class="w-full px-2.5 py-2 text-sm border border-gray-300 rounded-md bg-white focus:outline-none focus:ring-2 focus:ring-[#006664]/30 focus:border-[#006664] transition-colors appearance-none">
              <option value="">-- เลือก --</option>
            </select>
          </div>
        </div>

        <!-- Budget display -->
        <div class="rounded-md border border-gray-200 bg-gray-50 p-4">
          <p class="text-xs font-semibold text-gray-500 mb-1">งบประมาณสำหรับโครงการย่อยนี้</p>
          <p class="text-2xl font-bold text-[#0a1f3d]" id="displayBudget">0.00 <span class="text-base font-medium text-gray-400">บาท</span></p>
          <p class="text-[11px] text-gray-400 mt-1" id="displayBudgetNote">จัดสรรจากงบประมาณหลัก</p>
        </div>

        <div class="border-t border-dashed border-gray-200 my-1"></div>


        <!-- ── ความสอดคล้องกับยุทธศาสตร์ ── -->
        <div>
          <p class="text-[11px] font-semibold text-gray-500 uppercase tracking-widest mb-3 flex items-center gap-1.5">
