---
import '../styles/global.css';

export interface Props {
  title?: string;
}
const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="th">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="KU-PMS ระบบบริหารจัดการโครงการ มหาวิทยาลัยเกษตรศาสตร์" />
    <title>{title ? `${title} — KU-PMS` : 'KU-PMS'}</title>
    <script is:inline>
      (function() {
        const stored = localStorage.getItem('ku_theme');
        document.documentElement.setAttribute('data-theme', stored || 'light');
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="bg-gray-100 font-[Sarabun,Inter,sans-serif]">
    <div id="app" class="min-h-screen flex flex-col">
      <!-- Top Navbar -->
      <header class="bg-linear-to-r from-[#006664] via-[#b2bb1e] to-[#006664] shadow-lg sticky top-0 z-50">
        <div class="max-w-360 mx-auto px-4 sm:px-6 py-3">
          <div class="flex items-center justify-between">
            <!-- Left: Logo & System Name -->
            <div class="flex items-center gap-3 sm:gap-4 min-w-0">
              <div class="w-10 h-10 sm:w-12 sm:h-12 bg-white rounded-sm flex items-center justify-center border border-white/20 shrink-0 p-1">
                <img src="/images/ku_logo.png" alt="KU Logo" class="w-full h-full object-contain" />
              </div>
              <div class="min-w-0 hidden sm:block">
                <h1 class="text-white font-semibold text-sm lg:text-base leading-tight">ระบบบริหารโครงการ เพื่อขับเคลื่อนยุทธศาสตร์</h1>
                <p class="text-white text-base">มหาวิทยาลัยเกษตรศาสตร์</p>
              </div>
              <!-- Mobile: short name -->
              <div class="min-w-0 sm:hidden">
                <h1 class="text-white font-bold text-sm leading-tight">KU-PMS</h1>
                <p class="text-white/70 text-xs">ม.เกษตรศาสตร์</p>
              </div>
            </div>

            <!-- Desktop Navigation -->
            <nav class="hidden lg:flex items-center gap-6">
              <a href="/dashboard" class="nav-link flex items-center gap-2 text-white/80 hover:text-white text-sm font-medium transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
                </svg>
                หน้าแรก
              </a>
              <a href="/settings" class="nav-link flex items-center gap-2 text-white/80 hover:text-white text-sm font-medium transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
                ตั้งค่าระบบ
              </a>
              <a href="/profile" class="nav-link flex items-center gap-2 text-white/80 hover:text-white text-sm font-medium transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                </svg>
                โปรไฟล์
              </a>
              <button id="logoutBtn" class="flex items-center gap-2 px-4 py-2 bg-[#b2bb1e] hover:bg-[#9da61b] text-white text-sm font-medium rounded-lg transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
                </svg>
                ลงชื่อออก
              </button>
            </nav>

            <!-- Mobile Hamburger Button -->
            <button id="mobileMenuBtn" class="lg:hidden p-2 text-white/80 hover:text-white transition-colors" aria-label="เปิดเมนู">
              <svg class="w-6 h-6" id="menuIconOpen" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
              </svg>
              <svg class="w-6 h-6 hidden" id="menuIconClose" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
            </button>
          </div>

          <!-- Mobile Navigation Menu -->
          <nav id="mobileMenu" class="hidden lg:hidden mt-3 pt-3 border-t border-white/20">
            <div class="flex flex-col gap-1">
              <a href="/dashboard" class="nav-link flex items-center gap-3 px-3 py-2.5 text-white/80 hover:text-white hover:bg-white/10 rounded-lg text-sm font-medium transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
                </svg>
                หน้าแรก
              </a>
              <a href="#" class="nav-link flex items-center gap-3 px-3 py-2.5 text-white/80 hover:text-white hover:bg-white/10 rounded-lg text-sm font-medium transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
                ตั้งค่าระบบ
              </a>
              <a href="/profile" class="nav-link flex items-center gap-3 px-3 py-2.5 text-white/80 hover:text-white hover:bg-white/10 rounded-lg text-sm font-medium transition-colors">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                </svg>
                โปรไฟล์
              </a>
              <button id="logoutBtnMobile" class="flex items-center gap-3 px-3 py-2.5 text-white/90 hover:text-white hover:bg-white/10 rounded-lg text-sm font-medium transition-colors w-full text-left mt-1">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
                </svg>
                ลงชื่อออก
              </button>
            </div>
          </nav>
        </div>
      </header>

      <!-- Main Content -->
      <main class="flex-1 max-w-360 w-full mx-auto px-2 sm:px-4 py-4 sm:py-2">
        <slot />
      </main>
    </div>

    <!-- Toast Notification (global) -->
    <div id="toastContainer" style="position:fixed;top:100px;right:20px;z-index:9999;display:flex;flex-direction:column;gap:12px;pointer-events:none;"></div>

    <style>
      @keyframes toastProgress {
        from { transform: scaleX(1); }
        to   { transform: scaleX(0); }
      }
    </style>

    <script>
      // Global toast function
      (window as any).showToast = function(message: string, type = 'success') {
        const container = document.getElementById('toastContainer');
        if (!container) return;
        const isSuccess = type === 'success';
        const isWarning = type === 'warning';
        const iconBg   = isSuccess ? '#006664' : isWarning ? '#d97706' : '#ef4444';
        const progress = isSuccess ? '#00a896' : isWarning ? '#fbbf24' : '#f87171';
        const label    = isSuccess ? 'สำเร็จ' : isWarning ? 'แจ้งเตือน' : 'ผิดพลาด';
        const iconPath = isSuccess
          ? '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>'
          : isWarning
          ? '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>'
          : '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/>';

        const toast = document.createElement('div');
        toast.setAttribute('data-toast', '');
        toast.style.cssText = [
          'pointer-events:auto',
          'display:flex',
          'align-items:stretch',
          'width:320px',
          'border-radius:12px',
          'background:#fff',
          'box-shadow:0 8px 24px rgba(0,0,0,0.12),0 2px 8px rgba(0,0,0,0.08)',
          'overflow:hidden',
          'opacity:0',
          'transform:translateX(20px)',
          'transition:opacity 0.3s ease,transform 0.3s ease',
        ].join(';');

        toast.innerHTML = `
          <div style="width:48px;background:${iconBg};display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <svg width="22" height="22" fill="none" stroke="#fff" viewBox="0 0 24 24">${iconPath}</svg>
          </div>
          <div style="flex:1;padding:12px 14px 10px;">
            <div style="font-size:11px;font-weight:700;color:${iconBg};text-transform:uppercase;letter-spacing:0.06em;margin-bottom:2px;">${label}</div>
            <div style="font-size:13px;color:#374151;line-height:1.5;">${message}</div>
            <div style="margin-top:8px;height:3px;border-radius:99px;background:#f3f4f6;overflow:hidden;">
              <div style="height:100%;width:100%;background:${progress};border-radius:99px;transform-origin:left;animation:toastProgress 3s linear forwards;"></div>
            </div>
          </div>
          <button onclick="this.closest('[data-toast]').remove()"
            style="padding:10px 12px 0 0;background:none;border:none;cursor:pointer;color:#9ca3af;font-size:16px;line-height:1;align-self:flex-start;">✕</button>
        `;

        container.appendChild(toast);
        requestAnimationFrame(() => {
          toast.style.opacity = '1';
          toast.style.transform = 'translateX(0)';
        });
        setTimeout(() => {
          toast.style.opacity = '0';
          toast.style.transform = 'translateX(20px)';
          toast.addEventListener('transitionend', () => toast.remove(), { once: true });
        }, 3200);
      };

      // =====================
      // Global apiFetch — auto refresh token on 401
      // =====================
      const _AUTH_API = import.meta.env.PUBLIC_API_URL || 'http://localhost:3000';
      let _isRefreshing = false;
      let _refreshQueue: ((t: string) => void)[] = [];

      (window as any).apiFetch = async function(url: string, options: RequestInit = {}) {
        const buildHeaders = (token: string): HeadersInit => ({
          'Content-Type': 'application/json',
          ...((options as any).headers || {}),
          'Authorization': `Bearer ${token}`
        });

        const accessToken = localStorage.getItem('ku_access_token') || '';
        let res = await fetch(url, { ...options, headers: buildHeaders(accessToken) });

        if (res.status !== 401) return res;

        // --- token หมดอายุ: ขอ refresh ---
        const refreshToken = localStorage.getItem('ku_refresh_token');
        if (!refreshToken) { _forceLogout(); return res; }

        if (_isRefreshing) {
          // มี refresh กำลังทำอยู่ → รอ แล้ว retry
          return new Promise<Response>((resolve) => {
            _refreshQueue.push(async (newToken: string) => {
              resolve(await fetch(url, { ...options, headers: buildHeaders(newToken) }));
            });
          });
        }

        _isRefreshing = true;
        try {
          const rr = await fetch(`${_AUTH_API}/api/auth/refresh`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ refreshToken })
          });
          const rd = await rr.json();
          if (!rd.success || !rd.accessToken) throw new Error('refresh failed');

          localStorage.setItem('ku_access_token', rd.accessToken);
          localStorage.setItem('ku_refresh_token', rd.refreshToken);

          // flush queue
          _refreshQueue.forEach(cb => cb(rd.accessToken));
          _refreshQueue = [];

          // retry original request
          res = await fetch(url, { ...options, headers: buildHeaders(rd.accessToken) });
        } catch {
          _refreshQueue = [];
          _forceLogout();
        } finally {
          _isRefreshing = false;
        }
        return res;
      };

      function _forceLogout() {
        localStorage.removeItem('ku_access_token');
        localStorage.removeItem('ku_refresh_token');
        localStorage.removeItem('ku_user');
        localStorage.removeItem('ku_active_affiliation');
        window.location.replace('/login');
      }

      // =====================
      // Proactive token refresh — refresh ก่อน token หมดอายุ
      // =====================
      let _proactiveRefreshTimer: ReturnType<typeof setTimeout> | null = null;

      async function _doProactiveRefresh() {
        const refreshToken = localStorage.getItem('ku_refresh_token');
        if (!refreshToken) return;
        if (_isRefreshing) return; // มี refresh กำลังทำอยู่แล้ว

        _isRefreshing = true;
        try {
          const rr = await fetch(`${_AUTH_API}/api/auth/refresh`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ refreshToken })
          });
          const rd = await rr.json();
          if (!rd.success || !rd.accessToken) throw new Error('refresh failed');

          localStorage.setItem('ku_access_token', rd.accessToken);
          localStorage.setItem('ku_refresh_token', rd.refreshToken);

          _refreshQueue.forEach(cb => cb(rd.accessToken));
          _refreshQueue = [];

          _scheduleProactiveRefresh(); // นัดหมายครั้งถัดไป
        } catch {
          _refreshQueue = [];
          _forceLogout();
        } finally {
          _isRefreshing = false;
        }
      }

      function _scheduleProactiveRefresh() {
        if (_proactiveRefreshTimer) clearTimeout(_proactiveRefreshTimer);
        const accessToken = localStorage.getItem('ku_access_token');
        if (!accessToken) return;
        try {
          const payload = JSON.parse(atob(accessToken.split('.')[1]));
          const exp: number = payload.exp; // Unix timestamp (วินาที)
          const now = Math.floor(Date.now() / 1000);
          const msUntilRefresh = Math.max(0, (exp - now - 60)) * 1000; // refresh 60 วินาทีก่อนหมดอายุ
          _proactiveRefreshTimer = setTimeout(_doProactiveRefresh, msUntilRefresh);
        } catch {
          // JWT decode ล้มเหลว — ใช้ fallback refresh ทุก 10 นาที
          _proactiveRefreshTimer = setTimeout(_doProactiveRefresh, 10 * 60 * 1000);
        }
      }

      _scheduleProactiveRefresh();

      // Auth guard
      const token = localStorage.getItem('ku_access_token');
      const userStr = localStorage.getItem('ku_user');
      if (!token || !userStr) {
        window.location.replace('/login');
      } else {
        const appEl = document.getElementById('app');
        if (appEl) appEl.style.opacity = '1';
      }

      // Navigation active state
      document.addEventListener('DOMContentLoaded', () => {
        const current = window.location.pathname;
        document.querySelectorAll('.nav-link').forEach(el => {
          if (el.getAttribute('href') === current) {
            el.classList.remove('text-white/80');
            el.classList.add('text-white');
          }
        });
      });

      // Mobile menu toggle
      const mobileMenuBtn = document.getElementById('mobileMenuBtn');
      const mobileMenu = document.getElementById('mobileMenu');
      const menuIconOpen = document.getElementById('menuIconOpen');
      const menuIconClose = document.getElementById('menuIconClose');

      mobileMenuBtn?.addEventListener('click', () => {
        mobileMenu?.classList.toggle('hidden');
        menuIconOpen?.classList.toggle('hidden');
        menuIconClose?.classList.toggle('hidden');
      });

      // Logout handler
      function handleLogout() {
        fetch('http://localhost:3000/api/auth/logout', { method: 'POST' }).catch(() => {});
        localStorage.removeItem('ku_access_token');
        localStorage.removeItem('ku_refresh_token');
        localStorage.removeItem('ku_user');
        localStorage.removeItem('ku_active_affiliation');
        window.location.replace('/login');
      }
      document.getElementById('logoutBtn')?.addEventListener('click', handleLogout);
      document.getElementById('logoutBtnMobile')?.addEventListener('click', handleLogout);
    </script>
  </body>
</html>
